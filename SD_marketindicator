'use strict';
// ═══════════════════════════════════════════════════════════════════════
// SD_MarketReader v2.1  —  Clean rebuild from market first principles
//
// WHAT MOVES NQ:
//   1. Options delta hedging   → EXP sigma levels
//   2. Liquidity sweeps        → prev session / week H/L
//   3. Rebalancing             → price voids (untraded zones)
//   4. Fair value gravity      → VWAP / session open
//
// BEHAVIORS AT LEVELS (the only 3 signals):
//   ABSORPTION  → passive orders absorbing aggressive flow → reversal
//   EXHAUSTION  → aggressive side ran out of fuel → reversal
//   SWEEP       → stop hunt complete, algos reversing → snap-back
//
// TRIGGER: single delta flip bar at the level
//
// RUN ON: 4096-tick chart (NY session), 3072-tick chart (evening)
//
// v2.1 RENDERING CHANGES:
//   • Removed infinite-line clutter for every level
//   • Sigma lines drawn by expPlotter (session-bounded), labels at right
//   • Position lines (SL/TP/Entry/Trail) drawn as finite segments only when in trade
//   • Context levels (PSH/PDH/PWH/Asia/VWAP) shown as labels, only within 4 ATR
//   • Delta walls/footprint: top 2 nearest only, within 3 ATR
//   • Proximity arrow → on labels when price within 1.5 ATR
// ═══════════════════════════════════════════════════════════════════════

const predef       = require('./tools/predef');
const { px, du, op } = require('./tools/graphics');
const plottingTools  = require('./tools/plotting');

// ── CONSTANTS ────────────────────────────────────────────────────────────
const WARM_BARS  = 30;   // bars before trading starts (tick charts warm up fast)
// ╔══════════════════════════════════════════════════════════════════════╗
// ║  EXPECTED MOVE — set these in the indicator's SETTINGS panel.          ║
// ║  (The panel works now — no code editing needed.) Fields:               ║
// ║    expMoveDaily   — daily move; update every morning. Daily bands =     ║
// ║                     9:30 open ± value × {0.5, 1, 1.5, 2}.               ║
// ║    expMoveWeekly  — weekly move; set once at week start (0 = off).      ║
// ║    expMoveMonthly — monthly move; set once at month start (0 = off).    ║
// ║    rthOpen        — today's exact 9:30 RTH open price (0 = auto-detect).║
// ║                                                                        ║
// ║  The constants below are only a FALLBACK used when the matching        ║
// ║  Settings field is left at 0. Leave them at 0 to drive everything      ║
// ║  from the Settings panel.                                              ║
// ╚══════════════════════════════════════════════════════════════════════╝
const EM_DAILY   = 0;    // fallback daily move  (0 = use Settings)
const EM_WEEKLY  = 0;    // fallback weekly move (0 = use Settings / off)
const EM_MONTHLY = 0;    // fallback monthly move(0 = use Settings / off)
