        nyLunchBlackout:   predef.paramSpecs.number(0, 1, 0),
        // ── CAPITAL PRESERVATION (critical for trailing-drawdown accounts) ──
        // breakevenAtR: when trade is up X×R unrealized, move SL to entry+1tk.
