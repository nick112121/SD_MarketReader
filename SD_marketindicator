        //   Set to 0 to disable. Default ON.
        thesisExit:        predef.paramSpecs.number(1, 1, 0),
        // ── HUD APPEARANCE CONTROLS ──
        // hudScale: multiplier for ALL text on the chart. 1.0 = default,
