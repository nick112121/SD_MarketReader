const MAX_HOLD   = 80;   // max bars in a trade
const PAUSE_BARS = 50;   // bars to pause after 3/5 losses
const REPEAT_LOSS_BARS = 60; // block same dir+level re-entry within N bars of a loss (1hr on 1m bars)

class MarketReader {

    init() {
        // Tradovate calls init() with NO arguments and wires the params onto
        // this.props itself before map() runs. Do not declare/assign props
        // here — taking an argument or assigning this.props can interfere
        // with the framework's parameter binding.
        this.H=[]; this.L=[]; this.O=[]; this.C=[]; this.V=[]; this.D=[];
        this.barIdx=0;
        this.lastChartIdx=0;
        this.atr=4;
        // ── INSTRUMENT PROFILE ──
        // Auto-detected on first bar from price magnitude. Defaults to
        // NQ; switches to Gold if first close is below 10000. Each
        // profile sets the four price-sensitive constants that aren't
        // ATR-relative: tick size, footprint bucket, daily range floor,
        // and ATR floor. Everything else in the indicator scales with
        // ATR / avgVol and adapts naturally.
        this._instrument = 'NQ';        // 'NQ' or 'GC' or 'OTHER'
        this._profileLoaded = false;
        this.tickSize = 0.25;            // NQ default
        this.footprintBucket = 4;        // NQ default (16 ticks)
        this.minSessionRange = 50;       // NQ default (typical daily range)
        this.atrFloor = 0.25;            // NQ default (1 tick)
        this.autoContractValue = 2;      // NQ micro default ($2/pt)
        this._trBuf=[];     // deterministic ATR seeding buffer (first 14 bars)
        this.volBuf=[]; this.avgVol=1;
        this.prevDelta=0; this.cumDelta=0;
        this.sessKey='';
        this.sessOpen=0; this.sessHigh=0; this.sessLow=999999;
        this.sessOpenBar=0;
        this.openBias='INSIDE';
        this.pullbackToSigma=false;
        this.pullbackLevel=0;
        this.pullbackLevelType='';
        this.trendDay=false;
        this.trendDayDir=0;
        this.impulseOrigin=0;
        this.impulseEnd=0;
        this.impulseSize=0;
        this.impulseDir=0;
        this.impulseBar=0;
        this.pbDepth=0;
        this.pbClass='NONE';
        this.pbBars=[];
        this.swingHighs=[];
        this.swingLows=[];
        // Break-of-structure tracking (live trend override)
        this.bosDir=0;          // -1=bear, 0=none, 1=bull
        this.bosTriggerBar=0;   // bar index when BOS happened
        this.bosBrokeLevel=0;   // the swing price that got broken
        // Liquidity sweep tracking — break + reverse pattern.
        // sweepDir: direction of the REVERSAL (after sweep up = -1 short)
        // sweepLevel: the level that was swept
        // sweepBar: bar where the sweep candle peaked/troughed
        // sweepConfirmedBar: bar where reversal confirmed (close back through level)
        this.sweepDir=0;
        this.sweepLevel=0;
        this.sweepBar=0;
        this.sweepConfirmedBar=0;
        // Zone flip tracking (Ro's "sentiment shift" event) — when a
        // wick zone gets closed through, the side of the market that
        // used to control it has lost. Used as a fire-confirmation signal.
        this.lastZoneFlipBar = -1;
        this.lastZoneFlipDir = 0;
        // Absorption-at-level sequence (multi-bar rejection of same level)
        this.absSeqDir=0;       // 1=buyers absorbing, -1=sellers absorbing
        this.absSeqLevel=0;
        this.absSeqBars=0;
        this.absSeqStartBar=0;
        // First-pullback-after-impulse tracker
        this.recentImpulseDir=0;
        this.recentImpulseEnd=0;
        this.recentImpulseBar=0;
        this.recentImpulseSize=0;
        this.firstPullback=false;
        this.firstPullbackDir=0;
        // Demand/supply stepping in (J-hook recovery)
        this.steppingIn=false;
        this.steppingInDir=0;
        // Confirmed bases/ceilings (persist past the absorption sequence)
        this.confirmedBases=[];  // [{dir, level, bars, formedAt, retested, retestBar}]
        this.jhookActive=false;
        this.jhookDir=0;
        this.jhookLevel=0;
        this.jhookSourceBase=null;
        // ── UNIFIED LEVEL VOTES (per-bar) ────────────────────────────
        // Each bar, helper detectors write evidence to this map. A level
        // can have multiple confirmations stacked. Format:
        //   levelVotes: Map<priceKey, {
        //     price: number,
        //     dir: 1|-1,                  (defender direction)
        //     strength: 0-10,             (stacked confidence)
        //     behavior: 'HOLDING'|'FAILING'|'DISCOVERED',
        //     evidence: [string]          (which helpers contributed)
        //   }>
        // Reset each bar; readers consume current state.
        this.levelVotes = new Map();
        // Helper detector outputs (last bar) — useful for Wyckoff event ID
        this.lastSC = null;          // selling climax bar
        this.lastBC = null;          // buying climax bar
        this.lastSpringBar = -1;     // bar where spring fired
        this.lastUTADBar = -1;       // bar where UTAD fired
        this.lastClimaxBar = -1;     // bar where climactic reversal fired
        this.fvgZones = [];          // [{type:'BULL'|'BEAR', top, bot, bar, mitigated}]
        this.orderBlocks = [];       // [{dir, top, bot, bar, mitigated}]
        this.lastSwingLow=0;
        this.lastSwingHigh=0;
        this.higherLow=false;
        this.lowerHigh=false;
        this.prevSessHigh=0; this.prevSessLow=0;
        this.weekKey='';
        this.weekHigh=0; this.weekLow=999999;
        this.prevWeekHigh=0; this.prevWeekLow=0;
        this.vwapN=0; this.vwapD=0; this.vwap=0;
        // Safety-net date stamp for the daily NY 9:30 sigma refresh (set
        // when sigma is recomputed; compared on each new bar).
        this.sigmaRefreshDate = '';
        this.exp1H=0; this.exp1L=0;
        // Sigma-level respect tracking. For each level (1H/1L/2H/2L/3H/3L/4H/4L)
        // count touches, reversals, and break-throughs to measure whether
        // price actually respects the computed levels.
        this.sigmaStats = {};
        this.pendingSigma = {};   // { key: {hitBar, levelPrice, side, hitFromAbove} }
        this.exp2H=0; this.exp2L=0;
        this.exp3H=0; this.exp3L=0;
        this.exp4H=0; this.exp4L=0;
        this.expMid=0;
        this.expDailyIsInput=false;
        // Weekly/monthly expected-move bands (anchored at week/month open).
        this.weekOpen=0; this.wk1H=0; this.wk1L=0;
        this.monthKey=''; this.monthOpen=0; this.mo1H=0; this.mo1L=0;
        this.weekOpenBar=0; this.monthOpenBar=0;
        // 9:30 RTH (NY) open — the daily EM bands anchor here, NOT at the
        // current session open. Holds this morning's open through the EVE/
        // Asia/London sessions until the next NY open fires.
        this.rthOpen=0; this.rthOpenBar=0;
        // State for the interpolated 9:30-open auto-detect (2 completed bars
        // bracketing 9:30, computed once per day).
        this._bar1Close=0; this._bar1Ts=0; this._bar2Close=0; this._bar2Ts=0;
        this._rthDayKey='';
        this.calDayKey=''; this.calDayH=0; this.calDayL=999999;
        this.sessRanges=[]; this.avgSessRange=0;
        this.voids=[];
        this.h1Key=-1;
        this.h1O=0; this.h1H=0; this.h1L=999999; this.h1C=0;
        this.h1Candles=[];
        this.h1Dir=0;
        this.h1PrevDir=0;
        this.h1FlipBull=false;
        this.h1FlipBear=false;
        this.h1FlipBar=0;
        this.h1SwingH=[];
        this.h1SwingL=[];
        this.h1Trend='FLAT';
        this.h1HigherLow=false;
        this.h1LowerHigh=false;
        this.h4Key=-1;
        this.h4O=0; this.h4H=0; this.h4L=999999; this.h4C=0;
        this.h4Candles=[];
        this.h4Trend='FLAT';
        this.h4Dir=0;
        this.dailyCandleKey='';
        this.dailyCandleO=0; this.dailyCandleH=0; this.dailyCandleL=999999; this.dailyCandleC=0;
        this.dailyBias='FLAT';
        this.prevDailyHigh=0;
        this.prevDailyLow=0;
        this.prevDailyClose=0;
        this.todayVsPrevDay='INSIDE';
        this.preMarketHigh=0;
        this.preMarketLow=999999;
        this.asiaHigh=0;
        this.asiaLow=999999;
        this.mktState='RANGING';
        this.mktStateBar=0;
        // Auction theory state (set by _classifyAuctionState)
        this.auctionState='NEUTRAL';      // NEUTRAL/BALANCE/ROTATION/DISCOVERY
        this.auctionStateBias=0;
        this.auctionStateReason='';
        this.rangeHigh=0;
        this.rangeLow=0;
        this.trendStrength=0;
        this.volConfirm=false;
        this.absCount=0;
        this.absHigh=0; this.absLow=999999;
        this.exhDir=0;
        this.exhBars=[];
        // Note: sweepPending, sweepLevel, sweepDir, sweepBar are init'd
        // earlier in this method alongside BOS state — don't re-init here
        // or we'd zero out values set by the earlier block.
        this.position=0;
        this.qty=1;            // contracts for current trade (risk-based sizing, H4)
        this.ep=0; this.sl=0;
        this.tp1=0; this.tp2=0;
        this.tp1Hit=false; this.trailSL=0;
        // Capital preservation state (reset on each new trade)
        this.peakUnrealizedPnl=0;
        this.beMoved=false;
        this.lockMoved=false;
        this.entryRisk=null;
        // Runtime exit intelligence (latest values, for diagnostics)
        this.lastStrengthScore=5;
        this.lastThesisAgainst=0;
        this.sigBehavior=''; this.sigLevel='';
        // Repeat-failed-setup guard: don't re-fire same dir+level shortly after a loss.
        this.lastLossBar=-9999; this.lastLossDir=0; this.lastLossLevel='';
        // Regime-flip override: one extra trade allowed past MAX-TRADES if the
        // setup is opposite-direction high-conviction (per session).
        this.maxTradesOverrideUsed = false;
        // Volatility-by-hour profile: rolling avg range per 15-min bucket.
        // Accumulates across sessions so hot windows emerge over time.
        this.volBins = {};
        // Initial Balance: first 60 min of NY session sets the day's range.
        // A clean break + hold of IB high/low marks a trend day; we then
        // block counter-trend setups for the rest of the session.
        this.ibHigh = 0; this.ibLow = 0;
        this.ibStartBar = -1;
        this.ibLocked = false;
        this.ibBroken = 0;        // 0 = unbroken, 1 = up, -1 = down
        this.ibBreakBars = 0;     // consecutive bars holding outside IB
        this.entryBar=0; this.barsHeld=0; this.barsSinceSig=0;
        this.entryChartIdx=null;  // chart index at entry (for line rendering)
        this.results=[];
        this.sessPnl=0;
        this.dailyTrades=0;
        this.pauseUntilBar=-1;
        this.totalW=0; this.totalL=0; this.totalPnl=0;
        // Per-behavior performance buckets — auto-disable losers
        // ── COIL DETECTION ────────────────────────────────────
        // Volatility compression → expansion pattern. Measured edge:
        // 4:1 favorable/adverse over 20 bars across 3.5 years of QQQ
        // data (NQ proxy). Direction = breakout bar's direction.
        // Down-breakouts historically hit harder (74% vs 58% WR).
        this.coilActive = false;       // true when a tight cluster is forming
        this.coilHi = 0; this.coilLo = 0;
        this.coilStartBar = -1;
        this.lastCoilBreakBar = -9999; // for cooldown after a breakout fires

        // ── DELTA BUBBLES ─────────────────────────────────────
        // Per-bar largest bid-ask imbalance at a price level. Detected by
        // bucketing the bar's volume profile into N-tick slots and finding
        // the slot with the biggest |askVol - bidVol|. Stored as a rolling
        // history so entry/exit logic can reference recent bubbles.
        // Bubble shape: { bar, price, delta, ts }
        this.bubbles = [];
        // Running average of |bubble delta| — updated as new bubbles
        // print, used to scale the contra/hold thresholds adaptively per
        // chart. Different tick charts (e.g., NY 4096-tick vs EVE 3072-
        // tick) have different baseline volume, so an absolute threshold
        // is misleading. Using avg × multiplier auto-tunes to each chart.
        this.bubbleAvgAbs = 0;

        // ── MARKET-STATE RECOGNITION ──────────────────────────
        // Each bar we classify the market into one of 6 regimes so
        // downstream filters can adapt. Plus per-state setup stats
        // (online learning lite — each fired trade's outcome is
        // bucketed by the state it entered in, building a running
        // win-rate per (state, setup) we can gate on.
        this.marketState = 'NEUTRAL';     // current classified state
        this.marketStateBar = -1;         // last bar we recomputed
        this.entryState = '';             // state at entry of current pos
        // stateStats[state][setupTag] = {w, l, pnl}
        this.stateStats = {};
        this.behaviorStats = {
            SWP:{w:0,l:0,pnl:0},
            CLX:{w:0,l:0,pnl:0},
            ABS:{w:0,l:0,pnl:0},
            DIP:{w:0,l:0,pnl:0},
            RIP:{w:0,l:0,pnl:0},
            EXH:{w:0,l:0,pnl:0},
            WICK:{w:0,l:0,pnl:0},   // legacy single-bar wick rejection
            // New three-framework alignment buckets — track which voting
            // pattern produces edge. AUCT+STR+FLOW = all 3 agreed.
            // AUCT+FLOW = auction + orderflow (no structure agreement),
            // STR+FLOW = structure + orderflow, etc. Lets us see which
            // combinations actually win in real trading.
            'AUCT+STR+FLOW':{w:0,l:0,pnl:0},
            'AUCT+STR':{w:0,l:0,pnl:0},
            'AUCT+FLOW':{w:0,l:0,pnl:0},
            'STR+FLOW':{w:0,l:0,pnl:0},
            'AUCT':{w:0,l:0,pnl:0},
            'STR':{w:0,l:0,pnl:0},
            'FLOW':{w:0,l:0,pnl:0}
        };
        // ── DELTA TRACKING — WALLS + FOOTPRINT (side-by-side) ────
        this.deltaWalls=[];        // [{price, delta, dir, bar}]
        this.footprint={};         // { slotKey: {vol, delta} }
        this.footprintTops=[];     // top 3 slots [{price, delta, dir}]
        // Attribution: which delta layer made this trade possible
        this.entrySource='base';   // 'base' | 'walls' | 'footprint'
        this.attrStats = {
            base:     {w:0,l:0,pnl:0},
            walls:    {w:0,l:0,pnl:0},
            footprint:{w:0,l:0,pnl:0}
        };
        this.barLagMin=0;  // wall-clock vs bar-time lag (minutes)
        this.blockReason=''; // why canTrade is false (for HUD)
        this.renderMap={};
        // ── WICK-BASED BALANCE / IMBALANCE (Wick Sauce method) ────────
        // His framework is wick-centric, NOT FVG-centric. The single
        // wick (the rejection tail) IS the zone. The 50% of that wick
        // is equilibrium — entry trigger, premium/discount divider.
        //
        // IMBALANCE = a single significant wick that pokes into an area
        //   no other recent candle touched. Pure rejection, lopsided
        //   trade, leaves the zone "unbalanced." Price wants to come
        //   back and re-test that wick (rebalance the area).
        //
        // BALANCE = wicks from multiple candles cluster into the same
        //   price zone. Both sides traded there repeatedly — area is
        //   "balanced." Acts as support/resistance through wick density.
        //
        // INVERTED WICK = a wick that pokes against the prevailing
        //   trend and gets rejected back. Continuation signal — the
        //   wick zone becomes a re-entry magnet for the trend.
        //
        // Each wick zone tracks: top, bottom, 50% mid, direction (up
        // wick = sell zone, down wick = buy zone), tested status.
        this.wickZones=[];          // [{top, bot, mid, bull, bar, tested, trendCtx}]
        this.balanceClusters=[];    // [{top, bot, mid, wickCount, bars}]
        // ── DIAGNOSTICS & AUTO-TUNER ─────────────────────────────────
        // The "thinking machine" — observes the indicator's own state
        // every bar, flags problems, and (carefully) auto-adjusts wick
        // detection thresholds when it detects too many missed setups.
        //
        // Health verdicts:
        //   OK    = all checks pass, auto-tune allowed if calibration off
        //   WARN  = something looks off, no auto-tune
        //   ERROR = something is broken, no auto-tune, user must see it
        //
        // Auto-tuner is CONSERVATIVE on purpose:
        //   • Only acts when health = OK
        //   • Only after 200+ bars of consistent miss pattern
        //   • Tiny steps (5% of current value)
        //   • Never adjusts risk/session/SL/TP — only wick detection magnitudes
        //   • Reverts if next window shows worse signal output
        //   • Logs every change on-chart so user always knows what's tuned
        this.signalAttempts=[];     // [{bar, blockReason, behavior, dir, level}]
        this.postHocSetups=[];      // [{bar, type, dir, price}] — clean setups detected after the fact
        this.healthLog=[];          // [{bar, verdict, reason}]
        this.healthVerdict='OK';    // current health verdict
        this.healthMsg='';          // human-readable health message
        this.lastHealthCheckBar=0;
        this.autoTuneLog=[];        // [{bar, param, oldVal, newVal, reason}]
        this.lastAutoTuneBar=-9999; // for cooldown enforcement
        this.tuneProbation={};      // { paramName: {sinceBar, baselineFires} } — revert tracking
        // Live param values used by detection (initialized lazily, may be tuned)
        this.liveWickMinAtr=null;
        this.liveWickBodyRatio=null;
        this.liveClusterMinWicks=null;
        // ── SESSION JOURNAL ─────────────────────────────────────────
        // Self-reporting log: every interesting event (trade fired,
        // blocked, missed setup, session boundary, auto-tune action)
        // gets a structured entry. Used to build a session report on
        // demand (showReport param) and a tiny always-visible counter.
        //
        // Event types:
        //   FIRED     — trade actually taken; outcome filled in on exit
        //   BLOCKED   — would have fired, blocked by canonical reason
        //   MISSED    — post-hoc detected valid setup we didn't catch
        //   SESSION   — session start/end markers
        //   TUNE      — auto-tuner action
        //   HEALTH    — health verdict change (OK→WARN, WARN→ERROR, etc.)
        //
        // Each entry: {bar, time, session, type, details...}
        this.journal=[];                // ring buffer of events
        this.journalSessionStart=0;     // first bar of current session
        this.lastEventTime='';          // hh:mm of last event for display
        this.firedCount=0;
        this.blockedCount=0;
        this.missedCount=0;
        this.sessionWins=0;
        this.sessionLosses=0;
    }

    map(d) {
        try {
            const p   = this.props || {};
            const tz  = p.tzOffsetHours!=null ? p.tzOffsetHours : -4;
            // contractValuePt: if user explicitly set non-zero, use that.
            // Otherwise fall back to the auto-detected per-instrument value
            // (MNQ=$2, MGC=$10).
            const cv  = (p.contractValuePt && p.contractValuePt > 0)
                          ? p.contractValuePt
                          : this.autoContractValue;
            const maxLoss   = p.maxDailyLoss   || 400;
            const maxTrades = (p.maxDailyTrades != null) ? p.maxDailyTrades : 8;  // N6: align with paramSpec default (was ||3)
            const riskPerTrade  = (p.riskPerTrade!=null ? p.riskPerTrade : 100);
            const maxContracts  = (p.maxContracts && p.maxContracts > 0) ? p.maxContracts : 10;

            const o=d.open(), h=d.high(), l=d.low(), c=d.close();

            // ── BAD-DATA FRONT DOOR (H2 — fail closed) ──────────────────
            // One non-finite or non-positive print would poison ATR (NaN
            // propagates through the EMA forever), making every ATR-derived
            // stop NaN → 'l<=sl' is always false → the stop NEVER fires.
            // Reject the bar entirely: don't append it, don't advance state,
            // don't trade on it. The next valid bar resumes normally.
            if(!(Number.isFinite(o) && Number.isFinite(h) &&
                 Number.isFinite(l) && Number.isFinite(c)) ||
               o<=0 || h<=0 || l<=0 || c<=0 || h<l){
                this.badBarCount = (this.badBarCount||0) + 1;
                this.lastBadBar = true;
                return;   // skip this update; internal state stays clean
            }
            this.lastBadBar = false;

            // ── INSTRUMENT PROFILE (M2 — explicit beats guessing) ──
            // p.instrument: 0=auto, 1=NQ/MNQ, 2=GC/MGC. Auto still detects
            // NQ vs GC from price magnitude, but the front door above means
            // the seeding bar is always valid (no single-bad-bar mis-lock),
            // and an explicit setting removes the guess entirely (so e.g. ES
            // near 5000 is no longer silently treated as Gold).
            const _instParam = p.instrument || 0;
            if(!this._profileLoaded && c > 0){
                const _isNQ = _instParam === 1 || (_instParam === 0 && c > 10000);
                const _isGC = _instParam === 2 || (_instParam === 0 && c > 1500 && c <= 10000);
                if(_isNQ){
                    // NQ family (NQ, MNQ at 15000+)
                    this._instrument = 'NQ';
                    this.tickSize = 0.25;
                    this.footprintBucket = 4;     // 16 ticks per bucket
                    this.minSessionRange = 50;
                    this.atrFloor = 0.25;
                    this.autoContractValue = 2;   // MNQ default ($2/pt)
                } else if(_isGC){
                    // Gold family (GC, MGC at 1800-4500)
                    this._instrument = 'GC';
                    this.tickSize = 0.10;
                    this.footprintBucket = 1;     // 10 ticks per bucket
                    this.minSessionRange = 8;     // typical gold daily range in points
                    this.atrFloor = 0.10;
                    this.autoContractValue = 10;  // MGC default ($10/pt)
                } else {
                    // Unknown — scale relative to price.
                    this._instrument = 'OTHER';
                    this.tickSize = c * 0.0001;
                    this.footprintBucket = c * 0.0005;
                    this.minSessionRange = c * 0.005;
                    this.atrFloor = c * 0.0001;
                    this.autoContractValue = 2;   // safe default
                }
                this._profileLoaded = true;
            }
            const vol    = Math.max(d.volume()||1, 1);
            const offer  = d.offerVolume()||0;
            const bid    = d.bidVolume()||0;
            const delta  = offer - bid;

            const ts = d.timestamp();
            const lt = new Date(ts.getTime() + tz*3600000);
            const lth = lt.getUTCHours(), ltm = lt.getUTCMinutes();

            // ── WALL-CLOCK TIME (for boundary detection) ─────────────
            let wcLth=lth, wcLtm=ltm, wcDateStr='';
            let wcLagMin=0;
            try {
                const wcNow = Date.now();
                const wcLocal = new Date(wcNow + tz*3600000);
                wcLth = wcLocal.getUTCHours();
                wcLtm = wcLocal.getUTCMinutes();
                wcDateStr = wcLocal.getUTCFullYear()+'-'+(wcLocal.getUTCMonth()+1)+'-'+wcLocal.getUTCDate();
                wcLagMin = Math.round((wcNow - ts.getTime())/60000);
                if(Math.abs(wcLagMin) > 60){
                    wcLth=lth; wcLtm=ltm; wcDateStr=''; wcLagMin=0;
                }
            } catch(e){
                wcLth=lth; wcLtm=ltm; wcDateStr=''; wcLagMin=0;
            }
            const isLive = wcDateStr !== '';
            // Always use the BAR's own timestamp for session detection.
            // The previous wall-clock fallback caused session anchors to
            // jump to whatever the live clock said when the chart loaded
            // (e.g., a chart loaded at 8pm tagged recent bars as 8pm even
            // when their actual ts was earlier — producing a fake "session
            // change" at 8pm and resetting sigma/VWAP there).
            const bLth = lth;
            const bLtm = ltm;
            this.barLagMin = wcLagMin;
            // Format wall-clock time as HH:MM for journal entries
            const hhmmStr = (bLth<10?'0':'')+bLth+':'+(bLtm<10?'0':'')+bLtm;

            // ═════════════════════════════════════════════════════════
            // CRITICAL: TIMESTAMP-KEYED BAR STORAGE
            // ═════════════════════════════════════════════════════════
            // The Tradovate framework calls map(d) in three different
            // patterns, all of which we must handle correctly:
            //
            //   1. INITIAL HISTORICAL REPLAY — on chart load, map() is
            //      called once per historical bar in time order.
            //   2. LIVE TICK UPDATES — on the current bar, map() is
            //      called repeatedly with the same timestamp as ticks
            //      evolve the bar's H/L/C/V/D.
            //   3. SCROLL/TAB-SWITCH REPLAY — when the user scrolls,
            //      switches tabs, or the chart re-renders, Tradovate
            //      replays bars from the START of the chart history
            //      AGAIN. Same timestamps come through a second time
            //      (third, fourth, etc.), often interleaved with the
            //      live bar.
            //
            // The previous fix (compare current timestamp to LAST seen)
            // only handled case #2 correctly. On case #3, every bar
            // arrives with an OLDER timestamp than _lastBarTs, so it
            // got treated as a "new bar" and pushed onto the arrays.
            // This is the actual cause of the flickering — each tab
            // switch / scroll added duplicate copies of every historical
            // bar, corrupting ATR, sigmas, wick zones, level positions,
            // and ultimately the trade decisions.
            //
            // Proper fix: use a Map<timestamp, array_index>.
            //   - First time we see a timestamp: append to arrays, store
            //     timestamp → arrays.length-1 in the map
            //   - Subsequent times we see that timestamp: look up index,
            //     update arrays[idx] in place
            //
            // This way the arrays stay the same length forever (per session)
            // and same-timestamp updates always land in the same slot,
            // regardless of how many times Tradovate replays.
            //
            // We also detect REPLAY START (timestamp lower than _lastBarTs)
            // to avoid double-running per-bar logic. But the bar-array
            // updates still happen on every call, just into the right slot.
            // Use the timestamp's primitive value (epoch ms) as the map
            // key — Date objects compared by reference would always be
            // unique, breaking the dedup. getTime() returns a number that
            // properly compares for equality across calls.
            const _curTsObj = (typeof d.timestamp === 'function') ? d.timestamp() : null;
            const _curTs = _curTsObj && typeof _curTsObj.getTime === 'function'
                ? _curTsObj.getTime()
                : (typeof _curTsObj === 'number' ? _curTsObj : null);
            if(!this._tsIndex) this._tsIndex = new Map();

            let arrIdx;
            let isNewBar = false;       // first time we've ever seen this timestamp
            let isTickUpdate = false;   // same timestamp as last call (live tick)
            let isReplayPass = false;   // seen this ts before but not last (scroll replay)

            if(_curTs != null && this._tsIndex.has(_curTs)){
                // Already seen this timestamp — either a tick update or replay
                arrIdx = this._tsIndex.get(_curTs);
                if(_curTs === this._lastBarTs){
                    isTickUpdate = true;
                } else {
                    isReplayPass = true;
                }
                // Update the existing slot in place
                if(arrIdx < this.H.length){
                    if(h > this.H[arrIdx]) this.H[arrIdx] = h;
                    if(l < this.L[arrIdx]) this.L[arrIdx] = l;
                    this.C[arrIdx] = c;
                    this.V[arrIdx] = vol;
                    this.D[arrIdx] = delta;
                }
            } else {
                // First time seeing this timestamp — append.
                isNewBar = true;
                this.barIdx++;
                // Roll a 2-deep history of COMPLETED bars (close + timestamp)
                // for the 9:30-open interpolation below. Before this push,
                // this.C's last entry is the just-completed previous bar.
                if(this.C.length > 0){
                    this._bar2Close = this._bar1Close; this._bar2Ts = this._bar1Ts;
                    this._bar1Close = this.C[this.C.length-1];
                    this._bar1Ts    = this._lastBarTs;
                }
                this.H.push(h); this.L.push(l); this.O.push(o);
                this.C.push(c); this.V.push(vol); this.D.push(delta);
                arrIdx = this.H.length - 1;
                if(_curTs != null) this._tsIndex.set(_curTs, arrIdx);
            }
            this._lastBarTs = _curTs;

            // ── AUTO 9:30 RTH OPEN (interpolated) ─────────────────────────
            // Tick bars don't break at 9:30, so no bar's open IS the 9:30
            // print. But once the bar that closes just after 9:30 is done,
            // the two completed bars on either side of 9:30 bracket it — and
            // linear-interpolating their closes to the 9:30 timestamp gives a
            // close estimate of the open. Runs once per day; the manual
            // rthOpen setting (if > 0) overrides this everywhere downstream.
            if(isNewBar && this._bar1Close > 0 && this._bar2Close > 0){
                const _open930Adj = Date.UTC(lt.getUTCFullYear(), lt.getUTCMonth(), lt.getUTCDate(), 9, 30, 0, 0);
                const _tCross = _open930Adj - tz*3600000;
                const _dk = lt.getUTCFullYear()+'-'+(lt.getUTCMonth()+1)+'-'+lt.getUTCDate();
                if(this._rthDayKey !== _dk && this._bar2Ts < _tCross && _tCross <= this._bar1Ts){
                    const _span = this._bar1Ts - this._bar2Ts;
                    const _f = _span > 0 ? (_tCross - this._bar2Ts) / _span : 0;
                    this.rthOpen = this._bar2Close + (this._bar1Close - this._bar2Close) * _f;
                    this.rthOpenBar = this.barIdx;
                    this._rthDayKey = _dk;
                }
            }

            // For replay passes, the per-bar calculations would re-run
            // the work that was already done on the original pass. The
            // dedup checks on accumulated arrays (voids, swings, etc.)
            // catch the obvious cases. The bar-array slots have been
            // updated in place above. So we can just continue normally
            // and let the natural flow handle it.
            // Mark replay pass for downstream gating (entry decisions
            // shouldn't fire on replay — they already fired on original).

            const bi = this.barIdx;
            if(typeof d.index === 'function') this.lastChartIdx = d.index();
            else this.lastChartIdx = bi;

            const n = this.H.length;

            // ── DETERMINISTIC ATR SEEDING ─────────────────────────────
            // Only updates on NEW bars. Tick updates within the same bar
            // shouldn't repeatedly EMA-smooth the same TR — that would
            // make ATR drift toward the live bar's TR instead of being a
            // proper rolling 14-bar measure.
            const tr = n>1
                ? Math.max(h-l, Math.abs(h-this.C[n-2]), Math.abs(l-this.C[n-2]))
                : h-l;
            if(!this._trBuf) this._trBuf = [];
            if(isNewBar){
                this._trBuf.push(tr);
                if(this._trBuf.length > 14) this._trBuf.shift();
                if(n <= 14){
                    let _trSum = 0;
                    for(const _tr of this._trBuf) _trSum += _tr;
                    this.atr = _trSum / this._trBuf.length;
                } else {
                    this.atr = this.atr*0.87 + tr*0.13;
                }
            }
            // (On tick updates, this.atr stays stable from previous bar close.)
            const atr = Math.max(this.atr, this.atrFloor);

            // ── DELTA BUBBLE DETECTION (per new bar) ─────────────────
            // For each new bar, look at its volume profile and find the
            // price level with the biggest |askVol - bidVol|. If above the
            // threshold, record it. The history feeds entry confirmation
            // and exit-hold logic. Wrapped in try/catch — d.profile() may
            // be unavailable on chart types without per-price volume.
            if(isNewBar && typeof d.profile === 'function'){
                try {
                    const _profs = d.profile();
                    if(_profs && _profs.length > 0){
                        const _bThr = (p.bubbleThreshold!=null?p.bubbleThreshold:120);
                        const _ppb  = (p.bubblePriceLevels!=null?p.bubblePriceLevels:6);
                        const _step = this.tickSize * _ppb;
                        const _buckets = {};
                        let _last = null, _barInit = null;
                        const _sorted = _profs.slice().sort((a,b)=>a.price-b.price);
                        for(const pr of _sorted){
                            if(_barInit === null) _barInit = pr.price;
                            if(_last !== null && _last >= _barInit + _step) _barInit = pr.price;
                            const k = _barInit.toFixed(7);
                            if(!_buckets[k]){
                                _buckets[k] = { price:_barInit, askVol:0, bidVol:0 };
                            }
                            _buckets[k].askVol += (pr.askVol || 0);
                            _buckets[k].bidVol += (pr.bidVol || 0);
                            _last = pr.price;
                        }
                        // Find the largest absolute delta bucket.
                        let _maxAbs = 0, _bub = null;
                        for(const k in _buckets){
                            const _bk = _buckets[k];
                            const _d = _bk.askVol - _bk.bidVol;
                            if(Math.abs(_d) > _maxAbs){
                                _maxAbs = Math.abs(_d);
                                _bub = { price:_bk.price, delta:_d };
                            }
                        }
                        if(_bub && _maxAbs >= _bThr){
                            this.bubbles.push({
                                bar: bi,
                                price: _bub.price,
                                delta: _bub.delta,
                                ts: ts.getTime(),
                            });
                            if(this.bubbles.length > 40) this.bubbles.shift();
                            // EMA of |delta| over recent bubbles. Used by the
                            // contra/hold filters to auto-scale thresholds
                            // to this chart's typical bubble magnitude.
                            const _alpha = 0.1;
                            this.bubbleAvgAbs = this.bubbleAvgAbs > 0
                                ? this.bubbleAvgAbs * (1 - _alpha) + _maxAbs * _alpha
                                : _maxAbs;
                        }
                    }
                } catch(e) { /* profile unavailable on this chart — skip */ }
            }

            // ── MARKET-STATE CLASSIFICATION (per new bar) ────────────
            // Recompute the regime once per bar; cache on `this.marketState`.
            // Used by the STATE-FAIL dynamic gate and surfaced in HUD.
            if(isNewBar){
                this.marketState = this._classifyMarketState(c, atr);
                // Track which sigma levels actually get respected vs broken.
                this._trackSigmaRespect(bi, h, l, c, atr);
            }

            // ── VOLATILITY-BY-HOUR PROFILE ───────────────────────────
            // Bucket the bar's range into a 15-min bin. Over time the
            // bins reveal the windows where the day's big moves usually
            // happen (e.g. NY 09:45, 11:00). Surfaced in HUD as "HOT".
            if(isNewBar && n > 1){
                const _bm = Math.floor(bLtm/15)*15;
                const _bin = (bLth<10?'0':'')+bLth+':'+(_bm<10?'0':'')+_bm;
                if(!this.volBins[_bin]) this.volBins[_bin] = {n:0, sumRange:0};
                const _b = this.volBins[_bin];
                _b.n++; _b.sumRange += (h-l);
                // Prevent unbounded growth — halve to preserve avg.
                if(_b.n > 200){ _b.n = 100; _b.sumRange /= 2; }
            }

            // (IB tracking moved below to after sessSuffix is computed)

            // ── DETERMINISTIC AVGVOL SEEDING ─────────────────────────
            // Same: only push on new bars. Tick updates evolve the live
            // bar's vol but don't add a new entry to the rolling buffer.
            if(isNewBar){
                this.volBuf.push(vol);
                if(this.volBuf.length>20) this.volBuf.shift();
                this.avgVol = this.volBuf.reduce((a,b)=>a+b,0)/this.volBuf.length;
            }
            const avgVol = Math.max(this.avgVol, 1);

            const prevDelta = this.prevDelta;
            // Cumulative delta and prevDelta only update on new bars.
            // Tick updates and scroll-replay would otherwise double-count
            // the same bar's delta into cumDelta.
            if(isNewBar){
                this.prevDelta  = delta;
                this.cumDelta  += delta;
            }
            const minFlip = avgVol * 0.08;
            const dfBull  = prevDelta < -minFlip && delta > minFlip;
            const dfBear  = prevDelta >  minFlip && delta < -minFlip;

            // ── SESSION CLASSIFICATION (wall-clock driven) ────────
            const isNY      = (bLth>9||(bLth===9&&bLtm>=30)) && bLth<16;
            const isEve     = (bLth>=18 && bLth<23);
            const isAsia    = (bLth>=19 || bLth<3);
            const isLondon  = (bLth>=3 && bLth<8);

            const tNY  = (p.tradeNY!=null?p.tradeNY:1) >= 1;
            const tEve = (p.tradeEvening!=null?p.tradeEvening:1) >= 1;
            const tAsia   = (p.tradeAsia!=null?p.tradeAsia:1) >= 1;
            const tLondon = (p.tradeLondon!=null?p.tradeLondon:0) >= 1;
            // Simple mode flag — when on, the chart hides nearly everything
            // except what's needed to take/manage the trade. Read once per
            // bar and used to gate visual rendering blocks below.
            const simpleMode = (p.simpleMode!=null?p.simpleMode:1) >= 1;

            let sessSuffix='_overnight';
            if(isNY     && tNY)     sessSuffix='_ny';
            else if(isEve    && tEve)    sessSuffix='_eve';
            else if(isAsia   && tAsia)   sessSuffix='_asia';
            else if(isLondon && tLondon) sessSuffix='_london';

            const dateStr = lt.getUTCFullYear()+'-'+(lt.getUTCMonth()+1)+'-'+lt.getUTCDate();
            const newSessKey = dateStr+sessSuffix;

            const twoSuffix = isEve?'_eve':'_day';
            const calKey = dateStr+twoSuffix;
            if(isNewBar && calKey!==this.calDayKey){
                if(this.calDayKey!==''&&this.calDayH>0&&this.calDayL<999999){
                    const dr = this.calDayH - this.calDayL;
                    if(dr>this.minSessionRange){
                        this.sessRanges.push(dr);
                        if(this.sessRanges.length>20) this.sessRanges.shift();
                        let s=0; for(const r of this.sessRanges) s+=r;
                        this.avgSessRange = s/this.sessRanges.length;
                    }
                }
                this.calDayKey=calKey; this.calDayH=h; this.calDayL=l;
            } else if(isNewBar) {
                if(h>this.calDayH) this.calDayH=h;
                if(l<this.calDayL) this.calDayL=l;
            }

            if(isNewBar && newSessKey!==this.sessKey){
                // ── H5: FORCE-FLAT AT SESSION BOUNDARY ──────────────────
                // Never let a position ride into the next session while the
                // daily risk counters reset under it. Close at this bar's
                // market (close), realize P&L into the OUTGOING session, and
                // record it BEFORE any reset below. (this.sessKey is still the
                // outgoing session here, so the trade is journaled correctly.)
                if(this.position !== 0){
                    const _xPnl = (this.position===1 ? c - this.ep : this.ep - c);
                    const _xWin = _xPnl > 0, _xQty = this.qty || 1;
                    this.results.push({win:_xWin, pnl:_xPnl});
                    if(this.results.length>5) this.results.shift();
                    this.sessPnl  += _xPnl * _xQty;
                    this.totalPnl += _xPnl * _xQty;
                    if(_xWin) this.totalW++; else this.totalL++;
                    if(_xWin) this.sessionWins++; else this.sessionLosses++;
                    this._logJournal(bi, this.sessKey, hhmmStr, 'EXIT', {
                        win:_xWin, pnl:Math.round(_xPnl*100)/100, reason:'SESSION-FLAT',
                        entryBar:this.entryBar, ep:Math.round(this.ep*100)/100,
                        ex:Math.round(c*100)/100, strength:this.lastStrengthScore,
                        votesAgainst:this.lastThesisAgainst
                    });
                    if((this.props||{}).forwardLog){
                        var _Rh = Math.abs(this.ep - this.sl) || 0;
                        console.log('SDTRADE,'+ts.toISOString()+','+this.sessKey+','
                            +(this.sigLevel||'')+','+(this.entrySource||'')+','
                            +(this.entryState||'')+','+(this.position===1?'LONG':'SHORT')+','
                            +this.ep.toFixed(2)+','+this.sl.toFixed(2)+','+this.tp2.toFixed(2)+','
                            +c.toFixed(2)+',SESSION-FLAT,'
                            +_xPnl.toFixed(2)+','+_Rh.toFixed(2)+','+this.barsHeld+','
                            +(this.lastStrengthScore!=null?this.lastStrengthScore:'')+','
                            +_xQty+','
                            +((this.entryTs&&this.entryTs.toISOString)?this.entryTs.toISOString():''));
                    }
                    this.position=0; this.tp1Hit=false;
                }
                // Only carry forward H/L from REAL trading sessions.
                // The _overnight buckets (4-6pm post-NY gap, 11pm-9:30am
                // pre-NY gap) are brief dead-zones — letting their tiny
                // ranges become "PSH" pollutes the chart with a meaningless
                // level (you'd see PSH at 27208 when NY's actual high was
                // 27310 — confusing and useless). Skipping _overnight
                // means PSH always points to the most recent ACTUAL
                // trading session's high/low.
                const wasRealSession = this.sessKey &&
                                       !this.sessKey.includes('_overnight');
                if(this.sessOpen>0 && wasRealSession){
                    this.prevSessHigh = this.sessHigh;
                    this.prevSessLow  = this.sessLow;
                }
                this.sessKey     = newSessKey;
                this.sessOpen    = o;
                this.sessHigh    = h; this.sessLow = l;
                this.sessOpenBar = bi;
                // Latch the 9:30 RTH open so the daily EM bands stay pinned to
                // this morning's open across every later session of the day.
                if(sessSuffix==='_ny'){ this.rthOpen=o; this.rthOpenBar=bi; }
                this.vwapN=0; this.vwapD=0; this.vwap=o;
                this.cumDelta=0;
                this.dailyTrades=0; this.sessPnl=0;
                // ── DON'T reset price-structure state at session boundaries ──
                // wickZones, balanceClusters, deltaWalls, footprint, swing
                // highs/lows are CONTINUOUS market structure. The 9:30 NY
                // open doesn't make yesterday's wick zone at 27800 invalid —
                // price still respects it. By keeping these across sessions,
                // the indicator has rich level data immediately at NY open
                // instead of being blind for 30+ minutes while structure
                // rebuilds. This was the cause of missing the early NY
                // long that user circled — at 9:30 there was no level data
                // because session reset wiped it all.
                //
                // Wick zones do age out naturally (mitigated/tested flags),
                // and the cap of 12 voids / 8 swings prevents unbounded growth.
                //
                // Old: this.wickZones=[]; this.balanceClusters=[];
                //      this.deltaWalls=[]; this.footprint={}; this.footprintTops=[];
                // New: keep them all.
                // Reset diagnostic state per session — yesterday's
                // missed setups, signal attempts, and health log lose
                // relevance once a new auction opens. Keep autoTuneLog
                // (so user sees recent tunes) but reset everything else.
                this.signalAttempts=[];
                this.postHocSetups=[];
                this.healthVerdict='OK';
                this.healthMsg='';
                this.tuneProbation={};
                // Also reset the trade-results buffer and loss-pause clock.
                // Yesterday's losses should NOT trigger LOSS-PAUSE for
                // today's session. Each session is its own auction.
                // Without this reset, a bad NY day prevents you from
                // trading EVE at all (which is what just happened on
                // 2026-04-30 → 2026-05-01 transition).
                this.results=[];
                this.pauseUntilBar=-1;
                this.lastLossBar=-9999; this.lastLossDir=0; this.lastLossLevel='';
                this.maxTradesOverrideUsed = false;
                this.ibHigh = 0; this.ibLow = 0; this.ibStartBar = -1;
                this.ibLocked = false; this.ibBroken = 0; this.ibBreakBars = 0;
                // Reset cooldown so the open can fire immediately if
                // a setup presents. barsSinceSig was probably mid-cooldown
                // at session change — don't carry that into the new session.
                this.barsSinceSig = 100;
                // ── JOURNAL: write session-end summary, start new session ──
                // If we had a previous session with activity, write a
                // SESSION_END event with the final stats. Then start the
                // new session with a SESSION_START marker. Old journal
                // entries are kept for the report (capped at 200 entries
                // total, so multiple sessions can be reviewed).
                if(this.journalSessionStart > 0 &&
                   (this.firedCount > 0 || this.blockedCount > 0 || this.missedCount > 0)){
                    this.journal.push({
                        bar:bi, time:'', session:this.sessKey, type:'SESSION_END',
                        fired:this.firedCount,
                        blocked:this.blockedCount,
                        missed:this.missedCount,
                        wins:this.sessionWins,
                        losses:this.sessionLosses,
                        pnl:Math.round(this.sessPnl*cv*100)/100
                    });
                }
                this.journalSessionStart = bi;
                this.firedCount=0;
                this.blockedCount=0;
                this.missedCount=0;
                this.sessionWins=0;
                this.sessionLosses=0;
                // Cap journal at 200 entries (≈ several sessions of history)
                while(this.journal.length > 500) this.journal.shift();
                this.journal.push({
                    bar:bi, time:'', session:newSessKey, type:'SESSION_START',
                    open: o
                });
                this.volBuf=[];
                this.avgVol=Math.max(vol, 1);
                this._computeEXP(o);
                this.sigmaRefreshDate = newSessKey;

                this.pullbackToSigma=false; this.pullbackLevel=0; this.pullbackLevelType='';
                this.trendDay=false; this.trendDayDir=0;
                if(this.prevSessHigh>0&&this.prevSessLow>0){
                    const _prevMid=(this.prevSessHigh+this.prevSessLow)/2;
                    const _prevRange=this.prevSessHigh-this.prevSessLow;
                    const _prev1sH=_prevMid+_prevRange*0.309;
                    const _prev1sL=_prevMid-_prevRange*0.309;
                    if(o>_prev1sH)      this.openBias='ABOVE_1S';
                    else if(o<_prev1sL) this.openBias='BELOW_1S';
                    else                this.openBias='INSIDE';
                } else {
                    this.openBias='INSIDE';
                }
            } else if(isNewBar) {
                if(h>this.sessHigh) this.sessHigh=h;
                if(l<this.sessLow)  this.sessLow=l;
                // Safety net: refresh sigma at every NY 9:30 AND EVE 18:00
                // calendar-day open even if sessKey didn't transition.
                // Catches the case where the wall-clock fallback masks
                // session boundaries and sigma stays stuck on an old open.
                const _isNYOpenBar  = (bLth === 9  && bLtm >= 30 && bLtm < 35);
                const _isEVEOpenBar = (bLth === 18 && bLtm < 5);
                const _refreshKey = _isNYOpenBar  ? dateStr+'_ny'
                                  : _isEVEOpenBar ? dateStr+'_eve'
                                  : '';
                if(_refreshKey && this.sigmaRefreshDate !== _refreshKey){
                    this.sigmaRefreshDate = _refreshKey;
                    this.sessOpen = o;
                    this.sessHigh = h; this.sessLow = l;
                    this.sessOpenBar = bi;
                    // Latch this morning's 9:30 open for the daily EM anchor.
                    if(_isNYOpenBar){ this.rthOpen = o; this.rthOpenBar = bi; }
                    this._computeEXP(o);
                }
            }

            // ── INITIAL BALANCE (NY first 60 min) ────────────────────
            // The opening hour sets the day's character. A clean break
            // and hold (3+ bars) of IB high or low marks a trend day,
            // and counter-trend setups get blocked for the rest of the
            // session via the IB-COUNTER filter. Cheap, fast, decisive
            // — doesn't wait for swing-based mktState to catch up.
            if(isNewBar && sessSuffix === '_ny'){
                if(this.ibStartBar < 0){
                    this.ibStartBar = bi;
                    this.ibHigh = h; this.ibLow = l;
                    this.ibLocked = false; this.ibBroken = 0; this.ibBreakBars = 0;
                }
                const _ibAge = bi - this.ibStartBar;
                if(_ibAge <= 60){
                    if(h > this.ibHigh) this.ibHigh = h;
                    if(l < this.ibLow)  this.ibLow  = l;
                } else {
                    if(!this.ibLocked) this.ibLocked = true;
                    if(this.ibBroken === 0){
                        const _buf = atr * 0.3;
                        if(c > this.ibHigh + _buf){
                            this.ibBreakBars++;
                            if(this.ibBreakBars >= 3) this.ibBroken = 1;
                        } else if(c < this.ibLow - _buf){
                            this.ibBreakBars++;
                            if(this.ibBreakBars >= 3) this.ibBroken = -1;
                        } else {
                            this.ibBreakBars = 0;
                        }
                    }
                }
            }

            // VWAP accumulates ONCE per bar (on isNewBar). Tick updates
            // for the same bar must NOT re-add to the running totals or
            // the VWAP gets corrupted (each tick would multiply the bar's
            // contribution by N for N ticks).
            const tp = (h+l+c)/3;
            if(isNewBar){
                this.vwapN += tp*vol; this.vwapD += vol;
            }
            this.vwap   = this.vwapD>0 ? this.vwapN/this.vwapD : c;

            // Weekly key — wall-clock driven
            const wkBase = {y:lt.getUTCFullYear(), m:lt.getUTCMonth()+1, d:lt.getUTCDate()};
            const wk = Math.ceil(wkBase.d/7);
            const weekKey = wkBase.y+'-'+wkBase.m+'-W'+wk;
            if(isNewBar && weekKey!==this.weekKey){
                if(this.weekKey!==''){
                    this.prevWeekHigh = this.weekHigh;
                    this.prevWeekLow  = this.weekLow;
                }
                this.weekKey=weekKey; this.weekHigh=h; this.weekLow=l; this.weekOpen=o; this.weekOpenBar=bi;
            } else if(isNewBar) {
                if(h>this.weekHigh) this.weekHigh=h;
                if(l<this.weekLow)  this.weekLow=l;
            }
            // Monthly anchor + weekly/monthly expected-move bands (options-implied)
            const _monthKey = wkBase.y+'-'+wkBase.m;
            if(isNewBar && _monthKey!==this.monthKey){ this.monthKey=_monthKey; this.monthOpen=o; this.monthOpenBar=bi; }
            // Weekly/monthly use their OWN fixed numbers (set once per
            // week/month) so the bands don't drift as the daily changes.
            // Weekly anchors at the week open, monthly at the month open.
            let _emW=(p.expMoveWeekly!=null?Number(p.expMoveWeekly):0)||0;
            if(!(_emW>0)) _emW=EM_WEEKLY;
            let _emM=(p.expMoveMonthly!=null?Number(p.expMoveMonthly):0)||0;
            if(!(_emM>0)) _emM=EM_MONTHLY;
            this.wk1H=(this.weekOpen>0&&_emW>0)?this.weekOpen+_emW:0;
            this.wk1L=(this.weekOpen>0&&_emW>0)?this.weekOpen-_emW:0;
            this.mo1H=(this.monthOpen>0&&_emM>0)?this.monthOpen+_emM:0;
            this.mo1L=(this.monthOpen>0&&_emM>0)?this.monthOpen-_emM:0;

            // ── DAILY CANDLE — futures-session boundary at 5 PM EDT ──
            let fLth = lth;
            let fY = lt.getUTCFullYear();
            let fM = lt.getUTCMonth()+1;
            let fD = lt.getUTCDate();
            if(fLth >= 17){
                const dt = new Date(Date.UTC(fY, fM-1, fD+1));
                fY = dt.getUTCFullYear();
                fM = dt.getUTCMonth()+1;
                fD = dt.getUTCDate();
            }
            const calDayKey2 = fY+'-'+fM+'-'+fD;

            if(isNewBar && calDayKey2!==this.dailyCandleKey){
                if(this.dailyCandleKey!==''&&this.dailyCandleO>0){
                    this.prevDailyHigh  = this.dailyCandleH;
                    this.prevDailyLow   = this.dailyCandleL;
                    this.prevDailyClose = this.dailyCandleC;
                    const dayReturn = this.dailyCandleC - this.dailyCandleO;
                    this.dailyBias = dayReturn>0?'BULL':dayReturn<0?'BEAR':'FLAT';
                } else if(this.dailyCandleKey===''&&this.prevSessHigh>0){
                    this.prevDailyHigh  = this.prevSessHigh;
                    this.prevDailyLow   = this.prevSessLow;
                    this.dailyBias = 'FLAT';
                }
                this.dailyCandleKey=calDayKey2;
                this.dailyCandleO=o; this.dailyCandleH=h;
                this.dailyCandleL=l; this.dailyCandleC=c;
                if(this.prevDailyHigh>0){
                    if(o>this.prevDailyHigh)      this.todayVsPrevDay='ABOVE';
                    else if(o<this.prevDailyLow)   this.todayVsPrevDay='BELOW';
                    else                           this.todayVsPrevDay='INSIDE';
                }
                this.preMarketHigh=h; this.preMarketLow=l;
                this.asiaHigh=0;
                this.asiaLow=999999;
            } else if(isNewBar) {
                if(h>this.dailyCandleH) this.dailyCandleH=h;
                if(l<this.dailyCandleL) this.dailyCandleL=l;
                this.dailyCandleC=c;
                const isAsianHours = (bLth>=19 || bLth<4);
                if(isAsianHours){
                    if(h>this.asiaHigh)  this.asiaHigh=h;
                    if(l<this.asiaLow)   this.asiaLow=l;
                }
                const isPreNY = !isNY;
                if(isPreNY){
                    if(h>this.preMarketHigh) this.preMarketHigh=h;
                    if(l<this.preMarketLow)  this.preMarketLow=l;
                }
            }

            const h4Key = Math.floor(bLth/4);
            if(isNewBar && h4Key!==this.h4Key){
                if(this.h4Key>=0&&this.h4O>0){
                    const h4Dir = this.h4C>=this.h4O?1:-1;
                    this.h4Candles.push({o:this.h4O,h:this.h4H,l:this.h4L,c:this.h4C,dir:h4Dir});
                    if(this.h4Candles.length>10) this.h4Candles.shift();
                    this.h4Dir=h4Dir;
                    if(this.h4Candles.length>=2){
                        const l1=this.h4Candles[this.h4Candles.length-1];
                        const l2=this.h4Candles[this.h4Candles.length-2];
                        const d1=l1.c>=l1.o?1:-1;
                        const d2=l2.c>=l2.o?1:-1;
                        if(d1===1&&d2===1)       this.h4Trend='BULL';
                        else if(d1===-1&&d2===-1) this.h4Trend='BEAR';
                        else                       this.h4Trend='FLAT';
                    }
                }
                this.h4Key=h4Key; this.h4O=o; this.h4H=h; this.h4L=l; this.h4C=c;
            } else if(isNewBar) {
                if(h>this.h4H) this.h4H=h;
                if(l<this.h4L) this.h4L=l;
                this.h4C=c;
            }
            const h1Key = bLth;
            if(isNewBar && h1Key!==this.h1Key){
                if(this.h1Key>=0 && this.h1O>0){
                    const h1CandleDir = this.h1C >= this.h1O ? 1 : -1;
                    this.h1Candles.push({
                        o:this.h1O, h:this.h1H, l:this.h1L, c:this.h1C,
                        range:this.h1H-this.h1L, dir:h1CandleDir
                    });
                    if(this.h1Candles.length>20) this.h1Candles.shift();

                    this.h1PrevDir = this.h1Dir;
                    this.h1Dir     = h1CandleDir;
                    if(this.h1PrevDir!==0 && this.h1Dir!==this.h1PrevDir){
                        this.h1FlipBull = h1CandleDir===1;
                        this.h1FlipBear = h1CandleDir===-1;
                        this.h1FlipBar  = bi;
                    } else {
                        if(bi - this.h1FlipBar > 3){
                            this.h1FlipBull=false;
                            this.h1FlipBear=false;
                        }
                    }

                    this._update1hr();
                }
                this.h1Key=h1Key; this.h1O=o; this.h1H=h; this.h1L=l; this.h1C=c;
            } else if(isNewBar) {
                if(h>this.h1H) this.h1H=h;
                if(l<this.h1L) this.h1L=l;
                this.h1C=c;
            }

            if(n>1 && isNewBar){
                const move = Math.abs(c - this.C[n-2]);
                if(move > atr*2.5 && vol < avgVol*0.75){
                    const bull = c > this.C[n-2];
                    // Only push if this bar didn't already create one
                    const _lastVoid = this.voids[this.voids.length-1];
                    if(!_lastVoid || _lastVoid.bar !== bi){
                        this.voids.push({top:h, bot:l, bull, filled:false, bar:bi});
                        if(this.voids.length>12) this.voids.shift();
                    }
                }
                for(const v of this.voids){
                    if(!v.filled){
                        if(v.bull && l <= v.bot+atr*0.5) v.filled=true;
                        if(!v.bull && h >= v.top-atr*0.5) v.filled=true;
                    }
                }
            }

            // ── WICK-BASED BALANCE / IMBALANCE (Wick Sauce method) ──
            // The wick itself IS the zone. Every bar's significant wick
            // becomes a tracked zone with a 50% equilibrium line.
            //
            // 1. WICK ZONE detection — every closed bar with a meaningful
            //    rejection wick (upper or lower) creates a zone.
            //    "Meaningful" = wick length >= wickMinAtr * ATR (default 0.6)
            //    AND wick > wickBodyRatio * body (default 0.5).
            //    Up wick = sell zone (rejection from above)
            //    Down wick = buy zone (rejection from below)
            //
            //    Trend context tag — was this wick WITH or AGAINST the
            //    short-term trend? An "inverted wick" is one that goes
            //    against the trend and gets rejected, signaling
            //    continuation. We tag it for the entry logic.
            //
            //    All thresholds are user-tunable via params for tick-chart
            //    sensitivity tuning. The diagnostics layer can also auto-
            //    adjust these (within bounds) when it detects too many
            //    missed setups — see this.liveXxx values which are seeded
            //    from props but mutable by the auto-tuner.
            if(this.liveWickMinAtr === null){
                this.liveWickMinAtr = p.wickMinAtr != null ? Number(p.wickMinAtr) : 0.6;
            }
            if(this.liveWickBodyRatio === null){
                this.liveWickBodyRatio = p.wickBodyRatio != null ? Number(p.wickBodyRatio) : 0.5;
            }
            if(this.liveClusterMinWicks === null){
                this.liveClusterMinWicks = p.clusterMinWicks != null ? Math.max(2,Math.floor(Number(p.clusterMinWicks))) : 3;
            }
            const wickMinAtr   = this.liveWickMinAtr;
            const wickBodyRatio= this.liveWickBodyRatio;
            const trendLookback= p.wickTrendLookback != null ? Math.max(2,Math.floor(Number(p.wickTrendLookback))) : 5;
            if(n>=2 && isNewBar){
                const body = Math.abs(c-o);
                const upWick = h - Math.max(o,c);    // upper shadow
                const dnWick = Math.min(o,c) - l;    // lower shadow
                const wickMin = atr*wickMinAtr;       // minimum significant wick
                // Short-term trend reference: configurable lookback slope
                let trend = 0;
                if(n>=trendLookback+1){
                    const tm = c - this.C[n-trendLookback-1];
                    if(tm > atr*1.5) trend = 1;
                    else if(tm < -atr*1.5) trend = -1;
                }

                // Upper wick = SELL zone (price pushed up, got rejected back down)
                if(upWick >= wickMin && upWick > body*wickBodyRatio){
                    const zoneTop = h;
                    const zoneBot = Math.max(o,c);
                    const zoneMid = (zoneTop+zoneBot)/2;
                    // Inverted? Upper wick during downtrend = counter-trend rejection
                    // = continuation signal for shorts (price tried to rally but failed)
                    const inverted = trend === -1;
                    // De-dup against existing zones
                    let dup=false;
                    for(const wz of this.wickZones){
                        if(!wz.bull && Math.abs(wz.mid-zoneMid) < atr*0.5){
                            // Merge — extend zone to encompass both
                            wz.top = Math.max(wz.top, zoneTop);
                            wz.bot = Math.min(wz.bot, zoneBot);
                            wz.mid = (wz.top+wz.bot)/2;
                            wz.bar = bi;
                            dup=true; break;
                        }
                    }
                    if(!dup){
                        this.wickZones.push({
                            top:zoneTop, bot:zoneBot, mid:zoneMid,
                            bull:false,           // upper wick = bearish/sell zone
                            bar:bi, startBar:bi,
                            tested:false, mitigated:false,
                            inverted, trendCtx:trend
                        });
                    }
                }

                // Lower wick = BUY zone (price pushed down, got rejected back up)
                if(dnWick >= wickMin && dnWick > body*wickBodyRatio){
                    const zoneTop = Math.min(o,c);
                    const zoneBot = l;
                    const zoneMid = (zoneTop+zoneBot)/2;
                    // Inverted? Lower wick during uptrend = counter-trend rejection
                    // = continuation signal for longs (price tried to drop but failed)
                    const inverted = trend === 1;
                    let dup=false;
                    for(const wz of this.wickZones){
                        if(wz.bull && Math.abs(wz.mid-zoneMid) < atr*0.5){
                            wz.top = Math.max(wz.top, zoneTop);
                            wz.bot = Math.min(wz.bot, zoneBot);
                            wz.mid = (wz.top+wz.bot)/2;
                            wz.bar = bi;
                            dup=true; break;
                        }
                    }
                    if(!dup){
                        this.wickZones.push({
                            top:zoneTop, bot:zoneBot, mid:zoneMid,
                            bull:true,            // lower wick = bullish/buy zone
                            bar:bi, startBar:bi,
                            tested:false, mitigated:false,
                            inverted, trendCtx:trend
                        });
                    }
                }
            }

            // 2. WICK ZONE LIFECYCLE — tested when price re-enters the zone,
            //    mitigated when price closes through the far edge.
            //    Only on new bars — replay/tick updates would re-evaluate
            //    against the same closed bar's data, but mitigation is
            //    based on the bar's CLOSE which doesn't change after.
            //    Worse, during replay of a LATER bar's data into an EARLIER
            //    slot, mitigation would fire incorrectly.
            if(isNewBar){
                for(const wz of this.wickZones){
                    if(wz.mitigated) continue;
                    if(wz.bull){
                        // Buy zone — tested when price returns down to zone
                        if(l <= wz.top && l >= wz.bot) wz.tested = true;
                        if(c < wz.bot){
                            wz.mitigated = true;
                            // Bull zone violated = bearish flip event.
                            // Ro: "buyers don't die unless lows get broken"
                            // Once a demand zone is closed through, the
                            // sentiment in that range is now bearish.
                            this.lastZoneFlipBar = bi;
                            this.lastZoneFlipDir = -1;
                        }
                    } else {
                        // Sell zone — tested when price returns up to zone
                        if(h >= wz.bot && h <= wz.top) wz.tested = true;
                        if(c > wz.top){
                            wz.mitigated = true;
                            // Sell zone violated = bullish flip event.
                            // "sellers don't die unless highs get broken"
                            this.lastZoneFlipBar = bi;
                            this.lastZoneFlipDir = 1;
                        }
                    }
                }
                // Cap and prune
                if(this.wickZones.length > 30){
                    // Keep the most recent + unmitigated; drop oldest mitigated first
                    this.wickZones.sort((a,b) => {
                        if(a.mitigated !== b.mitigated) return a.mitigated ? -1 : 1;
                        return a.bar - b.bar;
                    });
                    while(this.wickZones.length > 30) this.wickZones.shift();
                }
            }

            // 3. BALANCE CLUSTERS — when N+ wick zones cluster within
            //    a tight price band, the area is "balanced." Multiple
            //    rejections from the same zone = wicks have agreed this
            //    is fair price.
            //    Recomputed every 5 bars (cheap, doesn't run every tick).
            //    Both cluster width (clusterWidthAtr) and minimum wick
            //    count (clusterMinWicks) are tunable for tick charts.
            const clusterWidthAtr = p.clusterWidthAtr != null ? Number(p.clusterWidthAtr) : 1.2;
            const clusterMinWicks = this.liveClusterMinWicks;
            if(bi % 5 === 0 && this.wickZones.length >= clusterMinWicks){
                const recent = this.wickZones
                    .filter(wz => !wz.mitigated && bi - wz.bar < 100)
                    .sort((a,b) => a.mid - b.mid);
                const clusters = [];
                let cur = null;
                for(const wz of recent){
                    if(cur && wz.mid - cur.bot <= atr*clusterWidthAtr){
                        cur.items.push(wz);
                        cur.top = Math.max(cur.top, wz.top);
                        cur.bot = Math.min(cur.bot, wz.bot);
                    } else {
                        if(cur && cur.items.length >= clusterMinWicks) clusters.push(cur);
                        cur = {items:[wz], top:wz.top, bot:wz.bot};
                    }
                }
                if(cur && cur.items.length >= clusterMinWicks) clusters.push(cur);
                this.balanceClusters = clusters.map(cl => ({
                    top: cl.top,
                    bot: cl.bot,
                    mid: (cl.top+cl.bot)/2,
                    wickCount: cl.items.length,
                    bars: cl.items.map(w => w.bar)
                }));
            }

            if(n>=10 && isNewBar){
                const move10=c-this.C[n-11];
                const hi10=Math.max.apply(null,this.H.slice(-10));
                const lo10=Math.min.apply(null,this.L.slice(-10));
                const range10=hi10-lo10;
                if(range10>atr*3&&c>hi10-atr*0.5&&move10>0&&
                   this.impulseDir!=1||(this.impulseEnd>0&&c>this.impulseEnd+atr*2)){
                    this.impulseOrigin=lo10;
                    this.impulseEnd=hi10;
                    this.impulseSize=range10;
                    this.impulseDir=1;
                    this.impulseBar=bi;
                    this.pbBars=[];
                }
                if(range10>atr*3&&c<lo10+atr*0.5&&move10<0&&
                   this.impulseDir!==-1||(this.impulseEnd>0&&c<this.impulseEnd-atr*2)){
                    this.impulseOrigin=hi10;
                    this.impulseEnd=lo10;
                    this.impulseSize=range10;
                    this.impulseDir=-1;
                    this.impulseBar=bi;
                    this.pbBars=[];
                }
            }

            this.pbClass='NONE';
            this.pbDepth=0;
            if(this.impulseSize>0&&bi-this.impulseBar<120){
                const pbMove = this.impulseDir===1
                    ? this.impulseEnd - c
                    : c - this.impulseEnd;
                this.pbDepth = Math.max(0, pbMove/this.impulseSize*100);

                if(this.pbDepth>0){
                    if(isNewBar){
                        const _lastPb = this.pbBars[this.pbBars.length-1];
                        if(!_lastPb || _lastPb.bar !== bi){
                            this.pbBars.push({range:h-l, vol, delta, bar:bi});
                            if(this.pbBars.length>20) this.pbBars.shift();
                        } else {
                            // Same-bar refresh (shouldn't happen on isNewBar
                            // but guard anyway)
                            _lastPb.range = h-l;
                            _lastPb.vol = vol;
                            _lastPb.delta = delta;
                        }
                    }

                    const pbLen=this.pbBars.length;

                    if(pbLen>=2){
                        const pbAvgVol=this.pbBars.reduce((s,b)=>s+b.vol,0)/pbLen;
                        const pbAvgRange=this.pbBars.reduce((s,b)=>s+b.range,0)/pbLen;
                        const lastPbDelta=this.pbBars[pbLen-1].delta;

                        const volDrying=pbAvgVol<avgVol*0.7;
                        const rangeShrinking=pbAvgRange<atr*0.7;
                        const deltaHolds=this.impulseDir===1?lastPbDelta>-avgVol*0.1
                                                              :lastPbDelta<avgVol*0.1;
                        const deltaFights=this.impulseDir===1?lastPbDelta<-avgVol*0.2
                                                               :lastPbDelta>avgVol*0.2;

                        if(this.pbDepth<38.2){
                            this.pbClass=(volDrying||rangeShrinking)?'CONTINUATION':'UNCERTAIN';
                        } else if(this.pbDepth<61.8){
                            if(volDrying&&deltaHolds)       this.pbClass='CONTINUATION';
                            else if(deltaFights&&pbLen>=3)  this.pbClass='REVERSAL';
                            else                             this.pbClass='UNCERTAIN';
                        } else if(this.pbDepth<100){
                            if(deltaFights)                 this.pbClass='REVERSAL';
                            else if(volDrying&&deltaHolds)  this.pbClass='UNCERTAIN';
                            else                            this.pbClass='REVERSAL';
                        } else {
                            this.pbClass='REVERSAL';
                            this.impulseDir*=-1;
                            this.impulseOrigin=this.impulseEnd;
                            this.impulseEnd=c;
                            this.impulseSize=Math.abs(c-this.impulseOrigin);
                            this.pbBars=[];
                        }
                    }
                }
            }

            // ─── PULLBACK TO σ CHECK ──
            if(this.exp1H>0 && bi>this.sessOpenBar+2){
                if(!this.trendDay){
                    if(c>this.exp1H&&this.sessOpen<this.exp1H){
                        this.trendDay=true; this.trendDayDir=1;
                    } else if(c<this.exp1L&&this.sessOpen>this.exp1L){
                        this.trendDay=true; this.trendDayDir=-1;
                    }
                }
                this.pullbackToSigma=false;
                if(this.openBias==='ABOVE_1S'||this.trendDayDir===1){
                    if(c>this.exp1H&&Math.abs(c-this.exp1H)<=atr*2){
                        this.pullbackToSigma=true;
                        this.pullbackLevel=this.exp1H;
                        this.pullbackLevelType='1σH';
                    }
                    if(this.trendDay&&c>this.exp2H&&Math.abs(c-this.exp2H)<=atr*2){
                        this.pullbackToSigma=true;
                        this.pullbackLevel=this.exp2H;
                        this.pullbackLevelType='2σH';
                    }
                }
                if(this.openBias==='BELOW_1S'||this.trendDayDir===-1){
                    if(c<this.exp1L&&Math.abs(c-this.exp1L)<=atr*2){
                        this.pullbackToSigma=true;
                        this.pullbackLevel=this.exp1L;
                        this.pullbackLevelType='1σL';
                    }
                    if(this.trendDay&&c<this.exp2L&&Math.abs(c-this.exp2L)<=atr*2){
                        this.pullbackToSigma=true;
                        this.pullbackLevel=this.exp2L;
                        this.pullbackLevelType='2σL';
                    }
                }
            }

            // ─── LOCATION CHECK ──
            // Find the most relevant level near current bar. Two key
            // improvements over a naive nearest-by-close approach:
            //
            // 1. Use bar wick proximity, not just close. A bar with low
            //    that wicked into a level "is at" that level even if the
            //    close drifted away from it.
            //
            // 2. PREFER strong levels (sigmas, JHOOK, MTT, BWICK/SWICK,
            //    BAL_H/BAL_L) over weak ones (BFOOT, SFOOT, VWAP) when both
            //    are reasonably close. A JHOOK_L at the bar's low is more
            //    important than a BFOOT a few ticks closer to close.
            const levels  = this._getLevels();
            const _isStrongLvl = (t) => t && (t.includes('σ') ||
                t==='BWICK' || t==='SWICK' || t==='BWICK_INV' || t==='SWICK_INV' ||
                t==='BAL_H' || t==='BAL_L' || t==='MTT_H' || t==='MTT_L' ||
                t==='JHOOK_L' || t==='JHOOK_H');
            let nearLevel = null, nearDist = 999999;
            let nearLevelStrong = null, nearDistStrong = 999999;
            for(const lv of levels){
                // Distance from any wick or close — closest point of bar to level
                const distToClose = Math.abs(c - lv.price);
                const distToWick = lv.price > c
                    ? Math.max(0, lv.price - h)   // level above bar
                    : lv.price < c
                    ? Math.max(0, l - lv.price)   // level below bar
                    : 0;
                // Use the smaller of close-distance or wick-distance
                const dist = Math.min(distToClose, distToWick);
                if(dist < nearDist){ nearDist=dist; nearLevel=lv; }
                if(_isStrongLvl(lv.type) && dist < nearDistStrong){
                    nearDistStrong = dist; nearLevelStrong = lv;
                }
            }
            // If we have a strong level within 2.0 ATR, prefer it over a
            // weak level even if a weak one is slightly closer. Strong
            // levels (sigmas, MTT, JHOOK, BWICK/SWICK, BAL_H/L) are the
            // structurally meaningful ones — when they exist, they should
            // anchor the read. The 2.0 ATR threshold (was 1.5) gives the
            // strong-level pulling power slightly further reach so the
            // structure isn't lost just because price has moved past.
            if(nearLevelStrong && nearDistStrong <= atr * 2.5){
                nearLevel = nearLevelStrong;
                nearDist = nearDistStrong;
            }
            // ── APPROACHING RESISTANCE/SUPPORT DETECTION ──
            // Even when not AT a level, detect when we're approaching a
            // strong topping/bottoming level (MTT_H/MTT_L, JHOOK_H/L) within
            // 2.5 ATR. This flag prevents firing continuation trades that
            // are heading INTO known resistance/support — e.g., longing
            // into a triple-top zone.
            this._approachingResistance = null;
            this._approachingSupport = null;
            for(const lv of levels){
                const isToppingLvl = lv.type === 'MTT_H' || lv.type === 'JHOOK_H';
                const isBottomingLvl = lv.type === 'MTT_L' || lv.type === 'JHOOK_L';
                if(!isToppingLvl && !isBottomingLvl) continue;
                const dist = Math.abs(c - lv.price);
                if(dist > atr * 2.5) continue;
                if(isToppingLvl && c < lv.price){
                    if(!this._approachingResistance ||
                       Math.abs(c - lv.price) < Math.abs(c - this._approachingResistance.price)){
                        this._approachingResistance = lv;
                    }
                }
                if(isBottomingLvl && c > lv.price){
                    if(!this._approachingSupport ||
                       Math.abs(c - lv.price) < Math.abs(c - this._approachingSupport.price)){
                        this._approachingSupport = lv;
                    }
                }
            }
            // ── ANTICIPATORY: TWO RECENT SWINGS NEAR EACH OTHER ──
            // Before a double-top has been "confirmed" via cluster
            // detection (which requires both swings to be retained in
            // swingHighs and clustered), look for two recent swing highs
            // within 1 ATR of each other above current price. That's a
            // forming double-top zone and price is approaching it.
            if(!this._approachingResistance && this.swingHighs && this.swingHighs.length >= 2){
                const recentSH = this.swingHighs.filter(s =>
                    bi - s.bar <= 20 && s.price > c && s.price - c <= atr * 2.5);
                if(recentSH.length >= 2){
                    for(let i = 0; i < recentSH.length; i++){
                        for(let j = i+1; j < recentSH.length; j++){
                            if(Math.abs(recentSH[i].price - recentSH[j].price) <= atr * 1.0){
                                const avgPrice = (recentSH[i].price + recentSH[j].price) / 2;
                                this._approachingResistance = { price: avgPrice, type: 'MTT_H', touches: 2 };
                                break;
                            }
                        }
                        if(this._approachingResistance) break;
                    }
                }
            }
            if(!this._approachingSupport && this.swingLows && this.swingLows.length >= 2){
                const recentSL = this.swingLows.filter(s =>
                    bi - s.bar <= 20 && s.price < c && c - s.price <= atr * 2.5);
                if(recentSL.length >= 2){
                    for(let i = 0; i < recentSL.length; i++){
                        for(let j = i+1; j < recentSL.length; j++){
                            if(Math.abs(recentSL[i].price - recentSL[j].price) <= atr * 1.0){
                                const avgPrice = (recentSL[i].price + recentSL[j].price) / 2;
                                this._approachingSupport = { price: avgPrice, type: 'MTT_L', touches: 2 };
                                break;
                            }
                        }
                        if(this._approachingSupport) break;
                    }
                }
            }
            if(this.pullbackToSigma){
                nearLevel={price:this.pullbackLevel, type:this.pullbackLevelType};
                nearDist=Math.abs(c-this.pullbackLevel);
            }
            // atLevel: are we close enough to nearLevel for it to drive
            // a trade? Tighter threshold (1.5 ATR) for weak levels (VWAP,
            // SH/SL singles, voids); looser (2.5 ATR) for strong structural
            // levels (sigmas, MTT, JHOOK, BWICK/SWICK). Strong levels have
            // pulling power even when not exactly tagged.
            const _nearLvlIsStrong = nearLevel && _isStrongLvl(nearLevel.type);
            const atLevel = nearLevel && nearDist <= atr * (_nearLvlIsStrong ? 2.5 : 1.5);

            // ── CLIMACTIC REVERSAL DETECTION ──
            let isClimaticLong=false, isClimaticShort=false;
            if(n>=5){
                const lowerWick = c - l;
                const upperWick = h - c;
                const barRange  = h - l;
                const wickRatio = barRange>0 ? lowerWick/barRange : 0;
                const fastDrop  = n>=6 && (this.C[n-6]-c) > atr*3;
                const clxMult = sessSuffix==='_ny' ? 2.0 : 1.6;
                const volClimax = vol > avgVol*clxMult;
                isClimaticLong  = fastDrop && volClimax && dfBull && wickRatio>0.4
                                  && (atLevel || this.pbDepth>60);

                const fastRise  = n>=6 && (c-this.C[n-6]) > atr*3;
                isClimaticShort = fastRise && volClimax && dfBear && (1-wickRatio)>0.4
                                  && (atLevel || this.pbDepth>60);
            }

            // ── DELTA WALLS ──
            // Only on new bars — replay/tick updates with the same delta
            // would re-evaluate the threshold against unchanged values
            // and could push duplicates that the loose dedup misses.
            const isNYSess = sessSuffix==='_ny';
            const wallDeltaMult = isNYSess ? 2.0 : 1.6;
            const wallVolMult   = isNYSess ? 1.5 : 1.3;
            if(isNewBar && Math.abs(delta) > avgVol*wallDeltaMult && vol > avgVol*wallVolMult){
                const wallPrice = (h+l)/2;
                const wallDir   = delta>0 ? 1 : -1;
                let dup=false;
                for(const w of this.deltaWalls){
                    if(w.dir===wallDir && Math.abs(w.price-wallPrice)<atr){
                        if(Math.abs(delta) > Math.abs(w.delta)){
                            w.price=wallPrice; w.delta=delta; w.bar=bi;
                        }
                        dup=true; break;
                    }
                }
                if(!dup){
                    this.deltaWalls.push({price:wallPrice, delta, dir:wallDir, bar:bi});
                    this.deltaWalls.sort((a,b)=>Math.abs(b.delta)-Math.abs(a.delta));
                    if(this.deltaWalls.length>5) this.deltaWalls.length=5;
                }
            }

            // ── FOOTPRINT ──
            // Volume/delta accumulators per price slot — only on new bars
            // to avoid double-counting during replay/tick updates.
            const _fb = this.footprintBucket;
            const slotKey = Math.round(((h+l)/2)/_fb)*_fb;
            if(isNewBar){
                if(!this.footprint[slotKey]) this.footprint[slotKey]={vol:0, delta:0, lastBar:bi};
                this.footprint[slotKey].vol   += vol;
                this.footprint[slotKey].delta += delta;
                this.footprint[slotKey].lastBar = bi;
            }
            if(isNewBar && bi % 10 === 0 && bi > this.sessOpenBar+30){
                const slots=[];
                for(const k in this.footprint){
                    const s=this.footprint[k];
                    if(s.vol > avgVol*2){
                        slots.push({price:Number(k), delta:s.delta, dir:s.delta>0?1:-1});
                    }
                }
                slots.sort((a,b)=>Math.abs(b.delta)-Math.abs(a.delta));
                this.footprintTops = slots.slice(0,3);
            }

            this.higherLow = this.h1HigherLow;
            this.lowerHigh  = this.h1LowerHigh;

            // Swing detection runs only on isNewBar — during scroll-replay
            // the swings were already detected on the original forward
            // pass and pushing again with the current (advanced) `bi` would
            // attribute swings to the wrong bar number, causing replay to
            // diverge from the live timeline.
            if(n>=6 && isNewBar){
                const si=n-3;
                const sL=this.L[si],sH=this.H[si];
                if(sL<this.L[si-1]&&sL<this.L[si-2]&&sL<this.L[si+1]&&sL<this.L[n-1]){
                    const _lastSL = this.swingLows[this.swingLows.length-1];
                    if(!_lastSL || _lastSL.bar !== bi-2){
                        this.swingLows.push({price:sL,bar:bi-2});
                        if(this.swingLows.length>8) this.swingLows.shift();
                    }
                }
                if(sH>this.H[si-1]&&sH>this.H[si-2]&&sH>this.H[si+1]&&sH>this.H[n-1]){
                    const _lastSH = this.swingHighs[this.swingHighs.length-1];
                    if(!_lastSH || _lastSH.bar !== bi-2){
                        this.swingHighs.push({price:sH,bar:bi-2});
                        if(this.swingHighs.length>8) this.swingHighs.shift();
                    }
                }
                if(this.swingLows.length>=2){
                    const sl1=this.swingLows[this.swingLows.length-1].price;
                    const sl2=this.swingLows[this.swingLows.length-2].price;
                    if(sl1>sl2 && !this.h1LowerHigh) this.higherLow=true;
                }
                if(this.swingHighs.length>=2){
                    const sh1=this.swingHighs[this.swingHighs.length-1].price;
                    const sh2=this.swingHighs[this.swingHighs.length-2].price;
                    if(sh1<sh2 && !this.h1HigherLow) this.lowerHigh=true;
                }
            }

            // ── BREAK OF STRUCTURE (BOS) + LIQUIDITY SWEEP DETECTOR ──
            // Two distinct outcomes when price breaks a swing level:
            //
            // BOS (true break, holds): close beyond level + subsequent
            //   bars stay on that side → genuine trend shift. Bearish if
            //   broke down, bullish if broke up.
            //
            // SWEEP (false break, reverses): wick or close briefly beyond
            //   level, then within 1-3 bars price closes BACK on original
            //   side → liquidity grab. The reversal AFTER the sweep is the
            //   actual signal — opposite direction from the breach.
            //
            // Both can't be true at the same time. Sweep detection runs
            // FIRST and supersedes any tentative BOS read on the same bar.
            //
            // Why this matters: the user's "1H flip" patterns are often
            // sweep-and-reverse setups, not clean rejections. A double or
            // triple top often punches above one of the prior highs (the
            // sweep) before reversing. The sweep itself is the strongest
            // signal — it traps breakout buyers and ignites the reversal.
            if(isNewBar && this.swingHighs.length > 0 && this.swingLows.length > 0){
                const lastSH = this.swingHighs[this.swingHighs.length-1];
                const lastSL = this.swingLows[this.swingLows.length-1];
                const breakMargin = atr * 0.5;
                const reclaimMargin = atr * 0.15;  // small re-cross is enough

                // ── SWEEP DETECTION (priority over BOS) ──
                // Mark a candidate sweep when current bar EXCEEDED a swing
                // level (high pierces resistance / low pierces support).
                // Then watch for the reversal close on this bar or next 3 bars.
                if(h > lastSH.price + breakMargin*0.4 && c < lastSH.price - reclaimMargin){
                    // Bar wicked above resistance, then closed back below
                    // = upside sweep, reversal signal = SHORT.
                    this.sweepDir = -1;
                    this.sweepLevel = lastSH.price;
                    this.sweepBar = bi;
                    this.sweepConfirmedBar = bi;
                    // Sweep invalidates any current BOS up
                    if(this.bosDir === 1) this.bosDir = 0;
                }
                if(l < lastSL.price - breakMargin*0.4 && c > lastSL.price + reclaimMargin){
                    // Bar wicked below support, then closed back above
                    // = downside sweep, reversal signal = LONG.
                    this.sweepDir = 1;
                    this.sweepLevel = lastSL.price;
                    this.sweepBar = bi;
                    this.sweepConfirmedBar = bi;
                    if(this.bosDir === -1) this.bosDir = 0;
                }
                // ── BOS DETECTION (only if no sweep just happened) ──
                // Close decisively beyond the swing level (not just a wick)
                // and the prior bar's high/low DIDN'T reverse it.
                const recentSweep = this.sweepBar > 0 && bi - this.sweepBar < 3;
                if(!recentSweep){
                    if(c < lastSL.price - breakMargin){
                        if(this.bosDir !== -1 || this.bosTriggerBar < lastSL.bar){
                            this.bosDir = -1;
                            this.bosTriggerBar = bi;
                            this.bosBrokeLevel = lastSL.price;
                        }
                    }
                    if(c > lastSH.price + breakMargin){
                        if(this.bosDir !== 1 || this.bosTriggerBar < lastSH.bar){
                            this.bosDir = 1;
                            this.bosTriggerBar = bi;
                            this.bosBrokeLevel = lastSH.price;
                        }
                    }
                }
                // BOS decays after 20 bars
                if(this.bosTriggerBar > 0 && bi - this.bosTriggerBar > 20){
                    this.bosDir = 0;
                    this.bosTriggerBar = 0;
                    this.bosBrokeLevel = 0;
                }
                // Sweep state decays after 8 bars (signal is fresh, then aging)
                if(this.sweepBar > 0 && bi - this.sweepBar > 8){
                    this.sweepDir = 0;
                    this.sweepLevel = 0;
                    this.sweepBar = 0;
                    this.sweepConfirmedBar = 0;
                }
            }

            if(this.sessOpen>0&&bi>this.sessOpenBar+10){
                const sessMove=c-this.sessOpen;
                const sessRange=this.sessHigh-this.sessLow;
                if(Math.abs(sessMove)>this.atr*3){
                    this.impulseDir=sessMove>0?1:-1;
                    this.impulseSize=Math.abs(sessMove);
                    this.impulseOrigin=this.sessOpen;
                    this.impulseEnd=c;
                }
            }

            const _ret = {graphics:{items:[]}};
            const _items = _ret.graphics.items;

            // ── HUD SIZE & COLOR CONTROLS ─────────────────────────────
            // hudScale multiplies all font sizes (1.0 = default, 1.5 = 50%
            // bigger, 2.0 = double). Lets user dial the entire HUD up/down.
            // brightMode: 0 = standard colors, 1 = brightened for dark bg.
            // Both tunable via param panel.
            const hudScale = (p.hudScale != null) ? Math.max(0.5, Math.min(3, p.hudScale)) : 1.0;
            const brightMode = (p.brightMode != null) ? p.brightMode : 1;
            const _fz = (n) => Math.round(n * hudScale);  // size helper
            // Bright color palette for dark backgrounds (more readable)
            const _C = brightMode >= 1 ? {
                bullBright:  '#00FFD0',  // entry long, win
                bearBright:  '#FF7744',  // entry short
                slLine:      '#FF4444',
                tpLine:      '#00FF66',
                trailLine:   '#33DD55',
                winText:     '#00FF99',
                lossText:    '#FF5555',
                statusOK:    '#FFFFFF',
                statusWarn:  '#FFCC44',
                statusErr:   '#FF6666',
                pnlPos:      '#00FF99',
                pnlNeg:      '#FF6666',
                diagBlue:    '#AABBFF',
                diagGray:    '#CCCCCC',
                wickBull:    '#22EE99',
                wickBear:    '#FF8855',
                balanceCol:  '#DDCCFF',
                mktBull:     '#00FFD0',
                mktBear:     '#FF7744',
                mktNeutral:  '#DDDDDD',
            } : {
                bullBright:  '#00FFCC', bearBright:  '#FF6622',
                slLine:      '#FF4444', tpLine:      '#00FF66', trailLine:'#00AA44',
                winText:     '#00DC78', lossText:    '#E24B4A',
                statusOK:    '#FFFFFF', statusWarn:  '#FFAA22', statusErr:'#FF4444',
                pnlPos:      '#00CC66', pnlNeg:      '#FF6666',
                diagBlue:    '#88AAFF', diagGray:    '#888899',
                wickBull:    '#00cc88', wickBear:    '#cc6644',
                balanceCol:  '#aa99cc',
                mktBull:     '#00FFCC', mktBear:     '#FF6622', mktNeutral:'#FFFFFF',
            };
            const showFallbackSigmas = (p.showFallbackSigmas != null ? p.showFallbackSigmas : 0) >= 1;

            if(this.exp1H>0 && (this.expDailyIsInput || showFallbackSigmas)){
                _ret.sessId   = this.sessKey;
                _ret.expCurH  = this.exp1H;
                _ret.expH=this.exp1H; _ret.expL=this.exp1L;
                _ret.exp2H=this.exp2H; _ret.exp2L=this.exp2L;
                _ret.exp3H=this.exp3H; _ret.exp3L=this.exp3L;
                _ret.exp4H=this.exp4H; _ret.exp4L=this.exp4L;
                _ret.expM=this.expMid;
            }
            _ret.weekId=this.weekKey; _ret.wkH=this.wk1H; _ret.wkL=this.wk1L;
            _ret.monthId=this.monthKey; _ret.moH=this.mo1H; _ret.moL=this.mo1L;

            // Draw expected-move bands as ordinary graphics on the latest
            // bar only. Keeping this before the warmup/ready gate lets EM
            // render while the signal engine warms up, without stacking one
            // full band set for every historical bar.
            const _drawEMFallback = typeof d.isLast==='function' && d.isLast();
            const _emRight = this.lastChartIdx + 10;
            const _emLeft = Math.max(0, this.lastChartIdx - 40);
            const _emLabelX = op(du(this.lastChartIdx),'+',px(10));
            const _emLine = (key, y, color, width, opacity, label) => {
                if(!(y > 0)) return;
                _items.push({tag:'LineSegments', key:key,
                    lines:[{tag:'Line', a:{x:du(_emLeft), y:du(y)}, b:{x:du(_emRight), y:du(y)}}],
                    lineStyle:{lineWidth:width, color:color, opacity:opacity}});
                if(label){
                    _items.push({tag:'Text', key:key+'_lbl', text:label+' '+y.toFixed(0),
                        point:{x:_emLabelX, y:du(y)},
                        style:{fontSize:_fz(10), fontWeight:'bold', fill:color},
                        textAlignment:'leftMiddle', global:true});
                }
            };
            // Live daily EM — read expMoveDaily every render and anchor at the
            // session open, so the bands appear the instant you set the param
            // (no dependency on the session-open recompute / stale flag).
            // Prefer the setting if Tradovate passes it; otherwise use the
            // EM_DAILY constant at the top of the file (so bands always draw).
            let _emDLive = (this.props && Number(this.props.expMoveDaily)) || 0;
            if(!(_emDLive > 0)) _emDLive = EM_DAILY;
            // Match the plotter's anchor exactly: Settings rthOpen, else the
            // RTH_OPEN constant, else the auto 9:30 open, else session/last.
            const _rthInL = (this.props && Number(this.props.rthOpen)) || 0;
            const _emAnchor = _rthInL > 0     ? _rthInL
                            : RTH_OPEN > 0     ? RTH_OPEN
                            : this.rthOpen > 0 ? this.rthOpen
                            : this.sessOpen > 0 ? this.sessOpen : c;
            if(_drawEMFallback && _emDLive > 0){
                _emLine('em_d_1h', _emAnchor+_emDLive*0.5, '#00CCFF', 2, 1.0, 'D +0.5EM');
                _emLine('em_d_1l', _emAnchor-_emDLive*0.5, '#00CCFF', 2, 1.0, 'D -0.5EM');
                _emLine('em_d_mid', _emAnchor, '#00FF88', 1, 0.35, 'D OPEN');
                _emLine('em_d_2h', _emAnchor+_emDLive, '#FF8C00', 1, 0.85, 'D +1EM');
                _emLine('em_d_2l', _emAnchor-_emDLive, '#FF8C00', 1, 0.85, 'D -1EM');
                _emLine('em_d_3h', _emAnchor+_emDLive*1.5, '#FFEE00', 1, 0.75, 'D +1.5EM');
                _emLine('em_d_3l', _emAnchor-_emDLive*1.5, '#FFEE00', 1, 0.75, 'D -1.5EM');
                _emLine('em_d_4h', _emAnchor+_emDLive*2.0, '#FF2244', 2, 0.9, 'D +2EM');
                _emLine('em_d_4l', _emAnchor-_emDLive*2.0, '#FF2244', 2, 0.9, 'D -2EM');
            } else if(_drawEMFallback && this.exp1H>0 && showFallbackSigmas){
                _emLine('em_d_1h', this.exp1H, '#00CCFF', 2, 1.0, 'D +0.5EM');
                _emLine('em_d_1l', this.exp1L, '#00CCFF', 2, 1.0, 'D -0.5EM');
                _emLine('em_d_2h', this.exp2H, '#FF8C00', 1, 0.85, 'D +1EM');
                _emLine('em_d_2l', this.exp2L, '#FF8C00', 1, 0.85, 'D -1EM');
            }
            if(_drawEMFallback && this.wk1H>0){
                _emLine('em_w_1h', this.wk1H, '#B388FF', 2, 0.8, 'WK +EM');
                _emLine('em_w_1l', this.wk1L, '#B388FF', 2, 0.8, 'WK -EM');
            }
            if(_drawEMFallback && this.mo1H>0){
                _emLine('em_m_1h', this.mo1H, '#FF88DD', 2, 0.7, 'MO +EM');
                _emLine('em_m_1l', this.mo1L, '#FF88DD', 2, 0.7, 'MO -EM');
            }
            if(_drawEMFallback && !(_emDLive > 0)){
                // Hint shown only when no daily move is set anywhere.
                _items.push({tag:'Text', key:'em_status_off',
                    text:'EM off — set expMoveDaily in the Settings panel',
                    point:{x:_emLabelX, y:du(c + atr*1.8)},
                    style:{fontSize:_fz(10), fontWeight:'bold', fill:'#FFCC44'},
                    textAlignment:'leftMiddle', global:true});
            }

            const readyTime = sessSuffix !== '_overnight' ||
                              (tNY && (bLth===9 || (bLth===8&&bLtm>=30)));
            if(bi < 20 || !readyTime) return _ret;

            let isExhausted=false, exhDir=0;
            if(this.exhBars.length>=5){
                const eb=this.exhBars;
                const first=eb[0],last=eb[eb.length-1];
                if(first.range>last.range*1.25&&(first.vol>last.vol*1.2||Math.abs(first.delta)>Math.abs(last.delta)*1.2)){
                    isExhausted=true; exhDir=this.exhDir;
                }
            }

            if(n>=20&&this.exp1H>0&&bi>this.sessOpenBar+2){
                let upC=0,dnC=0;
                for(let i=n-10;i<n;i++){if(this.C[i]>this.O[i])upC++;else if(this.C[i]<this.O[i])dnC++;}
                const hi20=Math.max.apply(null,this.H.slice(-20));
                const lo20=Math.min.apply(null,this.L.slice(-20));
                const rs=hi20-lo20;
                const cp20=rs>0?(c-lo20)/rs:0.5;
                const nt=cp20>0.75,nb=cp20<0.25;
                let dc=0;
                for(let i=n-9;i<n;i++){
                    const pd=(this.C[i-1]>=this.O[i-1])?1:-1,cd2=(this.C[i]>=this.O[i])?1:-1;
                    if(pd!==cd2)dc++;
                }
                const hi5=Math.max.apply(null,this.H.slice(-5)),lo5=Math.min.apply(null,this.L.slice(-5));
                const tc=rs>0?(hi5-lo5)/rs<0.35:false;

                const dailyBear = this.dailyBias==='BEAR';
                const dailyBull = this.dailyBias==='BULL';

                const h1CurDir = this.h1O>0 ? (c>=this.h1O?1:-1) : 0;
                const h1Bull = this.h1Trend==='BULL' || this.h1HigherLow;
                const h1Bear = this.h1Trend==='BEAR' || this.h1LowerHigh;
                const h4Bull = this.h4Trend==='BULL' || this.h4Dir===1;
                const h4Bear = this.h4Trend==='BEAR' || this.h4Dir===-1;

                const nm20=c-this.C[n-20];
                const nm10=n>=10?c-this.C[n-10]:nm20;
                const tickBull = nm20>this.atr*1.5 && nm10>this.atr*0.5;
                const tickBear = nm20<-this.atr*1.5 && nm10<-this.atr*0.5;

                const sessMove = this.sessOpen>0 ? c-this.sessOpen : 0;
                const sessBull = sessMove > this.atr*2;
                const sessBear = sessMove < -this.atr*2;

                // ── OSCILLATION-BASED RANGE DETECTION ──
                // True range markets oscillate. Detect by counting how
                // many times the medium-term slope (5-bar net move) flips
                // direction over the last 25 bars. Smooth sine-wave-like
                // ranges produce 2-4 slope reversals; sustained trends
                // produce 0-1.
                //
                // Combined with: total range stays modest (< 6 ATR over
                // 20 bars) AND latest close is near the middle of the range
                // (not pinned to top or bottom).
                let slopeFlips = 0;
                if(n >= 26){
                    let prevSlopeSign = 0;
                    for(let i = n-25; i+5 < n; i++){
                        const slope = this.C[i+5] - this.C[i];
                        if(Math.abs(slope) < this.atr * 0.5) continue;
                        const sign = slope > 0 ? 1 : -1;
                        if(prevSlopeSign !== 0 && sign !== prevSlopeSign) slopeFlips++;
                        prevSlopeSign = sign;
                    }
                }
                const totalRange20 = hi20 - lo20;
                const closeMidPosition = totalRange20 > 0 ? (c - lo20) / totalRange20 : 0.5;
                const inMiddle = closeMidPosition >= 0.25 && closeMidPosition <= 0.75;
                const isOscillating = slopeFlips >= 2 &&
                                     totalRange20 < this.atr * 7 &&
                                     inMiddle;

                const prevBear = this.mktState==='TRENDING_DN';
                const prevBull = this.mktState==='TRENDING_UP';
                const barsInState = bi - this.mktStateBar;
                const needsH1ToFlip = barsInState >= 20;

                const sb = h1Bull || (sessBull && tickBull) ||
                           (!needsH1ToFlip && tickBull && sessBull);
                const sbr = h1Bear || (sessBear && tickBear) ||
                            (!needsH1ToFlip && tickBear && sessBear);
                const ir = dc>=6&&!nt&&!nb&&!tc&&!sb&&!sbr;

                this.volConfirm=n>=3&&(
                    (this.C[n-1]>this.C[n-2]&&this.C[n-2]>this.C[n-3]&&this.V[n-1]>this.V[n-2])||
                    (this.C[n-1]<this.C[n-2]&&this.C[n-2]<this.C[n-3]&&this.V[n-1]>this.V[n-2])
                );
                const isTransit=isExhausted&&(this.trendDay||this.pbDepth>50)&&atLevel&&this.impulseSize>this.atr*5;
                const prev=this.mktState;

                const h1CurStrong = this.h1O>0 && Math.abs(c-this.h1O)>this.atr*4;
                const h1CurBull = h1CurDir===1;
                const h1CurBear = h1CurDir===-1;

                if(isTransit)                                           this.mktState='TRANSITIONING';
                else if(isOscillating)                                  {this.mktState='RANGING';this.rangeHigh=hi20;this.rangeLow=lo20;}
                else if(dailyBear && h4Bear && h1Bear && h1CurBear)     this.mktState='TRENDING_DN';
                else if(dailyBull && h4Bull && h1Bull && h1CurBull)     this.mktState='TRENDING_UP';
                else if(h1Bear && h1CurBear && !h1CurStrong)            this.mktState='TRENDING_DN';
                else if(h1Bull && h1CurBull && !h1CurStrong)            this.mktState='TRENDING_UP';
                else if(h1CurStrong && h1CurBull && sessBull)           this.mktState='TRENDING_UP';
                else if(h1CurStrong && h1CurBear && sessBear)           this.mktState='TRENDING_DN';
                else if(tc&&sb)                                         this.mktState='TRENDING_UP';
                else if(tc&&sbr)                                        this.mktState='TRENDING_DN';
                else if(ir)                                             {this.mktState='RANGING';this.rangeHigh=hi20;this.rangeLow=lo20;}
                else if(sb)                                             this.mktState='TRENDING_UP';
                else if(sbr)                                            this.mktState='TRENDING_DN';
                else                                                    {this.mktState='RANGING';this.rangeHigh=hi20;this.rangeLow=lo20;}

                const h1fr=bi-this.h1FlipBar<=8;
                if(this.h1FlipBull&&h1fr) this.mktState='TRENDING_UP';
                if(this.h1FlipBear&&h1fr)  this.mktState='TRENDING_DN';
                this.trendStrength=ir?Math.max(0,dc-4):Math.max(upC,dnC);
                if(this.mktState!==prev) this.mktStateBar=bi;
            }

            // ─────────────────────────────────────────────────────────
            // END-OF-SESSION RISK CONTROL
            // ─────────────────────────────────────────────────────────
            // Compute two booleans every bar:
            //   sessionEndExit  = within 5 min of close → force-close any
            //                     open position at market
            //   sessionEndBlock = within 15 min of close → stop opening
            //                     new entries (don't take a trade we can't manage)
            //
            // Close times per session (in tz-adjusted hours/minutes):
            //   NY:    closes 16:00 EDT → exit at 15:55, block from 15:45
            //   EVE:   closes ~17:00 EDT → exit at 16:55, block from 16:45
            //          (note: 5pm EDT is contract daily settlement)
            //   LON:   closes 08:00 EDT → exit at 07:55, block from 07:45
            //   ASIA:  closes 04:00 EDT → exit at 03:55, block from 03:45
            //
            // These are RISK rules, not profit-optimization. They prevent
            // holding into low-liquidity boundaries, settlement gaps, or
            // overnight positions that weren't intended.
            let sessionEndExit = false;
            let sessionEndBlock = false;
            // Convert wall-clock hour:minute into a "minutes since midnight"
            // value to make comparisons cleaner.
            const _mins = bLth*60 + bLtm;
            if(sessSuffix === '_ny'){
                // NY: close 16:00, exit window 15:55-16:00, block 15:45+
                if(_mins >= 15*60+55 && _mins < 16*60) sessionEndExit = true;
                if(_mins >= 15*60+45) sessionEndBlock = true;
            } else if(sessSuffix === '_eve'){
                // EVE: trades 18:00-22:59, close at 23:00.
                // Exit window 22:55-23:00, block from 22:45.
                if(_mins >= 22*60+55 && _mins < 23*60) sessionEndExit = true;
                if(_mins >= 22*60+45) sessionEndBlock = true;
            } else if(sessSuffix === '_london'){
                // LON: close 08:00, exit at 07:55
                if(_mins >= 7*60+55 && _mins < 8*60) sessionEndExit = true;
                if(_mins >= 7*60+45) sessionEndBlock = true;
            } else if(sessSuffix === '_asia'){
                // ASIA: trades 19:00-02:59, practical close 03:00.
                // Exit window 02:55-03:00, block from 02:45.
                if(_mins >= 2*60+55 && _mins < 3*60) sessionEndExit = true;
                if(_mins >= 2*60+45) sessionEndBlock = true;
            }

            // ─────────────────────────────────────────────────────────
            // POSITION MANAGEMENT
            // ─────────────────────────────────────────────────────────
            // Only run on the live forward timeline — not on replay
            // passes. Otherwise SL/TP would falsely trigger when an old
            // bar is replayed that happens to touch our stop level.
            let exitNow=false, exitPnl=0, exitDir=0;

            // ════════════════════════════════════════════════════
            // RUN PATTERN HELPERS BEFORE POSITION MANAGEMENT
            // ════════════════════════════════════════════════════
            // These vote on levelVotes which is used by:
            //   • Position exit decisions — Wyckoff event override can
            //     detect a reversal signature and trigger early exit
            //   • Entry decisions (when canTrade later)
            // Helpers must run BEFORE the position block so the exit
            // logic can see the current bar's votes.
            if(isNewBar){
                this.levelVotes.clear();
                this._runHelpers(c, h, l, o, vol, atr, avgVol);
            }

            if(this.position!==0 && !isReplayPass){
                if(isNewBar) this.barsHeld++;
                const pos = this.position;

                // ── CAPITAL PRESERVATION LAYERS ─────────────────────
                // For trailing-drawdown prop firms, giving back unrealized
                // profit is as bad as losing money. Three layers of
                // protection, applied in order:
                //   (1) Breakeven move — when up breakevenAtR × risk,
                //       move SL to entry+1tick (long) / entry-1tick (short)
                //   (2) Lock-in move — when up lockInAtR × risk, move SL
                //       to entry + 0.3R (locks small profit)
                //   (3) Peak give-back exit — track unrealized peak. If
                //       price retraces > peakGiveBackPct% from peak,
                //       exit immediately at market.
                //
                // All three protect compounding the same way: each tier
                // raises the floor under your trade. Once locked, can't
                // un-lock — SL only moves favorably.
                const breakevenAtR    = (p.breakevenAtR    != null) ? p.breakevenAtR    : 0.5;
                const lockInAtR       = (p.lockInAtR       != null) ? p.lockInAtR       : 1.0;
                const peakGiveBackPct = (p.peakGiveBackPct != null) ? p.peakGiveBackPct : 50;
                // Risk = original SL distance. Set on entry, doesn't change.
                if(this.entryRisk == null || this.entryRisk <= 0){
                    this.entryRisk = Math.abs(this.ep - this.sl);
                }
                const _R = this.entryRisk;
                // Current unrealized P/L in points (positive = winning)
                const _unrealized = pos===1 ? c - this.ep : this.ep - c;
                // Track peak unrealized P/L per trade. Reset on entry.
                if(this.peakUnrealizedPnl == null) this.peakUnrealizedPnl = 0;
                if(_unrealized > this.peakUnrealizedPnl){
                    this.peakUnrealizedPnl = _unrealized;
                }

                // ── Layer 1: breakeven move ──
                // Once trade is up breakevenAtR × R (default 0.5R = halfway
                // to TP1 if TP1 is at 1.5R), pull SL to entry. Worst case
                // becomes a wash trade — no give-back to negative.
                if(_R > 0 && breakevenAtR > 0 && !this.beMoved &&
                   _unrealized >= _R * breakevenAtR){
                    // One tick (0.25 NQ, 0.10 Gold, etc) buffer to avoid
                    // wick whipsaws.
                    const tick = this.tickSize;
                    if(pos===1)  this.sl = Math.max(this.sl, this.ep + tick);
                    if(pos===-1) this.sl = Math.min(this.sl, this.ep - tick);
                    this.beMoved = true;  // one-time per trade
                }

                // ── Layer 2: lock-in move ──
                // Once trade is up lockInAtR × R (default 1.0R), move SL
                // to entry + 0.3R. Now any exit is GREEN.
                if(_R > 0 && lockInAtR > 0 && !this.lockMoved &&
                   _unrealized >= _R * lockInAtR){
                    const _lockBuf = _R * 0.3;
                    if(pos===1)  this.sl = Math.max(this.sl, this.ep + _lockBuf);
                    if(pos===-1) this.sl = Math.min(this.sl, this.ep - _lockBuf);
                    this.lockMoved = true;
                }

                // ── Layer 3: peak give-back exit ──
                // If we've made meaningful profit (> 0.5R unrealized peak)
                // and price has retraced peakGiveBackPct% from that peak,
                // exit at market. This catches "trade went +20pt, came back
                // to +10pt" before it becomes "+20 → +0 → SL".
                // Only activates after a meaningful peak to avoid noise
                // exits on tiny initial wiggles.
                //
                // peakGiveBackPct here is BASE — strength score below may
                // tighten it (weak trend = exit faster) or loosen it
                // (strong trend = let it run).
                let peakGiveBackExit = false;
                let effectiveGiveBackPct = peakGiveBackPct;

                // ── RUNTIME EXIT INTELLIGENCE ───────────────────────
                // Two market-aware checks while in trade:
                //   strengthChk → 0-10 score in trade direction
                //   thesisChk   → frameworks still support trade direction?
                // Both can be disabled via params for pure mechanical exits.
                const strengthOn = (p.strengthExit != null) ? p.strengthExit : 1;
                const thesisOn   = (p.thesisExit   != null) ? p.thesisExit   : 1;
                let strengthScore = 5;
                let strengthReasons = [];
                let thesisIntact = true;
                let thesisVotesAgainst = 0;
                let thesisReasons = [];

                if(strengthOn >= 1){
                    const sc = this._assessTrendStrength(c, h, l, atr, n, pos);
                    strengthScore = sc.score;
                    strengthReasons = sc.reasons;
                    // STRONG (7-10): loosen trail, looser give-back
                    // MODERATE (4-6): default behavior
                    // WEAK (1-3): tighten trail, tighter give-back
                    // FADED (0): exit at market if in profit
                    if(strengthScore >= 7){
                        // Let runners run — push trail wider, allow more give-back
                        effectiveGiveBackPct = Math.min(80, peakGiveBackPct + 20);
                    } else if(strengthScore <= 3 && strengthScore >= 1){
                        // Trend fading — tighten the leash
                        effectiveGiveBackPct = Math.max(20, peakGiveBackPct - 25);
                    } else if(strengthScore === 0 && _unrealized > 0){
                        // Trend completely faded while in profit — exit
                        peakGiveBackExit = true;
                    }
                    this.lastStrengthScore = strengthScore;
                }

                if(thesisOn >= 1 && _R > 0 && _unrealized > _R * 0.3){
                    // Only check thesis once we've made some profit. Don't
                    // bail on a brand-new trade just because frameworks shifted
                    // by a few ticks.
                    const tc = this._assessThesisIntact(c, h, l, o, vol, delta, atr, avgVol, n,
                                                        pos, levels, nearLevel, nearDist);
                    thesisIntact = tc.intact;
                    thesisVotesAgainst = tc.votesAgainst;
                    thesisReasons = tc.reasons;
                    this.lastThesisAgainst = thesisVotesAgainst;
                }
                // Thesis-broken exit: 2+ frameworks now oppose us
                const thesisBrokenExit = thesisOn >= 1 && !thesisIntact;

                // ── WYCKOFF EVENT EXIT (NEW) ────────────────────────
                // If a strongly-stacked OPPOSITE-direction level vote
                // appeared (BC, UTAD, SFP, climax), exit immediately —
                // this is the Wyckoff reversal moment. Don't wait for
                // the slower thesis check; the helpers saw the top/
                // bottom forming on this bar.
                //
                // Fires regardless of P&L position because the reversal
                // signal is itself the exit thesis. If we entered at a
                // bad spot and now see a top, getting out beats holding
                // through the drop.
                let wyckoffEventExit = false;
                let wyckoffEventReason = '';
                if(this.levelVotes && this.levelVotes.size > 0){
                    const oppDir = -pos;
                    for(const [k, v] of this.levelVotes){
                        if(v.dir !== oppDir) continue;
                        if(v.strength < 9) continue;
                        if(v.evidence.length < 2) continue;
                        // Must be near current price (within 2 ATR)
                        if(Math.abs(v.price - c) > atr * 2) continue;
                        wyckoffEventExit = true;
                        wyckoffEventReason = 'WYCKOFF:'+v.evidence.slice(0,3).join(',');
                        break;
                    }
                }

                // Apply strength-adjusted give-back exit
                if(_R > 0 && this.peakUnrealizedPnl > _R * 0.5){
                    const _giveBackThreshold =
                        this.peakUnrealizedPnl * (1 - effectiveGiveBackPct/100);
                    if(_unrealized < _giveBackThreshold && _unrealized > 0){
                        peakGiveBackExit = true;
                    }
                }

                // Strength-adjusted trail width (after TP1 hit)
                if(this.tp1Hit){
                    let trailDist = atr * 1.5;
                    if(strengthOn >= 1){
                        if(strengthScore >= 7)      trailDist = atr * 2.2;  // looser
                        else if(strengthScore <= 3) trailDist = atr * 0.9;  // tighter
                    }
                    // Bubble-aware: a fresh bubble in trade direction means
                    // the move still has aggressive participation — give it
                    // more room to run. Bubble against = tighten and lock in.
                    // Threshold = max(absFloor, avgBubble * 1.8) — auto-
                    // scales per chart so NY (4096t) and EVE (3072t) both
                    // get a meaningful "strong bubble" definition.
                    const _bubX = this._recentBubbleAtZone(c, atr, 3, 2.0, bi);
                    if(_bubX){
                        const _bubXDir = _bubX.delta > 0 ? 1 : -1;
                        const _holdMult  = (p.bubbleHoldMult!=null?p.bubbleHoldMult:1.8);
                        const _holdFloor = (p.bubbleHoldFloor!=null?p.bubbleHoldFloor:250);
                        const _strongHold = Math.max(_holdFloor, this.bubbleAvgAbs * _holdMult);
                        if(_bubXDir === pos && Math.abs(_bubX.delta) > _strongHold){
                            trailDist *= 1.5;  // hold the winner — flow agrees
                        } else if(_bubXDir !== pos && Math.abs(_bubX.delta) > _strongHold){
                            trailDist *= 0.6;  // flow flipped — tighten now
                        }
                    }
                    if(pos===1)  this.trailSL = Math.max(this.trailSL, c-trailDist);
                    if(pos===-1) this.trailSL = Math.min(this.trailSL, c+trailDist);
                }

                if(!this.tp1Hit){
                    if(pos===1  && c>=this.tp1){ this.tp1Hit=true; this.trailSL=c-atr*1.5; }
                    if(pos===-1 && c<=this.tp1){ this.tp1Hit=true; this.trailSL=c+atr*1.5; }
                }

                // ── TP-VS-SL PROXIMITY + STALL DETECTION ─────────────
                // Before TP1 hits, assess whether TP is more reachable than
                // SL. If price has drifted closer to SL without momentum,
                // tighten the SL adaptively. If trade has stalled 25+ bars
                // with weak unrealized, exit at market — the move isn't
                // coming, free the slot for a fresh setup.
                let stallExit = false;
                if(!this.tp1Hit && this.entryRisk > 0){
                    const _unr = pos===1 ? c-this.ep : this.ep-c;
                    const _distToTP = pos===1 ? (this.tp1 - c) : (c - this.tp1);
                    const _distToSL = pos===1 ? (c - this.sl) : (this.sl - c);
                    const _proximityToSL = _distToSL / Math.max(_distToSL + _distToTP, 0.01);
                    // Stall: 25+ bars in, unrealized < 0.4R, momentum dying
                    if(this.barsHeld >= 25 && Math.abs(_unr) < this.entryRisk * 0.4){
                        // Check momentum dying: last 5 bars net move < 0.5 ATR
                        if(n >= 6){
                            const _recent = c - this.C[n - 6];
                            if(Math.abs(_recent) < atr * 0.5){
                                stallExit = true;
                            }
                        }
                    }
                    // Closer to SL than TP + against-direction momentum =
                    // tighten SL to lock in any remaining value
                    if(_proximityToSL < 0.35 && _unr < 0){
                        // We've drifted way toward SL — pull SL halfway
                        // closer to entry to cap loss
                        const _newSL = pos===1
                            ? this.sl + (this.ep - this.sl) * 0.3
                            : this.sl - (this.sl - this.ep) * 0.3;
                        if(pos===1)  this.sl = Math.max(this.sl, _newSL);
                        if(pos===-1) this.sl = Math.min(this.sl, _newSL);
                    }
                }

                // Stops/targets are resting orders → trigger on the bar's
                // EXTREME (intrabar), not the close. A wick through the stop
                // is a fill even if the bar closes back the other side.
                const hitTP2    = pos===1  ? h>=this.tp2  : l<=this.tp2;
                const hitSL     = pos===1  ? l<=this.sl   : h>=this.sl;
                const hitTrail  = this.tp1Hit && (pos===1 ? l<=this.trailSL : h>=this.trailSL);
                const maxHit    = this.barsHeld >= MAX_HOLD;
                // EOD risk close — force exit at session end regardless of
                // P&L. Better to take whatever you have than hold through
                // the boundary into low liquidity / settlement gap.
                const eodExit   = sessionEndExit;

                if(hitTP2||hitSL||hitTrail||maxHit||eodExit||peakGiveBackExit||thesisBrokenExit||wyckoffEventExit||stallExit){
                    exitNow=true;
                    exitDir=pos;
                    // Book P&L at the price that ACTUALLY fired, not the close.
                    // Straddle priority: stop/trail before target (assume the
                    // adverse level filled first — conservative without tick data).
                    let fillPx;
                    if(hitSL)         fillPx = this.sl;
                    else if(hitTrail) fillPx = this.trailSL;
                    else if(hitTP2)   fillPx = this.tp2;
                    else              fillPx = c;   // maxHold/EOD/give-back/stall/thesis = market @ close
                    exitPnl = pos===1 ? fillPx - this.ep : this.ep - fillPx;

                    const win = exitPnl > 0;   // breakeven (scratch) is NOT a win
                    this.results.push({win, pnl:exitPnl});
                    if(this.results.length>5) this.results.shift();
                    this.sessPnl  += exitPnl * this.qty;   // qty-weighted → sessPnl*cv = real account $
                    this.totalPnl += exitPnl * this.qty;
                    if(win) this.totalW++; else this.totalL++;

                    const baseBhv = (this.sigBehavior||'').split('@')[0];
                    // Per-(state, level-type) stats — bucket the outcome by
                    // market state at entry AND the level type that triggered
                    // it (MTT_H, SWICK_INV, etc). The dynamic gate looks up
                    // these stats at decision time to refuse setups that have
                    // historically lost in the current state.
                    const _eState = this.entryState || 'NEUTRAL';
                    const _eLevel = this.sigLevel || '';
                    if(_eLevel){
                        if(!this.stateStats[_eState]) this.stateStats[_eState] = {};
                        if(!this.stateStats[_eState][_eLevel]){
                            this.stateStats[_eState][_eLevel] = {w:0, l:0, pnl:0};
                        }
                        const _ss = this.stateStats[_eState][_eLevel];
                        if(win) _ss.w++; else _ss.l++;
                        _ss.pnl += exitPnl;
                    }
                    if(this.behaviorStats[baseBhv]){
                        const s = this.behaviorStats[baseBhv];
                        if(win) s.w++; else s.l++;
                        s.pnl += exitPnl;
                    }
                    if(this.attrStats[this.entrySource]){
                        const a = this.attrStats[this.entrySource];
                        if(win) a.w++; else a.l++;
                        a.pnl += exitPnl;
                    }

                    const losses = this.results.filter(r=>!r.win).length;
                    // 2 losses in last 5 trades = pause. Was 3, but today's
                    // session lost 4 in a row before pause kicked. When the
                    // system is wrong about regime, give it a forced timeout
                    // earlier so it can re-evaluate.
                    if(losses>=2) this.pauseUntilBar = bi + PAUSE_BARS;
                    // Track the failing setup so we don't re-fire the same
                    // direction at the same level type immediately after.
                    if(!win){
                        this.lastLossBar = bi;
                        this.lastLossDir = pos;
                        this.lastLossLevel = this.sigLevel || '';
                    }

                    if(this.renderMap[this.entryBar]){
                        this.renderMap[this.entryBar].exitPnl = exitPnl;
                        this.renderMap[this.entryBar].exitBar = bi;
                    }
                    // ── JOURNAL: write EXIT outcome onto the matching
                    // FIRED entry. We find it by entryBar, fill in the
                    // outcome fields. Also write a discrete EXIT event
                    // for the report's chronological view.
                    for(let ji=this.journal.length-1; ji>=0 && ji>=this.journal.length-30; ji--){
                        const jEntry = this.journal[ji];
                        if(jEntry.type==='FIRED' && jEntry.bar===this.entryBar){
                            jEntry.exitPrice = Math.round(c*100)/100;
                            jEntry.exitBar = bi;
                            jEntry.exitPnl = Math.round(exitPnl*100)/100;
                            jEntry.exitWin = win;
                            jEntry.exitReason = hitTP2 ? 'TP2' :
                                                hitSL ? 'SL' :
                                                hitTrail ? 'TRAIL' :
                                                stallExit ? 'STALL' :
                                                wyckoffEventExit ? wyckoffEventReason :
                                                thesisBrokenExit ? 'THESIS-BROKEN' :
                                                peakGiveBackExit ? 'GIVE-BACK' :
                                                eodExit ? 'EOD' :
                                                maxHit ? 'MAX-HOLD' : 'EXIT';
                            break;
                        }
                    }
                    this._logJournal(bi, this.sessKey, hhmmStr, 'EXIT', {
                        win: win,
                        pnl: Math.round(exitPnl*100)/100,
                        reason: hitTP2?'TP2':hitSL?'SL':hitTrail?'TRAIL':stallExit?'STALL':wyckoffEventExit?wyckoffEventReason:thesisBrokenExit?'THESIS-BROKEN':peakGiveBackExit?'GIVE-BACK':eodExit?'EOD':'MAX-HOLD',
                        entryBar: this.entryBar,
                        ep: Math.round(this.ep*100)/100,
                        ex: Math.round(c*100)/100,
                        strength: this.lastStrengthScore,
                        votesAgainst: this.lastThesisAgainst
                    });
                    // ── FORWARD-TEST TRADE LOG (pairs with the honest-fill patch) ──
                    // One durable, machine-readable line per closed trade. Copy
                    // 'SDTRADE,' lines from the browser console into a file, then:
                    //   node tests/forward_report.js <file>
                    if((this.props||{}).forwardLog){
                        var _fx = (typeof fillPx !== 'undefined') ? fillPx : c;
                        var _Rr = Math.abs(this.ep - this.sl) || 0;
                        console.log('SDTRADE,'+ts.toISOString()+','+this.sessKey+','
                            +(this.sigLevel||'')+','+(this.entrySource||'')+','
                            +(this.entryState||'')+','+(pos===1?'LONG':'SHORT')+','
                            +this.ep.toFixed(2)+','+this.sl.toFixed(2)+','+this.tp2.toFixed(2)+','
                            +_fx.toFixed(2)+','
                            +(hitTP2?'TP2':hitSL?'SL':hitTrail?'TRAIL':stallExit?'STALL':eodExit?'EOD':maxHit?'MAX-HOLD':'EXIT')+','
                            +exitPnl.toFixed(2)+','+_Rr.toFixed(2)+','+this.barsHeld+','
                            +(this.lastStrengthScore!=null?this.lastStrengthScore:'')+','
                            +(this.qty||1)+','
                            +((this.entryTs&&this.entryTs.toISOString)?this.entryTs.toISOString():''));
                    }
                    if(win) this.sessionWins++; else this.sessionLosses++;
                    this.position=0; this.tp1Hit=false;
                }
            }

            if(isNewBar) this.barsSinceSig++;

            // ─────────────────────────────────────────────────────────
            // BEHAVIOR DETECTION
            // ─────────────────────────────────────────────────────────

            if(n>1 && isNewBar){
                const up = c > this.C[n-2];
                const dn = c < this.C[n-2];
                if((up&&this.exhDir===1)||(dn&&this.exhDir===-1)){
                    const _lastEx = this.exhBars[this.exhBars.length-1];
                    if(!_lastEx || _lastEx.bar !== bi){
                        this.exhBars.push({range:h-l, vol, delta, bar:bi});
                    } else {
                        _lastEx.range = h-l;
                        _lastEx.vol = vol;
                        _lastEx.delta = delta;
                    }
                } else {
                    this.exhDir  = up?1:dn?-1:this.exhDir;
                    this.exhBars = [{range:h-l, vol, delta, bar:bi}];
                }
                if(this.exhBars.length>12) this.exhBars.shift();
            }

            if(n>0){
                const range   = h-l;
                const tinyBar = range < atr*0.65;
                const highVol = vol > avgVol*1.3;
                const dFight  = (delta<0&&c>=o) || (delta>0&&c<=o);
                if(tinyBar && highVol && dFight) this.absCount++;
                else this.absCount = Math.max(0, this.absCount-1);
            }
            const isAbsorption = this.absCount >= 3;
            const isAbsorptionHL = this.absCount >= 2 && (this.higherLow||this.lowerHigh);

            // ── ABSORPTION-AT-LEVEL SEQUENCE TRACKER ─────────────────
            // Detects: multiple consecutive bars hitting the SAME level
            // (low or high) and getting rejected. This is the "U-shape"
            // pattern user marked as #1 — sellers hitting bottom 4-5 times,
            // each time with smaller wicks/lower volume, finally exhausting.
            //
            // Maintains:
            //   absSeqDir: 1 = buyers absorbing sells (forming a base)
            //              -1 = sellers absorbing buys (forming a top)
            //   absSeqLevel: the price being repeatedly tested
            //   absSeqBars: how many consecutive bars at that level
            //   absSeqStartBar: when the sequence started
            //
            // Triggers a strong orderflow signal when bars >= 3.
            // ── ABSORPTION-AT-LEVEL SEQUENCE TRACKER ─────────────────
            // The CORE pattern: multiple bars hitting the same low (or high)
            // and FAILING to break it. That's absorption — defined by what
            // price is NOT doing, not by delta/wick magnitude.
            //
            // Real-world example (the J-hook bottom):
            //   Bar 1: low 27555
            //   Bar 2: low 27557  (didn't go lower)
            //   Bar 3: low 27558  (didn't go lower)
            //   Bar 4: low 27554  (slightly tested, held)
            //   Bar 5: low 27562  (lifting)
            // → 5 bars at same level, base formed
            //
            // We don't require strong delta or huge wicks. The PRICE
            // NOT BREAKING is the absorption. Delta/wick add confidence
            // but aren't required to detect the pattern.
            if(n >= 2 && isNewBar){
                const _absTol = atr * 0.4;
                const _bodyAbs = Math.abs(c - o);
                const _upWickAbs = h - Math.max(o, c);
                const _dnWickAbs = Math.min(o, c) - l;
                // Detect absorption by looking at LOW CLUSTERING across
                // recent bars. If the last 3-6 bars all have lows within
                // 0.4 ATR of each other, that's absorption at the floor.
                // Same for highs at the ceiling.
                //
                // Key insight: don't compare to "lowest of last 6" because
                // a fresh leg DOWN would break that comparison even though
                // bars 2-6 of the new leg are clustered absorbing at the
                // new low. Compare bars to EACH OTHER.
                //
                // Algorithm: Look at lows of last K bars (K=3,4,5,6).
                // For each K, check if max(lows) - min(lows) <= absTol.
                // The largest K that satisfies this is the absorption count.
                let lowCluster = 0;
                let highCluster = 0;
                let lowAvg = l, highAvg = h;
                for(let K = 2; K <= Math.min(7, n+1); K++){
                    // last K bars including current
                    let minL = l, maxL = l, minH = h, maxH = h, sumL = 0, sumH = 0;
                    let cnt = 0;
                    for(let i = Math.max(0, n+1-K); i <= n; i++){
                        const bL = i < n ? this.L[i] : l;
                        const bH = i < n ? this.H[i] : h;
                        if(bL < minL) minL = bL;
                        if(bL > maxL) maxL = bL;
                        if(bH < minH) minH = bH;
                        if(bH > maxH) maxH = bH;
                        sumL += bL; sumH += bH; cnt++;
                    }
                    if(maxL - minL <= _absTol){
                        // Lows of last K bars all within absTol → cluster
                        lowCluster = K;
                        lowAvg = sumL / cnt;
                    }
                    if(maxH - minH <= _absTol){
                        highCluster = K;
                        highAvg = sumH / cnt;
                    }
                }
                // We need to decide: is this primarily a low-cluster (base
                // forming) or high-cluster (ceiling forming)?
                // If both, prefer the LARGER cluster.
                let testingLow = false, testingHigh = false;
                if(lowCluster >= 3 && lowCluster >= highCluster){
                    testingLow = true;
                } else if(highCluster >= 3 && highCluster > lowCluster){
                    testingHigh = true;
                }

                if(testingLow && !testingHigh){
                    // the cluster size — that's how many bars are clustered.
                    this.absSeqDir = 1;
                    this.absSeqLevel = lowAvg;
                    this.absSeqBars = lowCluster;
                    if(lowCluster <= 3) this.absSeqStartBar = bi - lowCluster + 1;
                } else if(testingHigh && !testingLow){
                    this.absSeqDir = -1;
                    this.absSeqLevel = highAvg;
                    this.absSeqBars = highCluster;
                    if(highCluster <= 3) this.absSeqStartBar = bi - highCluster + 1;
                } else {
                    // Decay if we've moved away
                    if(this.absSeqBars > 0 && bi - this.absSeqStartBar > 8){
                        // Before zeroing out, if this was a confirmed base
                        // (3+ bars of absorption), SAVE it as a confirmedBase
                        // so we can detect the retest later (the J-hook).
                        if(this.absSeqBars >= 3 && this.absSeqDir !== 0){
                            this.confirmedBases.push({
                                dir: this.absSeqDir,
                                level: this.absSeqLevel,
                                bars: this.absSeqBars,
                                formedAt: this.absSeqStartBar,
                                retested: false,
                                retestBar: 0
                            });
                            if(this.confirmedBases.length > 8){
                                this.confirmedBases.shift();
                            }
                        }
                        this.absSeqDir = 0;
                        this.absSeqBars = 0;
                        this.absSeqLevel = 0;
                    }
                }
                // Hard invalidation: price decisively breaks the level
                if(this.absSeqDir === 1 && c < this.absSeqLevel - atr * 0.5){
                    this.absSeqDir = 0; this.absSeqBars = 0;
                }
                if(this.absSeqDir === -1 && c > this.absSeqLevel + atr * 0.5){
                    this.absSeqDir = 0; this.absSeqBars = 0;
                }
            }

            // ── J-HOOK RETEST DETECTOR ────────────────────────────────
            // The J-hook is a TWO-PART pattern:
            //   1. Base forms (already tracked as confirmedBases)
            //   2. Price comes back to retest the base and HOLDS
            //
            // This detector handles part 2: every bar, check if current
            // price is near any confirmed base/ceiling, and if so whether
            // it's holding (not breaking the level).
            //
            // jhookActive=true with jhookDir means: current bar is sitting
            // on a previously-confirmed base/ceiling and holding. This is
            // the entry trigger.
            this.jhookActive = false;
            this.jhookDir = 0;
            this.jhookLevel = 0;
            this.jhookSourceBase = null;
            if(this.confirmedBases.length > 0){
                for(let bi_b = this.confirmedBases.length - 1; bi_b >= 0; bi_b--){
                    const base = this.confirmedBases[bi_b];
                    // Skip very old bases (>50 bars since formation)
                    if(bi - base.formedAt > 60){
                        this.confirmedBases.splice(bi_b, 1);
                        continue;
                    }
                    // Has price decisively broken this base? Remove it.
                    if(base.dir === 1 && c < base.level - atr * 0.6){
                        this.confirmedBases.splice(bi_b, 1);
                        continue;
                    }
                    if(base.dir === -1 && c > base.level + atr * 0.6){
                        this.confirmedBases.splice(bi_b, 1);
                        continue;
                    }
                    // Is current bar AT this base?
                    // For bullish base: low within 0.5 ATR of base level AND
                    //   low is not breaking by more than 0.2 ATR (held)
                    if(base.dir === 1){
                        const distFromBase = Math.abs(l - base.level);
                        const holding = (l - base.level) >= -atr * 0.2;
                        if(distFromBase <= atr * 0.5 && holding){
                            this.jhookActive = true;
                            this.jhookDir = 1;
                            this.jhookLevel = base.level;
                            this.jhookSourceBase = base;
                            if(!base.retested){
                                base.retested = true;
                                base.retestBar = bi;
                            }
                            break;
                        }
                    }
                    // For bearish ceiling: high within 0.5 ATR AND not breaking
                    if(base.dir === -1){
                        const distFromBase = Math.abs(h - base.level);
                        const holding = (base.level - h) >= -atr * 0.2;
                        if(distFromBase <= atr * 0.5 && holding){
                            this.jhookActive = true;
                            this.jhookDir = -1;
                            this.jhookLevel = base.level;
                            this.jhookSourceBase = base;
                            if(!base.retested){
                                base.retested = true;
                                base.retestBar = bi;
                            }
                            break;
                        }
                    }
                }
            }

            // ── DEMAND/SUPPLY STEPPING IN (the J-hook trigger) ────────
            // After absorption forms a base (or ceiling), the entry signal
            // is when CONTINUATION bars start firing:
            //   • At a base (absSeqDir=1): 2+ green bars getting LARGER,
            //     volume picking up, delta turning positive
            //   • At a ceiling (absSeqDir=-1): 2+ red bars getting larger,
            //     volume up, delta negative
            //
            // This is what user described: "small green candles getting
            // larger, delta increasing, volume increasing." It's the
            // J-hook recovery (the hook handle starting to form).
            //
            // Replaces the old "first pullback after impulse" which was
            // too restrictive — required a sharp 1.5 ATR move which doesn't
            // happen on slower absorption-then-grind setups.
            this.steppingIn = false;
            this.steppingInDir = 0;
            if(n >= 3 && this.absSeqDir !== 0 && this.absSeqBars >= 2){
                // Look at the last 3 bars including current
                const b1 = { c:this.C[n-3], o:this.O[n-3], h:this.H[n-3], l:this.L[n-3],
                             v:this.V[n-3], d:this.D[n-3] };
                const b2 = { c:this.C[n-2], o:this.O[n-2], h:this.H[n-2], l:this.L[n-2],
                             v:this.V[n-2], d:this.D[n-2] };
                const b3 = { c:c, o:o, h:h, l:l, v:vol, d:delta };
                // Bar direction (1=green, -1=red, 0=doji)
                const dir1 = b1.c > b1.o ? 1 : b1.c < b1.o ? -1 : 0;
                const dir2 = b2.c > b2.o ? 1 : b2.c < b2.o ? -1 : 0;
                const dir3 = b3.c > b3.o ? 1 : b3.c < b3.o ? -1 : 0;
                // Bar bodies (size of move within the bar)
                const body1 = Math.abs(b1.c - b1.o);
                const body2 = Math.abs(b2.c - b2.o);
                const body3 = Math.abs(b3.c - b3.o);

                // Bullish step-in: at a base, 2+ recent bars green & expanding
                if(this.absSeqDir === 1){
                    // Need at least last 2 bars green
                    const recentGreen = (dir2 === 1 && dir3 === 1) ||
                                        (dir1 === 1 && dir2 === 1) ||
                                        (dir1 === 1 && dir3 === 1);
                    // Bodies expanding (bigger green candles forming)
                    const expanding = body3 > body2 * 1.1 || body2 > body1 * 1.1;
                    // Volume picking up (any of the recent bars high vol)
                    const volPickup = b3.v > avgVol * 1.0 || b2.v > avgVol * 1.0;
                    // Delta turning positive on at least one recent bar
                    const deltaUp = b3.d > 0 || b2.d > 0;
                    if(recentGreen && (expanding || volPickup) && deltaUp){
                        this.steppingIn = true;
                        this.steppingInDir = 1;
                    }
                }
                // Bearish step-in: at a ceiling, 2+ recent bars red & expanding
                if(this.absSeqDir === -1){
                    const recentRed = (dir2 === -1 && dir3 === -1) ||
                                      (dir1 === -1 && dir2 === -1) ||
                                      (dir1 === -1 && dir3 === -1);
                    const expanding = body3 > body2 * 1.1 || body2 > body1 * 1.1;
                    const volPickup = b3.v > avgVol * 1.0 || b2.v > avgVol * 1.0;
                    const deltaDn = b3.d < 0 || b2.d < 0;
                    if(recentRed && (expanding || volPickup) && deltaDn){
                        this.steppingIn = true;
                        this.steppingInDir = -1;
                    }
                }
            }

            // NOTE: legacy sweep detection (sweepPending) was removed —
            // the new BOS+SWEEP detector above handles this correctly with
            // proper direction logic. The old version had inverted direction
            // (would set sweepDir=1 on an upside sweep, which is wrong).
            let isSweepEntry = false, sweepEntryDir = 0;

            // NY lunch-hour blackout — historically the indicator skipped
            // 12:00 PM - 1:59 PM and the 3:30 PM final half-hour because
            // those are typically low-volume / news-distorted in NY.
            // Now controlled by `nyLunchBlackout` param (default OFF) so
            // it doesn't silently kill trades. Flip on if you want it.
            const lunchBlackoutOn = (p.nyLunchBlackout!=null?p.nyLunchBlackout:0) >= 1;
            const inNYBlackout = lunchBlackoutOn && sessSuffix==='_ny' &&
                (bLth===12 || bLth===13 || (bLth===15 && bLtm>=30));
            const timeOK = sessSuffix !== '_overnight' && !inNYBlackout;

            // ─────────────────────────────────────────────────────────
            // SIGNAL GENERATION
            // ─────────────────────────────────────────────────────────
            // ── DAY-QUALITY composite (0-10) ─────────────────────────
            // Aggregates the regime signals the indicator is reading
            // into a single number. Used as a master gate: when the
            // day looks structurally hostile to mean-reversion (low
            // quality), refuse all setups regardless of setup score.
            // Also surfaced in HUD so the user can see WHY trades are
            // being held back.
            let dayQuality = 5;            // neutral
            const _dqReasons = [];
            // IB unbroken + held → +2 (balance day character)
            if(this.ibLocked && this.ibBroken === 0){
                dayQuality += 2; _dqReasons.push('IB-HELD');
            }
            // IB broken → -3 (trend day character, mean-reversion fragile)
            if(this.ibBroken !== 0){
                dayQuality -= 3; _dqReasons.push('IB-BROKEN');
            }
            // Strong directional day move (>5 ATR) → -2
            if(this.sessOpen > 0){
                const _dMv  = Math.abs(c - this.sessOpen);
                if(_dMv > atr * 5){
                    dayQuality -= 2; _dqReasons.push('DAY-DIRECTIONAL');
                }
            }
            // PIDR in extreme zone (<15% or >85%) → -1
            if(this.sessOpen > 0){
                const _pidr = (c - this.sessLow) /
                    Math.max(this.sessHigh - this.sessLow, 0.01);
                if(_pidr < 0.15 || _pidr > 0.85){
                    dayQuality -= 1; _dqReasons.push('PIDR-EXTREME');
                }
            }
            // H1 trending → -1 (mean-reversion fights HTF)
            if(this.h1Trend === 'BULL' || this.h1Trend === 'BEAR'){
                dayQuality -= 1; _dqReasons.push('H1-TRENDING');
            }
            // Recent loss streak → -2 (something is structurally off)
            if(this.results && this.results.length >= 2){
                const _recentL = this.results.slice(-2).filter(r=>!r.win).length;
                if(_recentL >= 2){ dayQuality -= 2; _dqReasons.push('LOSS-STREAK'); }
            }
            // Low recent momentum (last 20 bars net move < 1.5 ATR) → +1
            // This keeps balance/chop days firmly above the master block
            // threshold so genuine fade setups can fire.
            if(n >= 21){
                const _refC = this.C[n - 21];
                if(_refC != null && Math.abs(c - _refC) < atr * 1.5){
                    dayQuality += 1; _dqReasons.push('LOW-MOMENTUM');
                }
            }
            // Floor + ceiling
            dayQuality = Math.max(0, Math.min(10, dayQuality));
            this.dayQuality = dayQuality;
            this.dayQualityReasons = _dqReasons;

            // ── HARD-STOP: half-loss kill switch ─────────────────────
            // If session P&L drops below half of maxDailyLoss, refuse
            // any further trades. Better to take a small loss day than
            // give the system rope to hang itself with revenge trades.
            const _halfLossHit = this.sessPnl * cv <= -(maxLoss * 0.5)
                                  && this.dailyTrades > 0;

            // ── COIL BREAKOUT detection (new entry signal class) ──
            // Measured edge: 4:1 favorable/adverse over 20 bars across
            // 3.5 years of QQQ data. Direction = breakout bar's direction.
            // Fires as its own signal class — bypasses the NO-LEVEL guard
            // (the coil IS the level) but still respects regime/quality
            // filters downstream.
            let coilFire = 0;
            if(isNewBar && (bi - this.lastCoilBreakBar) > 10){
                const _coil = this._detectCoil(bi, atr, 6);
                if(_coil){
                    coilFire = this._coilBreakDir(_coil, c, o, h, l, atr);
                    if(coilFire !== 0) this.lastCoilBreakBar = bi;
                }
            }

            let blockReason = '';
            // ── BLOCK PRECEDENCE (most punitive wins) ───────────────────
            // Structural first, then HARD account-survival + PACING blocks,
            // THEN the overridable MAX-TRADES, then setup-quality. HARD/PACING
            // MUST sit above MAX-TRADES: the flip-override (below) may only
            // relax MAX-TRADES, and it is reached only when canTrade is true.
            // If MAX-TRADES could mask MAX-LOSS/HARD-STOP/LOSS-PAUSE, the
            // override would silently bypass the daily loss cap.
            if(!timeOK)                                blockReason='TIME';
            else if(this.position!==0)                 blockReason='IN-POS';
            else if(sessionEndBlock)                   blockReason='EOD-BLOCK';
            else if(n < WARM_BARS)                     blockReason='WARM-UP';
            else if(this.sessPnl*cv<=-maxLoss)         blockReason='MAX-LOSS';
            else if(_halfLossHit)                      blockReason='HARD-STOP';
            else if(bi<=this.pauseUntilBar)            blockReason='LOSS-PAUSE';
            else if(this.barsSinceSig<=5)              blockReason='COOLDOWN';
            else if(this.dailyTrades>=maxTrades)       blockReason='MAX-TRADES';
            else if(dayQuality < 4)                    blockReason='DAY-QUALITY';
            else if(!(atLevel||isSweepEntry||coilFire!==0)) blockReason='NO-LEVEL';
            this.blockReason = blockReason;
            // Allow decision eval to proceed when the only block is MAX-TRADES
            // and the regime-flip override hasn't been used yet — the actual
            // override decision (opposite dir + score≥7) is applied after the
            // decision is computed and the proposed direction is known.
            const onlyMaxTrades = (blockReason === 'MAX-TRADES') && !this.maxTradesOverrideUsed;
            const canTrade = blockReason === '' || onlyMaxTrades;

            // ── DIAGNOSTICS: log this bar's signal-attempt outcome ──
            // Every bar where we actively considered a trade (i.e., not
            // blocked by structural reasons like TIME or IN-POS) gets
            // logged. This builds the "why didn't I take that?" trail.
            const structuralBlock = blockReason==='TIME' || blockReason==='IN-POS' ||
                                    blockReason==='EOD-BLOCK' || blockReason==='WARM-UP' ||
                                    blockReason==='HARD-STOP' ||
                                    blockReason==='MAX-TRADES' || blockReason==='LOSS-PAUSE' ||
                                    blockReason==='COOLDOWN' || blockReason==='MAX-LOSS';
            if(!structuralBlock){
                // Logical block (NO-LEVEL or canTrade=true) — interesting for diagnostics
                const _lastSa = this.signalAttempts[this.signalAttempts.length-1];
                if(!_lastSa || _lastSa.bar !== bi){
                    this.signalAttempts.push({
                        bar:bi, price:c,
                        blockReason: blockReason || 'OK',
                        nearLevel: nearLevel ? nearLevel.type : '',
                        nearDist: nearLevel ? Math.round(nearDist*100)/100 : -1,
                        mktState: this.mktState,
                        pbClass: this.pbClass
                    });
                    if(this.signalAttempts.length > 300) this.signalAttempts.shift();
                } else {
                    // Update existing entry for this bar
                    _lastSa.price = c;
                    _lastSa.blockReason = blockReason || 'OK';
                    _lastSa.nearLevel = nearLevel ? nearLevel.type : '';
                    _lastSa.nearDist = nearLevel ? Math.round(nearDist*100)/100 : -1;
                    _lastSa.mktState = this.mktState;
                    _lastSa.pbClass = this.pbClass;
                }
            }

            // ── JOURNAL: log notable BLOCKED events ──
            // Only when:
            //   • Price is at/near a level (nearDist <= 1.5 ATR)
            //   • The block reason just changed (not flooding identical reasons)
            // This catches "we were AT a level but couldn't trade because X"
            // — the most useful blocks for understanding why setups missed.
            const _atLvlForJrn = nearLevel && nearDist <= atr*1.5;
            if(blockReason && _atLvlForJrn){
                const lastJEntry = this.journal.length>0 ? this.journal[this.journal.length-1] : null;
                const recentSimilar = lastJEntry && lastJEntry.type==='BLOCKED' &&
                                       lastJEntry.reason===blockReason &&
                                       lastJEntry.level===nearLevel.type &&
                                       (bi - lastJEntry.bar < 20);
                if(!recentSimilar){
                    this._logJournal(bi, this.sessKey, hhmmStr, 'BLOCKED', {
                        reason: blockReason,
                        level: nearLevel.type,
                        levelPrice: Math.round(nearLevel.price*100)/100,
                        price: Math.round(c*100)/100,
                        dist: Math.round(nearDist*100)/100,
                        mktState: this.mktState,
                        pbClass: this.pbClass
                    });
                    this.blockedCount++;
                }
            }

            // ── DIAGNOSTICS: run periodic health check + auto-tune ──
            // Health check every 20 bars. If verdict OK and calibration
            // is off, the conservative auto-tuner gets a chance to act
            // (gated by its own cooldowns and bounds).
            // Also run the probation revert check on every health cycle.
            if(bi % 20 === 0 && bi > 50){
                const calib = this._runHealthCheck(bi, atr, avgVol);
                this._checkRevert(bi);
                // Auto-tuner only allowed by user param `autoTune` (default OFF)
                const autoTuneOn = (p.autoTune!=null?p.autoTune:0) >= 1;
                if(autoTuneOn){
                    this._autoTune(bi, calib);
                }
            }

            let newLong=false, newShort=false;

            // (Helpers already ran earlier, before position management,
            // so exit logic could see Wyckoff events.)

            // Entry decisions only happen on bar close (new bar arriving means
            // the previous bar just closed). This prevents trades from firing
            // on intra-bar tick updates and then potentially "vanishing" on
            // subsequent ticks if conditions evolve. Bar-close-only entry is
            // also best-practice for systematic trading — wait for confirmation.
            //
            // Live mode protection: in live trading, isNewBar fires on the
            // FIRST tick of a new bar — at which point the bar is essentially
            // c≈o with no range yet. Decisions made on this empty bar are
            // unreliable. We skip entry analysis if the bar has not formed
            // enough range (< 0.2 ATR), waiting for the bar to develop.
            const barRange = h - l;
            const barFormed = barRange >= atr * 0.2 || atr <= 0;
            if(canTrade && isNewBar && barFormed){
                // ════════════════════════════════════════════════════
                // NEW THREE-FRAMEWORK ENTRY ENGINE
                // ════════════════════════════════════════════════════
                // No more 6 hardcoded behaviors with 30+ AND-gates.
                // Read the market through 3 lenses, score each, fire when
                // 2-of-3 align at strong level OR 3-of-3 align anywhere.
                // ════════════════════════════════════════════════════
                // (Helpers already ran earlier in this map() iteration)
                const auctionR  = this._readAuction(c, h, l, atr, levels, nearLevel, nearDist);
                const structR   = this._readStructure(c, h, l, atr);
                const flowR     = this._readOrderflow(c, h, l, o, vol, delta, atr, avgVol, n);
                const decision  = this._combineReadings(auctionR, structR, flowR, nearLevel, atLevel);
                // COIL injection: if a coil breakout fired this bar and the
                // frameworks haven't already produced a fire signal, inject
                // the coil as the decision. Direction = the breakout bar's
                // direction. Score 7 puts it firmly in fireable territory
                // but still requires downstream filters (regime, momentum,
                // bubble-contra) to pass — so a coil on a hostile day still
                // gets blocked appropriately.
                if(coilFire !== 0 && !decision.fire){
                    decision.fire = true;
                    decision.dir = coilFire;
                    decision.totalScore = 7;
                    decision.setupTag = 'COIL@BREAK_' + (coilFire === 1 ? 'UP' : 'DN');
                }
                // Diagnostic — capture the readings on this bar even if no fire
                if(this.signalAttempts.length > 0){
                    const sa = this.signalAttempts[this.signalAttempts.length-1];
                    if(sa.bar === bi){
                        sa.auctionDir   = auctionR.dir;
                        sa.auctionScore = auctionR.score;
                        sa.structDir    = structR.dir;
                        sa.structScore  = structR.score;
                        sa.flowDir      = flowR.dir;
                        sa.flowScore    = flowR.score;
                        sa.combinedDir  = decision.dir;
                        sa.combinedScore= decision.totalScore;
                        sa.combinedFire = decision.fire;
                        sa.dirClearedBy = decision.fire ? '' :
                            (auctionR.dir === 0 && structR.dir === 0 && flowR.dir === 0)
                                ? 'no framework signal'
                                : (decision.dir === 0)
                                    ? 'frameworks tied/zero'
                                    : decision.totalScore < 4
                                        ? 'avg score too low ('+decision.totalScore+')'
                                        : '2-of-3 not at strong level';
                        sa.behaviorTried = decision.setupTag || '';
                    }
                }
                if(decision.fire){
                    const dir = decision.dir;
                    // Repeat-failed-setup guard: same dir + same level type
                    // within REPEAT_LOSS_BARS of a loss = skip. Stops the
                    // "buy every dip into a level that just stopped me out"
                    // pattern when a level keeps rejecting in one direction.
                    const _lt2pre = coilFire !== 0
                        ? ('COIL_' + (coilFire === 1 ? 'UP' : 'DN'))
                        : (nearLevel ? nearLevel.type : '');
                    if(this.lastLossDir === dir &&
                       this.lastLossLevel && this.lastLossLevel === _lt2pre &&
                       (bi - this.lastLossBar) < REPEAT_LOSS_BARS){
                        decision.fire = false;
                        this.blockReason = 'REPEAT-LOSS';
                    }
                    // Chase filter: block entries at the wrong end of a fresh
                    // extended move. A SHORT near the bottom of a >6 ATR
                    // 15-bar range, or a LONG near the top, means the move
                    // already happened — you're paying premium for what's
                    // already paid out. Today's 11:15 SHORT @ 27738 fired
                    // after a 200pt drop and immediately reversed; this
                    // would have caught it.
                    if(decision.fire){
                        const _chaseLB = 15;
                        let _hi = h, _lo = l;
                        for(let i = 1; i <= _chaseLB && (n-1-i) >= 0; i++){
                            const _hi_i = this.H[n-1-i], _lo_i = this.L[n-1-i];
                            if(_hi_i > _hi) _hi = _hi_i;
                            if(_lo_i < _lo) _lo = _lo_i;
                        }
                        const _rng = _hi - _lo;
                        if(_rng > atr * 6){
                            const _posInRng = (c - _lo) / Math.max(_rng, 0.01);
                            if(dir === -1 && _posInRng < 0.30){
                                decision.fire = false;
                                this.blockReason = 'CHASE-DOWN';
                            } else if(dir === 1 && _posInRng > 0.70){
                                decision.fire = false;
                                this.blockReason = 'CHASE-UP';
                            }
                        }
                    }
                    // IB-COUNTER: once NY's initial balance is broken and
                    // held, treat it as a trend day in that direction.
                    // Counter-trend setups get blocked outright for the
                    // rest of the session — no waiting on mktState.
                    if(decision.fire && this.ibBroken !== 0 && dir === -this.ibBroken){
                        decision.fire = false;
                        this.blockReason = 'IB-COUNTER';
                    }
                    // H1-COUNTER: when the higher timeframe (H1) is clearly
                    // trending, counter-trend trades require a much higher
                    // score. AUCT/STR/FLOW only see ~20 1-min bars; this
                    // adds the macro view they're missing.
                    if(decision.fire && this.h1Trend && this.h1Trend !== 'FLAT'){
                        const _h1Dir = this.h1Trend === 'BULL' ? 1 : -1;
                        if(dir === -_h1Dir && (decision.totalScore || 0) < 7){
                            decision.fire = false;
                            this.blockReason = 'H1-COUNTER';
                        }
                    }
                    // BUBBLE-CONTRA: refuse entry when a strong OPPOSITE-
                    // direction delta bubble printed at this level in the
                    // last 5 bars. Means the wrong side is aggressively
                    // hitting it — your level isn't holding.
                    // Threshold = max(absoluteFloor, avgBubble * 1.5) — auto-
                    // scales to each chart's own bubble activity.
                    if(decision.fire){
                        const _bub = this._recentBubbleAtZone(c, atr, 5, 1.0, bi);
                        if(_bub){
                            const _bubDir = _bub.delta > 0 ? 1 : -1;
                            const _contraMult = (p.bubbleContraMult!=null?p.bubbleContraMult:1.5);
                            const _floor = (p.bubbleContraFloor!=null?p.bubbleContraFloor:200);
                            const _strongTh = Math.max(_floor, this.bubbleAvgAbs * _contraMult);
                            if(dir !== _bubDir && Math.abs(_bub.delta) > _strongTh){
                                decision.fire = false;
                                this.blockReason = 'BUBBLE-CONTRA';
                            }
                        }
                    }
                    // STATE-FAIL: dynamic gate from per-state historical stats.
                    // Refuses setups that have historically lost in the
                    // current regime. Two block conditions:
                    //   - <40% WR over ≥5 samples (clear coinflip-or-worse)
                    //   - Negative cumulative P&L over ≥10 samples
                    //     (wins are 50%+ but R:R is bad — backtest showed
                    //     RANGE×MTT_L was 47% WR but -14.5pt total)
                    // The PnL gate catches the trickier loser bucket the
                    // WR gate misses.
                    if(decision.fire && _lt2pre){
                        const _wr = this._stateSetupWR(this.marketState, _lt2pre);
                        // N2: gate only on NEGATIVE EXPECTANCY with an adequate
                        // sample (≥20, enforced in _stateSetupWR). The old
                        // win-rate<40% clause was dropped — it fought the
                        // strategy's own low-win-rate / high-R:R design.
                        if(_wr && _wr.pnl < 0){
                            decision.fire = false;
                            this.blockReason = 'STATE-FAIL';
                        }
                    }
                    // MOMENTUM filter: catches what COUNTER-DAY misses early.
                    // A 6+ ATR drop over 30 bars before the day's "directional"
                    // threshold trips would still let a counter-trend long
                    // slip through. This filter looks at the last 20 bars and
                    // requires BOTH magnitude (net move > 3.5 ATR) AND
                    // consistency (12+ of 20 bars closed in the move's
                    // direction). Then refuses any trade against that flow.
                    if(decision.fire && n >= 21){
                        const _refClose = this.C[n - 21];
                        const _netMv = c - _refClose;
                        let _aligned = 0;
                        for(let _i = 1; _i <= 20; _i++){
                            const _o_i = this.O[n - 1 - _i];
                            const _c_i = this.C[n - 1 - _i];
                            if(_o_i == null || _c_i == null) continue;
                            if(_netMv > 0 && _c_i > _o_i) _aligned++;
                            else if(_netMv < 0 && _c_i < _o_i) _aligned++;
                        }
                        const _strong = Math.abs(_netMv) > atr * 3.5;
                        const _consistent = _aligned >= 12;
                        if(_strong && _consistent){
                            const _momDir = _netMv > 0 ? 1 : -1;
                            if(dir === -_momDir){
                                decision.fire = false;
                                this.blockReason = _momDir === -1
                                    ? 'MOMENTUM-DOWN'
                                    : 'MOMENTUM-UP';
                            }
                        }
                    }
                    // Day-context filters: the 15-bar chase filter only sees
                    // recent action. A balance-then-dump day (today: 27945
                    // top → 27620 = 320pt one-sided) leaves a small recent
                    // range at the bottom while the DAY has clearly trended.
                    // Use sessOpen/sessHigh/sessLow to gauge the whole day.
                    if(decision.fire && this.sessOpen > 0){
                        const _dayRng = Math.max(this.sessHigh - this.sessLow, 0.01);
                        const _dayMv  = c - this.sessOpen;
                        const _PIDR   = (c - this.sessLow) / _dayRng; // 0=low, 1=high
                        const _dayDir = _dayMv > 0 ? 1 : -1;
                        const _directional = Math.abs(_dayMv) > atr * 4;
                        if(_directional){
                            // COUNTER-DAY: fading a directional day at the
                            // wrong extreme = catching falling knife.
                            //   LONG when day is down AND price near day low
                            //   SHORT when day is up AND price near day high
                            if(dir === 1 && _dayDir === -1 && _PIDR < 0.35){
                                decision.fire = false;
                                this.blockReason = 'COUNTER-DAY';
                            } else if(dir === -1 && _dayDir === 1 && _PIDR > 0.65){
                                decision.fire = false;
                                this.blockReason = 'COUNTER-DAY';
                            }
                            // LATE-CHASE: piling in WITH a directional day at
                            // its extreme — the move already paid out.
                            //   SHORT into the lows of a down day
                            //   LONG into the highs of an up day
                            if(decision.fire){
                                if(dir === -1 && _dayDir === -1 && _PIDR < 0.20){
                                    decision.fire = false;
                                    this.blockReason = 'LATE-CHASE';
                                } else if(dir === 1 && _dayDir === 1 && _PIDR > 0.80){
                                    decision.fire = false;
                                    this.blockReason = 'LATE-CHASE';
                                }
                            }
                        }
                    }
                    // Regime-flip override: when at MAX-TRADES, allow ONE extra
                    // trade if it's the opposite direction of recent losses and
                    // high-conviction. The market just flipped on us — taking
                    // the new direction is the whole point. Bounded to one use
                    // per session.
                    if(decision.fire && this.dailyTrades >= maxTrades){
                        // The override may relax MAX-TRADES ONLY. Never let a
                        // regime-flip reopen trading past the daily loss cap,
                        // the hard-stop, or an active loss-pause. (Redundant
                        // with block precedence above, kept as a hard guard.)
                        const _overLoss  = this.sessPnl*cv <= -(maxLoss*0.5); // covers MAX-LOSS + HARD-STOP
                        const _inPause   = bi <= this.pauseUntilBar;
                        const isFlip = this.lastLossDir !== 0 &&
                                       dir === -this.lastLossDir &&
                                       decision.totalScore >= 7 &&
                                       !this.maxTradesOverrideUsed &&
                                       !_overLoss && !_inPause;
                        if(isFlip){
                            this.maxTradesOverrideUsed = true;
                            this.blockReason = '';
                        } else {
                            decision.fire = false;
                            this.blockReason = 'MAX-TRADES';
                        }
                    }
                }
                if(decision.fire){
                    const dir = decision.dir;
                    const rsk = atr * 2.0;
                    let tps = this._findTPs(dir, c, levels, atr);
                    if(this.trendDay){
                        if(dir===1){ tps[0]=this.exp2H||tps[0]; tps[1]=this.exp3H||tps[1]; }
                        else        { tps[0]=this.exp2L||tps[0]; tps[1]=this.exp3L||tps[1]; }
                    }
                    // Source attribution — for the existing attrStats system.
                    const lt2 = coilFire !== 0
                        ? ('COIL_' + (coilFire === 1 ? 'UP' : 'DN'))
                        : (nearLevel ? nearLevel.type : '');
                    if(lt2==='BWALL'||lt2==='SWALL') this.entrySource='walls';
                    else if(lt2==='BFOOT'||lt2==='SFOOT') this.entrySource='footprint';
                    else this.entrySource='base';
                    // Behavior tag now describes the ALIGNMENT, not a hardcoded
                    // behavior name. Format: "AUCT+STR+FLOW@<level>" telling
                    // user which frameworks agreed.
                    const fwTags = [];
                    if(auctionR.dir === dir) fwTags.push('AUCT');
                    if(structR.dir === dir) fwTags.push('STR');
                    if(flowR.dir === dir) fwTags.push('FLOW');
                    const behaviorTag = fwTags.join('+') + '@' + lt2 +
                                        ' s'+decision.totalScore;
                    this.ep        = c;
                    this.position  = dir;
                    this.tp1Hit    = false;
                    this.trailSL   = 0;
                    // Reset capital preservation per-trade state
                    this.peakUnrealizedPnl = 0;
                    this.beMoved = false;
                    this.lockMoved = false;
                    this.entryRisk = null;  // computed on first eval below
                    this.sigBehavior = behaviorTag;
                    this.sigLevel    = lt2;
                    this.entryBar    = bi;
                    // Snapshot the market state at entry so we can attribute
                    // the outcome to the regime when the trade closes.
                    this.entryState  = this.marketState || 'NEUTRAL';
                    // Also store the CHART bar index that Tradovate uses
                    // for x-coordinate rendering. this.entryBar is our
                    // internal index (this.barIdx); this.entryChartIdx is
                    // d.index() — what du() needs to position lines.
                    // These are usually the same but can diverge across
                    // re-renders / replays / chart refreshes.
                    this.entryChartIdx = this.lastChartIdx;
                    this.entryTs       = ts;   // backtest: enables IS/OOS split by ENTRY time
                    this.barsHeld    = 0;
                    this.barsSinceSig= 0;
                    this.dailyTrades++;
                    // High-conviction setups get an extended TP2. When the
                    // backtest measured edge to be top-quartile (score ≥7,
                    // or a COIL fire which has measured +6pt/trade), push
                    // TP2 from 2.5R to 3.5R to capture the full move.
                    // Average winner of 1.34pt was 1:1 with avgL; widening
                    // TP shifts R:R toward 1.7:1 on the trades that earn it.
                    const _highConv = (decision.totalScore || 0) >= 7 || coilFire !== 0;
                    const _tp2Mult = _highConv ? 3.5 : 2.5;
                    // N4: cap stop distance. A level-anchored stop can land up to
                    // ~3.3 ATR away (atLevel ≤2.5 ATR + 0.8 buffer); bound it so a
                    // single trade's risk can't balloon (the H4 qty floor of 1
                    // means a very wide stop still risks the full |entry-stop|).
                    // Minimum stop stays ≥ rsk via the Math.min/Math.max below.
                    const _maxStop = atr * ((p.maxStopAtr!=null && p.maxStopAtr>0) ? p.maxStopAtr : 3.0);
                    if(dir===1){
                        this.sl  = nearLevel ? Math.min(nearLevel.price-atr*0.8, c-rsk) : c-rsk;
                        this.sl  = Math.max(this.sl, c - _maxStop);   // N4: clamp wide stops
                        this.tp1 = tps[0]||c+rsk*1.5;
                        this.tp2 = tps[1]||c+rsk*_tp2Mult;
                        newLong=true;
                    } else {
                        this.sl  = nearLevel ? Math.max(nearLevel.price+atr*0.8, c+rsk) : c+rsk;
                        this.sl  = Math.min(this.sl, c + _maxStop);   // N4: clamp wide stops
                        this.tp1 = tps[0]||c-rsk*1.5;
                        this.tp2 = tps[1]||c-rsk*_tp2Mult;
                        newShort=true;
                    }
                    // N5: ensure TP1 (partial / trail-activation) is the NEARER
                    // target and TP2 the farther one, even when one is a level and
                    // the other a fallback — otherwise a far level-based TP1 with a
                    // closer fallback TP2 would exit fully before the trail engages.
                    if((dir===1 && this.tp1 > this.tp2) || (dir===-1 && this.tp1 < this.tp2)){
                        const _tpSwap = this.tp1; this.tp1 = this.tp2; this.tp2 = _tpSwap;
                    }
                    // ── RISK-BASED POSITION SIZING (H4) ──────────────────
                    // qty from the per-trade $ budget and the ACTUAL stop
                    // distance, so the dollar guardrails (MAX-LOSS/HARD-STOP)
                    // reflect what you really risk. Floored at 1 (signals are
                    // never silently dropped) and capped by maxContracts.
                    const _riskPerContract = Math.abs(this.ep - this.sl) * cv;
                    if(riskPerTrade > 0 && _riskPerContract > 0){
                        this.qty = Math.max(1, Math.min(maxContracts,
                                              Math.floor(riskPerTrade / _riskPerContract)));
                    } else {
                        this.qty = 1;
                    }
                    this.renderMap[bi]={
                        dir, ep:c, sl:this.sl, tp1:this.tp1, tp2:this.tp2,
                        behavior:this.sigBehavior, level:lt2, exitPnl:null, exitBar:null
                    };
                    // Journal entry — captures all 3 readings for analysis
                    this._logJournal(bi, this.sessKey, hhmmStr, 'FIRED', {
                        dir: dir,
                        behavior: behaviorTag,
                        level: lt2,
                        ep: Math.round(c*100)/100,
                        sl: Math.round(this.sl*100)/100,
                        tp1: Math.round(this.tp1*100)/100,
                        tp2: Math.round(this.tp2*100)/100,
                        score: decision.totalScore,
                        auction: auctionR.dir+'/'+auctionR.score,
                        structure: structR.dir+'/'+structR.score,
                        orderflow: flowR.dir+'/'+flowR.score,
                        why: decision.reason
                    });
                    this.firedCount++;
                }
            }


            // ── DIAGNOSTICS: post-hoc setup detection ───────────────
            // Every 10 bars, look back 8-15 bars and check: did a clean
            // setup happen that we didn't take? Used by the auto-tuner
            // to know if filters are too tight.
            //
            // What counts as a post-hoc valid setup:
            //   • A wick rejection bar at a known level (sigma, wick zone,
            //     PSH, etc.) within tolerance
            //   • Followed within 3 bars by price moving in the rejection
            //     direction by >= 1.2 ATR
            //   • That bar's recovery was clean (close in rejection direction)
            //
            // If we DID fire on/near that bar, no log. If we didn't, log it.
            //
            // 2026-04-30 fix: previous version ran every 10 bars and only
            // looked back 8-15 bars, missing any setup older than that.
            // Also required candle to close in rejection direction (lC>lO
            // for bull, lC<lO for bear) which excluded indecisive doji-
            // wick rejections that are still valid setups. Now: every 5
            // bars, look 6-40 back, accept any wick rejection regardless
            // of body close direction. Caller still de-dups against past
            // detections.
            if(bi % 5 === 0 && n >= 15){
                const lookback = Math.min(40, n-1);
                for(let look=6; look<=lookback; look++){
                    const idx = n - 1 - look;
                    if(idx < 5) continue;
                    const lH = this.H[idx], lL = this.L[idx];
                    const lO = this.O[idx], lC = this.C[idx];
                    const lBody = Math.abs(lC-lO);
                    const lUpWick = lH - Math.max(lO,lC);
                    const lDnWick = Math.min(lO,lC) - lL;
                    // Wick threshold matches actual detector (0.6 ATR)
                    // and body-ratio (0.5) so any wick the indicator's
                    // own detector sees, the post-hoc detector also sees.
                    let setupDir = 0;
                    if(lDnWick > atr*0.6 && lDnWick > lBody*0.5){
                        setupDir = 1;  // bullish rejection (lower wick)
                    } else if(lUpWick > atr*0.6 && lUpWick > lBody*0.5){
                        setupDir = -1; // bearish rejection (upper wick)
                    }
                    if(setupDir === 0) continue;
                    // Was it at a level? Check against levels at THAT bar
                    // (using current levels as proxy — close enough for detection)
                    const lookPrice = (lH+lL)/2;
                    const levels2 = this._getLevels();
                    let atLvl = false;
                    for(const lv of levels2){
                        if(Math.abs(lookPrice - lv.price) < atr*1.5){ atLvl=true; break; }
                    }
                    if(!atLvl) continue;
                    // Did price follow through within 3 bars?
                    let followThrough = false;
                    for(let j=1; j<=3 && idx+j < n; j++){
                        const followMove = setupDir===1
                            ? this.H[idx+j] - lC
                            : lC - this.L[idx+j];
                        if(followMove >= atr*1.2){ followThrough=true; break; }
                    }
                    if(!followThrough) continue;
                    // Did we fire on or within 2 bars of this setup?
                    const setupBar = bi - look;
                    let weFired = false;
                    if(this.entryBar >= setupBar-1 && this.entryBar <= setupBar+2){
                        weFired = true;
                    }
                    // De-dup: don't log the same setup twice
                    let alreadyLogged = false;
                    for(const ph of this.postHocSetups){
                        if(Math.abs(ph.bar - setupBar) < 3) { alreadyLogged=true; break; }
                    }
                    if(!weFired && !alreadyLogged){
                        // ── ENHANCED MISS DIAGNOSTIC ──
                        // Re-run the three framework readers using the data
                        // at the setup bar. This tells us EXACTLY what each
                        // reader saw and why the trade didn't fire.
                        // The readers don't take an explicit bar argument —
                        // they use this.* state and the most recent values —
                        // so we temporarily swap in the setup bar's values.
                        const savedC = this.C, savedH = this.H, savedL = this.L,
                              savedO = this.O, savedV = this.V, savedD = this.D;
                        // Build truncated arrays as they would have been at idx
                        // (so readers see history UP TO the setup bar)
                        this.C = savedC.slice(0, idx+1);
                        this.H = savedH.slice(0, idx+1);
                        this.L = savedL.slice(0, idx+1);
                        this.O = savedO.slice(0, idx+1);
                        this.V = savedV.slice(0, idx+1);
                        this.D = savedD.slice(0, idx+1);
                        const histC = lC, histH = lH, histL = lL;
                        const histO = lO, histV = this.V[idx]||0, histD = this.D[idx]||0;
                        // Run readers as they would have at that bar
                        let nearLv2 = null, nearDist2 = 1e9;
                        for(const lv of levels2){
                            const d2 = Math.abs(histC - lv.price);
                            if(d2 < nearDist2){ nearDist2 = d2; nearLv2 = lv; }
                        }
                        let auctR2={dir:0,score:0,reason:'?'};
                        let strR2={dir:0,score:0,reason:'?'};
                        let flowR2={dir:0,score:0,reason:'?'};
                        try {
                            auctR2 = this._readAuction(histC, histH, histL, atr, levels2, nearLv2, nearDist2);
                            strR2  = this._readStructure(histC, histH, histL, atr);
                            flowR2 = this._readOrderflow(histC, histH, histL, histO, histV, histD, atr, this.avgVol||1, idx+1);
                        } catch(e){}
                        // Restore arrays
                        this.C = savedC; this.H = savedH; this.L = savedL;
                        this.O = savedO; this.V = savedV; this.D = savedD;

                        this.postHocSetups.push({
                            bar:setupBar, dir:setupDir, price:lookPrice,
                            atr:Math.round(atr*10)/10,
                            // What each reader saw at the missed bar
                            aDir: auctR2.dir, aScore: auctR2.score, aReason: auctR2.reason,
                            sDir: strR2.dir,  sScore: strR2.score,  sReason: strR2.reason,
                            fDir: flowR2.dir, fScore: flowR2.score, fReason: flowR2.reason,
                            // Pattern detector state at this bar (current state, approximate)
                            absSeqBars: this.absSeqBars,
                            absSeqDir:  this.absSeqDir,
                            steppingIn: this.steppingIn,
                            bosDir:     this.bosDir,
                            // Level info
                            nearLv: nearLv2 ? nearLv2.type : 'none',
                            nearDistATR: Math.round(nearDist2/atr*10)/10
                        });
                        if(this.postHocSetups.length > 30) this.postHocSetups.shift();
                        // ── JOURNAL: log MISSED setup ──
                        // Try to figure out why we missed it by looking at
                        // signalAttempts around setupBar — find the closest
                        // attempt and use its blockReason or dirClearedBy
                        // as best-guess cause.
                        // Two-pass lookup: first try ±3 bars (most accurate),
                        // then widen to ±10 bars if nothing found. This
                        // handles cases where the post-hoc detection bar
                        // and the actual signalAttempt bar drift apart.
                        let whyMissed = '';
                        const _lookupSetup = (windowSize) => {
                            for(let saI = this.signalAttempts.length-1; saI>=0; saI--){
                                const sa = this.signalAttempts[saI];
                                if(Math.abs(sa.bar - setupBar) <= windowSize){
                                    if(sa.blockReason && sa.blockReason !== 'OK'){
                                        return sa.blockReason;
                                    } else if(sa.dirClearedBy){
                                        return sa.dirClearedBy;
                                    } else if(sa.behaviorTried === ''){
                                        return 'no behavior pattern matched';
                                    } else {
                                        return 'OK (silent rejection)';
                                    }
                                }
                            }
                            return '';
                        };
                        whyMissed = _lookupSetup(3) || _lookupSetup(10);
                        // Last-resort fallback — check journal for nearby BLOCKED entry
                        if(!whyMissed){
                            for(let ji = this.journal.length-1; ji >= 0 && ji >= this.journal.length-50; ji--){
                                const je = this.journal[ji];
                                if(je.type === 'BLOCKED' && Math.abs(je.bar - setupBar) <= 5){
                                    whyMissed = je.reason || 'blocked';
                                    break;
                                }
                            }
                        }
                        if(!whyMissed) whyMissed = 'no nearby attempt logged';
                        // Get the rich data we just captured
                        const lastPH = this.postHocSetups[this.postHocSetups.length-1];
                        this._logJournal(bi, this.sessKey, hhmmStr, 'MISSED', {
                            setupBar: setupBar,
                            dir: setupDir,
                            price: Math.round(lookPrice*100)/100,
                            why: whyMissed,
                            barsAgo: bi - setupBar,
                            // What each reader saw at the missed bar
                            aDir: lastPH ? lastPH.aDir : 0,
                            aScore: lastPH ? lastPH.aScore : 0,
                            aReason: lastPH ? lastPH.aReason : '',
                            sDir: lastPH ? lastPH.sDir : 0,
                            sScore: lastPH ? lastPH.sScore : 0,
                            sReason: lastPH ? lastPH.sReason : '',
                            fDir: lastPH ? lastPH.fDir : 0,
                            fScore: lastPH ? lastPH.fScore : 0,
                            fReason: lastPH ? lastPH.fReason : '',
                            absSeqBars: lastPH ? lastPH.absSeqBars : 0,
                            steppingIn: lastPH ? lastPH.steppingIn : false,
                            nearLv: lastPH ? lastPH.nearLv : 'none',
                            nearDistATR: lastPH ? lastPH.nearDistATR : 0
                        });
                        this.missedCount++;
                    }
                }
            }


            // ─────────────────────────────────────────────────────────
            // GRAPHICS — ENTRY / EXIT LABELS
            // ─────────────────────────────────────────────────────────
            // These are the actual SIGNAL arrows — they render every bar
            // (independent of HUD mode), so in simpleMode they're the
            // primary attention-grabber. Made bold and large enough to
            // catch the eye without a banner.
            if(newLong){
                _items.push({tag:'Text',key:'eL_'+bi,text:'▲ LONG',
                    point:{x:du(this.lastChartIdx),y:du(l-atr*1.4)},
                    style:{fontSize:_fz(14),fontWeight:'bold',fill:_C.bullBright},
                    textAlignment:'centerMiddle'});
                _items.push({tag:'Text',key:'eLb_'+bi,
                    text:this.sigBehavior+' @ '+c.toFixed(2),
                    point:{x:du(this.lastChartIdx),y:du(l-atr*2.1)},
                    style:{fontSize:_fz(10),fontWeight:'bold',fill:_C.bullBright},textAlignment:'centerMiddle'});
            }
            if(newShort){
                _items.push({tag:'Text',key:'eS_'+bi,text:'▼ SHORT',
                    point:{x:du(this.lastChartIdx),y:du(h+atr*1.4)},
                    style:{fontSize:_fz(14),fontWeight:'bold',fill:_C.bearBright},
                    textAlignment:'centerMiddle'});
                _items.push({tag:'Text',key:'eSb_'+bi,
                    text:this.sigBehavior+' @ '+c.toFixed(2),
                    point:{x:du(this.lastChartIdx),y:du(h+atr*2.1)},
                    style:{fontSize:_fz(10),fontWeight:'bold',fill:_C.bearBright},textAlignment:'centerMiddle'});
            }
            if(exitNow){
                const win = exitPnl>=0;
                // Key the exit label by entryBar (fixed for this trade) +
                // exit bar to avoid duplicate WIN labels rendering at
                // slightly different bar indices during tick replay.
                // Tradovate dedups by key, so a stable key per trade
                // produces a single label even if map() re-fires.
                const _exKey = 'ex_'+(this.entryBar||0)+'_'+bi;
                // Place above bar when LONG-win or SHORT-loss (price went up at exit),
                // below bar when LONG-loss or SHORT-win (price went down at exit).
                const _above = (exitDir===1) === win;
                _items.push({tag:'Text',key:_exKey,
                    text:win?'✓ WIN':'✗ LOSS',
                    point:{x:du(this.lastChartIdx),y:du(_above?h+atr:l-atr)},
                    style:{fontSize:_fz(11),fontWeight:'bold',fill:win?_C.winText:_C.lossText},
                    textAlignment:'centerMiddle'});
            }

            // ─────────────────────────────────────────────────────────
            // HUD  (clean, focused — only what you need to trade)
            // ─────────────────────────────────────────────────────────
            // Render HUD on the last bar via d.isLast(). Stable keys
            // (sm_status, sm_jrn_summary, etc.) ensure de-duplication
            // even if isLast misfires.
            const isLast = typeof d.isLast==='function' && d.isLast();
            if(isLast){
                const _px = op(du(this.lastChartIdx),'+',px(8));

                // Expected-move line fallback. The custom expPlotter draws
                // these from history, but some Tradovate layouts do not call
                // custom plotters reliably. Ordinary LineSegments keep the EM
                // bands visible either way.
                const _lineRight = this.lastChartIdx + 15;
                const _lineFromBar = (bar, fallbackBars) => {
                    const age = Math.max(0, bi - (bar || bi));
                    return Math.max(0, this.lastChartIdx - (age || fallbackBars || 0));
                };
                const _pushLvlLine = (key, y, color, width, opacity, startX) => {
                    if(!(y > 0)) return;
                    _items.push({tag:'LineSegments', key:key,
                        lines:[{tag:'Line', a:{x:du(startX), y:du(y)}, b:{x:du(_lineRight), y:du(y)}}],
                        lineStyle:{lineWidth:width, color:color, opacity:opacity}});
                };
                if(false && this.exp1H>0){
                    const sxExp = _lineFromBar(this.sessOpenBar, Math.min(bi, 80));
                    _pushLvlLine('em_d_1h', this.exp1H, '#00CCFF', 2, 1.0, sxExp);
                    _pushLvlLine('em_d_1l', this.exp1L, '#00CCFF', 2, 1.0, sxExp);
                    _pushLvlLine('em_d_mid', this.expMid, '#00FF88', 1, 0.35, sxExp);
                    _pushLvlLine('em_d_2h', this.exp2H, '#FF8C00', 1, 0.85, sxExp);
                    _pushLvlLine('em_d_2l', this.exp2L, '#FF8C00', 1, 0.85, sxExp);
                    _pushLvlLine('em_d_3h', this.exp3H, '#FFEE00', 1, 0.75, sxExp);
                    _pushLvlLine('em_d_3l', this.exp3L, '#FFEE00', 1, 0.75, sxExp);
                    _pushLvlLine('em_d_4h', this.exp4H, '#FF2244', 2, 0.9, sxExp);
                    _pushLvlLine('em_d_4l', this.exp4L, '#FF2244', 2, 0.9, sxExp);
                }
                if(false && this.wk1H>0){
                    const sxWk = _lineFromBar(this.weekOpenBar, Math.min(bi, 300));
                    _pushLvlLine('em_w_1h', this.wk1H, '#B388FF', 2, 0.8, sxWk);
                    _pushLvlLine('em_w_1l', this.wk1L, '#B388FF', 2, 0.8, sxWk);
                }
                if(false && this.mo1H>0){
                    const sxMo = _lineFromBar(this.monthOpenBar, Math.min(bi, 600));
                    _pushLvlLine('em_m_1h', this.mo1H, '#FF88DD', 2, 0.7, sxMo);
                    _pushLvlLine('em_m_1l', this.mo1L, '#FF88DD', 2, 0.7, sxMo);
                }

                // ═════════════════════════════════════════════════════
                // SIMPLE MODE — clean signal-focused chart
                // ═════════════════════════════════════════════════════
                // When simpleMode is on, hide ~95% of the visual clutter.
                // What's visible:
                //   • Sigma lines (drawn by expPlotter — always there)
                //   • Entry/SL/TP lines + numeric labels WHEN in a trade
                //   • The 1-2 nearest sigmas as labels (price context)
                //   • Tiny status line: session + state + "WATCHING" or
                //     "BLOCKED: reason" + trade count
                // Everything else (walls, footprints, wick zones, balance
                // clusters, full HUD, performance stats, H1 timer, etc.)
                // is hidden. The LONG/SHORT/WIN/LOSS markers at entry
                // bars are still drawn (those are outside this block) —
                // those ARE the signal.
                if(simpleMode){
                    // Position lines — keep these so you can see SL/TP visually
                    if(this.position!==0 && this.entryBar>0){
                        const pos = this.position;
                        // Use entryChartIdx (Tradovate's chart index at entry)
                        // not this.entryBar (our internal counter) for x coord
                        const sx = (this.entryChartIdx != null) ? this.entryChartIdx : this.entryBar;
                        const ex = this.lastChartIdx + 5;
                        // Entry
                        _items.push({tag:'LineSegments', key:'sm_pos_entry',
                            lines:[{tag:'Line', a:{x:du(sx), y:du(this.ep)}, b:{x:du(ex), y:du(this.ep)}}],
                            lineStyle:{lineWidth:1, color:pos===1?'#00FFCC':'#FF6622', opacity:0.9}});
                        // Stop loss
                        _items.push({tag:'LineSegments', key:'sm_pos_sl',
                            lines:[{tag:'Line', a:{x:du(sx), y:du(this.sl)}, b:{x:du(ex), y:du(this.sl)}}],
                            lineStyle:{lineWidth:1, color:'#FF4444', opacity:0.9}});
                        // TP1 / Trail
                        const tpLv = this.tp1Hit ? this.trailSL : this.tp1;
                        _items.push({tag:'LineSegments', key:'sm_pos_tp1',
                            lines:[{tag:'Line', a:{x:du(sx), y:du(tpLv)}, b:{x:du(ex), y:du(tpLv)}}],
                            lineStyle:{lineWidth:1, color:'#00FF66', opacity:0.9}});
                        // TP2 — only before tp1 hit
                        if(!this.tp1Hit && this.tp2>0){
                            _items.push({tag:'LineSegments', key:'sm_pos_tp2',
                                lines:[{tag:'Line', a:{x:du(sx), y:du(this.tp2)}, b:{x:du(ex), y:du(this.tp2)}}],
                                lineStyle:{lineWidth:1, color:'#00AA44', opacity:0.6}});
                        }
                        // Numeric labels at right edge — Entry / SL / TP only
                        const pnl = pos===1?c-this.ep:this.ep-c;
                        const pnlD = Math.round(pnl*cv);
                        const ec = pnl>=0?'#00FF88':'#FF4444';
                        const rr = Math.abs(tpLv-this.ep)/Math.max(Math.abs(this.ep-this.sl),0.01);
                        _items.push({tag:'Text', key:'sm_ep',
                            text:'ENTRY '+this.ep.toFixed(2)+'   '+
                                 (pnl>=0?'+':'')+pnl.toFixed(0)+'pt  '+
                                 (pnlD>=0?'+$':'-$')+Math.abs(pnlD),
                            point:{x:_px, y:du(this.ep)},
                            style:{fontSize:_fz(12), fontWeight:'bold', fill:ec},
                            textAlignment:'leftMiddle', global:true});
                        _items.push({tag:'Text', key:'sm_sl',
                            text:'SL '+this.sl.toFixed(2)+
                                 ' (-$'+Math.round(Math.abs(this.ep-this.sl)*cv)+')',
                            point:{x:_px, y:du(this.sl)},
                            style:{fontSize:_fz(11), fontWeight:'bold', fill:_C.slLine},
                            textAlignment:'leftMiddle', global:true});
                        _items.push({tag:'Text', key:'sm_tp',
                            text:(this.tp1Hit?'TRAIL ':'TP ')+tpLv.toFixed(2)+
                                 '  ('+rr.toFixed(1)+'R)',
                            point:{x:_px, y:du(tpLv)},
                            style:{fontSize:_fz(11), fontWeight:'bold', fill:_C.tpLine},
                            textAlignment:'leftMiddle', global:true});
                    }

                    // Nearest 2 sigma labels — minimal price context
                    if(this.exp1H>0 && (this.expDailyIsInput || showFallbackSigmas)){
                        const sigs = [
                            {p:this.exp1H, t:'1σH '+this.exp1H.toFixed(0), c:'#00CCFF'},
                            {p:this.exp1L, t:'1σL '+this.exp1L.toFixed(0), c:'#00CCFF'},
                            {p:this.exp2H, t:'2σH '+this.exp2H.toFixed(0), c:'#FF8C00'},
                            {p:this.exp2L, t:'2σL '+this.exp2L.toFixed(0), c:'#FF8C00'},
                            {p:this.exp3H, t:'3σH '+this.exp3H.toFixed(0), c:'#FFEE00'},
                            {p:this.exp3L, t:'3σL '+this.exp3L.toFixed(0), c:'#FFEE00'}
                        ].sort((a,b)=>Math.abs(c-a.p)-Math.abs(c-b.p)).slice(0,2);
                        for(let i=0;i<sigs.length;i++){
                            const s = sigs[i];
                            const close = Math.abs(c-s.p) <= atr*1.5;
                            _items.push({tag:'Text', key:'sm_sig_'+i,
                                text:(close?'→ ':'')+s.t,
                                point:{x:_px, y:du(s.p)},
                                style:{fontSize:_fz(10), fontWeight:close?'bold':'normal', fill:s.c},
                                textAlignment:'leftMiddle', global:true});
                        }
                    }

                    // Weekly / monthly expected-move band labels (colors match
                    // the plotter lines: weekly = purple, monthly = pink). Only
                    // shown when that horizon's EM is set (>0).
                    if(this.wk1H>0){
                        _items.push({tag:'Text', key:'sm_wkH', text:'WK +EM '+this.wk1H.toFixed(0),
                            point:{x:_px, y:du(this.wk1H)},
                            style:{fontSize:_fz(10), fontWeight:'bold', fill:'#B388FF'},
                            textAlignment:'leftMiddle', global:true});
                        _items.push({tag:'Text', key:'sm_wkL', text:'WK -EM '+this.wk1L.toFixed(0),
                            point:{x:_px, y:du(this.wk1L)},
                            style:{fontSize:_fz(10), fontWeight:'bold', fill:'#B388FF'},
                            textAlignment:'leftMiddle', global:true});
                    }
                    if(this.mo1H>0){
                        _items.push({tag:'Text', key:'sm_moH', text:'MO +EM '+this.mo1H.toFixed(0),
                            point:{x:_px, y:du(this.mo1H)},
                            style:{fontSize:_fz(10), fontWeight:'bold', fill:'#FF88DD'},
                            textAlignment:'leftMiddle', global:true});
                        _items.push({tag:'Text', key:'sm_moL', text:'MO -EM '+this.mo1L.toFixed(0),
                            point:{x:_px, y:du(this.mo1L)},
                            style:{fontSize:_fz(10), fontWeight:'bold', fill:'#FF88DD'},
                            textAlignment:'leftMiddle', global:true});
                    }

                    // Tiny status text — top of chart
                    const sessTag = sessSuffix==='_ny'      ? 'NY'    :
                                    sessSuffix==='_eve'     ? 'EVE'   :
                                    sessSuffix==='_asia'    ? 'ASIA'  :
                                    sessSuffix==='_london'  ? 'LON'   :
                                                              'OFF';
                    // ── SINGLE CONSOLIDATED HUD LINE ──────────────────
                    // Everything you need in one row, anchored ABOVE the
                    // session high so it never sits on candles. Indicator
                    // does the heavy lifting; the chart stays clean.
                    //
                    // Format:
                    //   [NY] WATCH 2/3 • Q5 RANGE • DAY ▼-78 P23% IB↓ H1▼ • 2F 0W2L
                    let _stateTag, _stateCol;
                    if(this.position!==0){
                        _stateTag = 'IN-TRADE';
                        _stateCol = this.position===1?'#00FFCC':'#FF6622';
                    } else if(this.blockReason){
                        _stateTag = this.blockReason;
                        _stateCol = '#888888';
                    } else {
                        _stateTag = 'WATCH';
                        _stateCol = '#AAAAAA';
                    }
                    const _hudParts = ['['+sessTag+'] '+_stateTag+' '+
                                       this.dailyTrades+'/'+maxTrades];
                    const _qNum = (this.dayQuality != null) ? this.dayQuality : 5;
                    const _msShort = this.marketState && this.marketState !== 'NEUTRAL'
                        ? ' '+this.marketState : '';
                    _hudParts.push('Q'+_qNum.toFixed(0)+_msShort);
                    if(this.sessOpen > 0){
                        const _dRng2 = Math.max(this.sessHigh - this.sessLow, 0.01);
                        const _dMv2  = c - this.sessOpen;
                        const _PIDR2 = (c - this.sessLow) / _dRng2;
                        const _ibSym = this.ibBroken === 1 ? ' IB↑' :
                                       this.ibBroken === -1 ? ' IB↓' :
                                       this.ibLocked ? ' IB·' : '';
                        const _h1Sym = this.h1Trend === 'BULL' ? ' H1▲' :
                                       this.h1Trend === 'BEAR' ? ' H1▼' : '';
                        _hudParts.push('DAY '+(_dMv2>0?'▲':_dMv2<0?'▼':'·')+
                                       (_dMv2>=0?'+':'')+_dMv2.toFixed(0)+
                                       ' P'+(_PIDR2*100).toFixed(0)+_ibSym+_h1Sym);
                    }
                    if(this.firedCount > 0 || this.blockedCount > 0){
                        const _wl = (this.sessionWins+this.sessionLosses) > 0
                            ? ' '+this.sessionWins+'W'+this.sessionLosses+'L'
                            : '';
                        _hudParts.push(this.firedCount+'F'+_wl);
                    }
                    // Anchor above session high so HUD doesn't touch candles.
                    const _hudY = (this.sessHigh > 0 ? this.sessHigh : c) + atr * 2;
                    _items.push({tag:'Text', key:'sm_hud',
                        text: _hudParts.join('  •  '),
                        point:{x:_px, y:du(_hudY)},
                        style:{fontSize:_fz(11), fontWeight:'bold', fill:_stateCol},
                        textAlignment:'leftMiddle', global:true});

                    // ── PATTERN DETECTOR DIAGNOSTIC LINE ──
                    // Shows live state of detectors so we can see what
                    // the indicator sees. Format:
                    //   PHASE:MARKUP  AUC:DISCOVERY+  abs:bull@27580×4  ...
                    // PHASE = Wyckoff phase (the master context)
                    // If a detector is empty, it's dashed.
                    const pdParts = [];
                    // Instrument profile (NQ / GC / OTHER) — auto-detected
                    // on first bar from price magnitude. Shown so user can
                    // verify the right profile loaded.
                    pdParts.push(this._instrument);
                    // Wyckoff phase — drives everything else
                    let phaseLabel = 'PHASE:—';
                    if(this.mktState === 'TRENDING_UP') phaseLabel = 'PHASE:MARKUP';
                    else if(this.mktState === 'TRENDING_DN') phaseLabel = 'PHASE:MARKDOWN';
                    else if(this.mktState === 'RANGING') phaseLabel = 'PHASE:RANGE';
                    else if(this.mktState === 'TRANSITIONING') phaseLabel = 'PHASE:TRANSIT';
                    pdParts.push(phaseLabel);
                    // Auction state (current bar context)
                    if(this.auctionState && this.auctionState !== 'NEUTRAL'){
                        const biasStr = this.auctionStateBias===1?'+':
                                        this.auctionStateBias===-1?'-':'·';
                        pdParts.push('AUC:'+this.auctionState+biasStr);
                    } else {
                        pdParts.push('AUC:—');
                    }
                    if(this.absSeqDir !== 0 && this.absSeqBars >= 2){
                        pdParts.push('abs:'+(this.absSeqDir===1?'bull':'bear')+
                                     '@'+this.absSeqLevel.toFixed(1)+
                                     '×'+this.absSeqBars);
                    } else {
                        pdParts.push('abs:—');
                    }
                    if(this.steppingIn){
                        pdParts.push('step:'+(this.steppingInDir===1?'up':'dn'));
                    } else {
                        pdParts.push('step:—');
                    }
                    if(this.bosDir !== 0){
                        const barsSinceBOS = bi - this.bosTriggerBar;
                        pdParts.push('bos:'+(this.bosDir===1?'up':'dn')+
                                     '('+barsSinceBOS+'b)');
                    } else {
                        pdParts.push('bos:—');
                    }
                    // Sweep state
                    if(this.sweepDir !== 0 && this.sweepBar > 0){
                        const barsSinceSweep = bi - this.sweepBar;
                        pdParts.push('SWEEP:'+(this.sweepDir===1?'up':'dn')+
                                     '@'+this.sweepLevel.toFixed(0)+
                                     '('+barsSinceSweep+'b)');
                    } else {
                        pdParts.push('sweep:—');
                    }
                    // Show MTT levels currently in level list
                    const _curLevels = this._getLevels();
                    const mttLevels = _curLevels.filter(lv =>
                        lv.type === 'MTT_H' || lv.type === 'MTT_L');
                    if(mttLevels.length > 0){
                        const lv0 = mttLevels[0];
                        pdParts.push('mtt:'+(lv0.type==='MTT_H'?'H':'L')+
                                     '@'+lv0.price.toFixed(0)+
                                     '('+lv0.touches+'t)');
                    } else {
                        pdParts.push('mtt:—');
                    }
                    // J-hook status: bases tracked, retest active
                    if(this.jhookActive){
                        pdParts.push('JHOOK:'+(this.jhookDir===1?'up':'dn')+
                                     '@'+this.jhookLevel.toFixed(0));
                    } else if(this.confirmedBases.length > 0){
                        pdParts.push('bases:'+this.confirmedBases.length);
                    } else {
                        pdParts.push('jhook:—');
                    }
                    // Strongest level vote — shows behavior consensus across helpers
                    if(this.levelVotes && this.levelVotes.size > 0){
                        let topVote = null;
                        for(const [k, v] of this.levelVotes){
                            if(!topVote || v.strength > topVote.strength) topVote = v;
                        }
                        if(topVote && topVote.strength >= 6){
                            const dirChar = topVote.dir === 1 ? 'BUY' : 'SELL';
                            pdParts.push('LV:'+dirChar+'@'+topVote.price.toFixed(0)+
                                         '×'+topVote.evidence.length+'/'+topVote.strength);
                        }
                    }
                    // Pattern detector diagnostic suppressed in simpleMode
                    // (user wants a clean chart). Available in full mode.
                    // _items.push({tag:'Text', key:'sm_pattern_diag', ...})

                    // ── DIAGNOSTICS OVERLAY (when diagMode is on) ──
                    // Health badge + recent auto-tune action + missed-setup
                    // dots on the bars where setups were detected post-hoc.
                    const diagOn = (p.diagMode!=null?p.diagMode:1) >= 1;
                    if(diagOn){
                        // Health badge — only render when something's off.
                        // When verdict is OK, stay invisible (per user pref:
                        // "tiny badge, expands only when there's a problem").
                        if(this.healthVerdict !== 'OK'){
                            const hCol = this.healthVerdict==='ERROR' ? '#FF4444' : '#FFAA22';
                            const hSym = this.healthVerdict==='ERROR' ? '[!]' : '[?]';
                            _items.push({tag:'Text', key:'sm_health',
                                text: hSym+' '+this.healthMsg,
                                point:{x:_px, y:du(c+atr*2.3)},
                                style:{fontSize:_fz(10), fontWeight:'bold', fill:hCol},
                                textAlignment:'leftMiddle', global:true});
                        }

                        // Most recent auto-tune log entry, if any
                        if(this.autoTuneLog.length>0){
                            const lastTune = this.autoTuneLog[this.autoTuneLog.length-1];
                            // Show only if recent (last 200 bars)
                            if(bi - lastTune.bar < 200){
                                _items.push({tag:'Text', key:'sm_tune',
                                    text:'⚙ '+lastTune.param+' '+lastTune.oldVal+'→'+lastTune.newVal+' ('+lastTune.reason+')',
                                    point:{x:_px, y:du(c+atr*3.1)},
                                    style:{fontSize:_fz(9), fontWeight:'normal', fill:_C.statusWarn},
                                    textAlignment:'leftMiddle', global:true});
                            }
                        }

                        // Missed-setup dots — on the bars where post-hoc setups
                        // were detected. Render as small text symbol above
                        // (for shorts) or below (for longs) the bar.
                        let phK = 0;
                        for(const ph of this.postHocSetups){
                            if(bi - ph.bar > 80) continue; // only recent
                            // Find the actual chart x for this bar
                            const phX = this.lastChartIdx - (bi - ph.bar);
                            if(phX < 0) continue;
                            const phY = ph.dir===1 ? ph.price - atr*0.4 : ph.price + atr*0.4;
                            const phCol = ph.dir===1 ? '#FFAA66' : '#FFAA66';
                            const phSym = ph.dir===1 ? '·↑' : '·↓';
                            _items.push({tag:'Text', key:'sm_miss_'+phK,
                                text: phSym,
                                point:{x:du(phX), y:du(phY)},
                                style:{fontSize:_fz(9), fill:phCol},
                                textAlignment:'centerMiddle'});
                            phK++;
                        }
                    }

                    // ── JOURNAL: tiny always-visible summary line ──
                    // Format: "📓 3 fired (2W/1L) | 4 blocked | 2 missed"
                    // Always shown (even at zero) so you know the indicator
                    // is alive and tracking. Sits below the status line.
                    const wlStr = (this.sessionWins + this.sessionLosses) > 0
                        ? ' ('+this.sessionWins+'W/'+this.sessionLosses+'L)'
                        : '';
                    // Session counts now folded into the consolidated HUD line
                    // above. The standalone journal-summary push is suppressed
                    // in simpleMode for a cleaner chart.
                    void wlStr;

                    // ── JOURNAL: full report (only when showReport=1) ──
                    // Fills the chart with a structured session report:
                    // session header + chronological event list + stats.
                    // User flips showReport=1 to see, 0 to hide.
                    const showRep = (p.showReport!=null?p.showReport:0) >= 1;
                    if(showRep){
                        this._renderReport(_items, _px, c, atr, _fz);
                    }

                    return _ret;
                }
                // ═════════════════════════════════════════════════════
                // FULL DIAGNOSTIC MODE (simpleMode = 0) — original chart
                // ═════════════════════════════════════════════════════

                // ── BUILD LEVEL LIST — labels only (lines are session-bounded
                // via expPlotter for sigmas, finite segments for active position).
                // Sigmas + VWAP always shown; everything else only when relevant.
                const allLvls = [];

                // Sigma bands — ALWAYS visible (lines drawn by expPlotter)
                if(this.exp1H>0 && (this.expDailyIsInput || showFallbackSigmas)){
                    allLvls.push({p:this.exp1H, f:'#00CCFF', s:11, b:false, t:'1σH '+this.exp1H.toFixed(0), always:true});
                    allLvls.push({p:this.exp1L, f:'#00CCFF', s:11, b:false, t:'1σL '+this.exp1L.toFixed(0), always:true});
                    allLvls.push({p:this.exp2H, f:'#FF8C00', s:10, b:false, t:'2σH '+this.exp2H.toFixed(0), always:true});
                    allLvls.push({p:this.exp2L, f:'#FF8C00', s:10, b:false, t:'2σL '+this.exp2L.toFixed(0), always:true});
                    allLvls.push({p:this.exp3H, f:'#FFEE00', s:10, b:false, t:'3σH '+this.exp3H.toFixed(0), always:true});
                    allLvls.push({p:this.exp3L, f:'#FFEE00', s:10, b:false, t:'3σL '+this.exp3L.toFixed(0), always:true});
                    allLvls.push({p:this.exp4H, f:'#FF2244', s:11, b:true,  t:'4σH '+this.exp4H.toFixed(0), always:true});
                    allLvls.push({p:this.exp4L, f:'#FF2244', s:11, b:true,  t:'4σL '+this.exp4L.toFixed(0), always:true});
                }

                // VWAP — always
                if(this.vwap>0){
                    allLvls.push({p:this.vwap, f:'#44FF88', s:10, b:false, t:'VWAP '+this.vwap.toFixed(0), always:true});
                }

                // Context levels — only if within 4 ATR of price (about to be tested
                // or recently tested). Far-off levels are hidden until they matter.
                const ctxDist = atr*4;
                if(this.prevSessHigh>0){
                    allLvls.push({p:this.prevSessHigh, f:'#8888FF', s:10, b:false, t:'PSH '+this.prevSessHigh.toFixed(0), maxDist:ctxDist});
                    allLvls.push({p:this.prevSessLow,  f:'#8888FF', s:10, b:false, t:'PSL '+this.prevSessLow.toFixed(0), maxDist:ctxDist});
                }
                if(this.asiaHigh>0&&this.asiaLow<999999){
                    allLvls.push({p:this.asiaHigh, f:'#FFCC44', s:10, b:false, t:'AsiaH '+this.asiaHigh.toFixed(0), maxDist:ctxDist});
                    allLvls.push({p:this.asiaLow,  f:'#FFCC44', s:10, b:false, t:'AsiaL '+this.asiaLow.toFixed(0), maxDist:ctxDist});
                }
                if(this.prevDailyHigh>0){
                    const dCol = this.dailyBias==='BEAR'?'#FF6666':'#66FF66';
                    const arrow= this.dailyBias==='BEAR'?'↓':'↑';
                    allLvls.push({p:this.prevDailyHigh, f:dCol, s:10, b:true, t:arrow+'PDH '+this.prevDailyHigh.toFixed(0), maxDist:ctxDist});
                    allLvls.push({p:this.prevDailyLow,  f:dCol, s:10, b:true, t:arrow+'PDL '+this.prevDailyLow.toFixed(0), maxDist:ctxDist});
                }
                if(this.prevWeekHigh>0){
                    allLvls.push({p:this.prevWeekHigh, f:'#AA88FF', s:10, b:false, t:'PWH '+this.prevWeekHigh.toFixed(0), maxDist:ctxDist});
                    allLvls.push({p:this.prevWeekLow,  f:'#AA88FF', s:10, b:false, t:'PWL '+this.prevWeekLow.toFixed(0), maxDist:ctxDist});
                }

                // Delta walls — only the 2 nearest within 3 ATR
                const dDist = atr*3;
                const wallsNear = this.deltaWalls
                    .filter(w => Math.abs(c-w.price) <= dDist)
                    .sort((a,b) => Math.abs(c-a.price) - Math.abs(c-b.price))
                    .slice(0,2);
                for(const w of wallsNear){
                    const wcol = w.dir===1 ? '#00FF99' : '#FF5566';
                    const wTag = w.dir===1 ? 'BWALL' : 'SWALL';
                    allLvls.push({p:w.price, f:wcol, s:10, b:true,
                                  t:wTag+' '+w.price.toFixed(0), maxDist:dDist});
                }

                // Footprint zones — only the 2 nearest within 3 ATR
                const footNear = this.footprintTops
                    .filter(f => Math.abs(c-f.price) <= dDist)
                    .sort((a,b) => Math.abs(c-a.price) - Math.abs(c-b.price))
                    .slice(0,2);
                for(const f of footNear){
                    const fcol = f.dir===1 ? '#33CCAA' : '#CC5577';
                    const fTag = f.dir===1 ? 'BFOOT' : 'SFOOT';
                    allLvls.push({p:f.price, f:fcol, s:10, b:true,
                                  t:fTag+' '+f.price.toFixed(0), maxDist:dDist});
                }

                // Filter: keep "always" + context within their maxDist
                const inRange = allLvls
                    .filter(lv => lv.p>0 && (lv.always || Math.abs(c-lv.p) <= lv.maxDist))
                    .sort((a,b)=>a.p - b.p);

                // Proximity cue — when price is within 1.5 ATR of a level,
                // mark it with → and bold to flag "about to test"
                const proxDist = atr*1.5;
                for(const lv of inRange){
                    if(Math.abs(c-lv.p) <= proxDist){
                        lv.t = '→ '+lv.t;
                        lv.b = true;
                    }
                }

                // ── WICK ZONES + BALANCE CLUSTERS (Wick Sauce visual) ─
                // Each wick zone = small box (top wick → body edge) with
                // a dotted 50% midline. Bullish wicks (lower) = green
                // shades, bearish (upper) = red. Inverted wicks (counter-
                // trend rejections) get brighter color = strong continuation.
                // Tested zones dim. Mitigated zones gone.
                // Balance clusters draw thicker top/bottom + bold equilibrium.
                let zoneKey = 0;

                // Active wick zones — keep within ATR*8 of price (decluttering)
                const activeWicks = this.wickZones
                    .filter(wz => !wz.mitigated && Math.abs(c - wz.mid) <= atr*8)
                    .sort((a,b) => Math.abs(c-a.mid) - Math.abs(c-b.mid))
                    .slice(0,6);

                for(const wz of activeWicks){
                    // Color logic:
                    //   bullish wick (buy zone)  → green family
                    //   bearish wick (sell zone) → red family
                    //   inverted = brighter (continuation signal)
                    //   tested  = dimmer
                    let edgeCol, midCol;
                    if(wz.bull){
                        edgeCol = wz.inverted ? '#5fcf85' : '#3a7a52';
                        midCol  = wz.inverted ? '#8fef9f' : '#5a9a72';
                    } else {
                        edgeCol = wz.inverted ? '#e07060' : '#7a4a3a';
                        midCol  = wz.inverted ? '#ff9080' : '#9a6a5a';
                    }
                    const opac = wz.tested ? 0.35 : 0.7;
                    const wzSx = Math.max(0, wz.startBar);
                    const wzEx = this.lastChartIdx + 5;

                    // Top edge of wick zone
                    _items.push({
                        tag:'LineSegments', key:'wz_t_'+zoneKey,
                        lines:[{tag:'Line',
                            a:{x:du(wzSx), y:du(wz.top)},
                            b:{x:du(wzEx), y:du(wz.top)}}],
                        lineStyle:{lineWidth:1, color:edgeCol, opacity:opac}
                    });
                    // Bottom edge of wick zone
                    _items.push({
                        tag:'LineSegments', key:'wz_b_'+zoneKey,
                        lines:[{tag:'Line',
                            a:{x:du(wzSx), y:du(wz.bot)},
                            b:{x:du(wzEx), y:du(wz.bot)}}],
                        lineStyle:{lineWidth:1, color:edgeCol, opacity:opac}
                    });
                    // 50% equilibrium line (the entry trigger)
                    _items.push({
                        tag:'LineSegments', key:'wz_m_'+zoneKey,
                        lines:[{tag:'Line',
                            a:{x:du(wzSx), y:du(wz.mid)},
                            b:{x:du(wzEx), y:du(wz.mid)}}],
                        lineStyle:{lineWidth:1, color:midCol, opacity:opac*0.7}
                    });
                    // Label only when within 4 ATR (close enough to matter)
                    if(Math.abs(c - wz.mid) <= atr*4){
                        const baseTag = wz.bull ? 'BWICK' : 'SWICK';
                        const tag = (wz.inverted ? '★' : '') + baseTag +
                                    (wz.tested ? '·' : '');
                        _items.push({tag:'Text', key:'wz_lbl_'+zoneKey,
                            text: tag+' '+wz.mid.toFixed(0),
                            point:{x:_px, y:du(wz.mid)},
                            style:{fontSize:_fz(9), fontWeight:wz.inverted?'bold':'normal', fill:midCol},
                            textAlignment:'leftMiddle', global:true});
                    }
                    zoneKey++;
                }

                // Balance clusters — wick-density zones (3+ wicks at same level)
                // Drawn with thicker lines and clear EQ line — these are the
                // "balanced" areas where wicks have agreed on fair price.
                let bcKey = 0;
                for(const bc of this.balanceClusters){
                    // Skip if too far from price
                    if(Math.abs(c - bc.mid) > atr*10) continue;
                    const bcCol = '#a0a0c8';
                    const bcSx = Math.max(0, Math.min(...bc.bars));
                    const bcEx = this.lastChartIdx + 5;
                    // Top
                    _items.push({
                        tag:'LineSegments', key:'bc_t_'+bcKey,
                        lines:[{tag:'Line',
                            a:{x:du(bcSx), y:du(bc.top)},
                            b:{x:du(bcEx), y:du(bc.top)}}],
                        lineStyle:{lineWidth:2, color:bcCol, opacity:0.6}
                    });
                    // Bottom
                    _items.push({
                        tag:'LineSegments', key:'bc_b_'+bcKey,
                        lines:[{tag:'Line',
                            a:{x:du(bcSx), y:du(bc.bot)},
                            b:{x:du(bcEx), y:du(bc.bot)}}],
                        lineStyle:{lineWidth:2, color:bcCol, opacity:0.6}
                    });
                    // Equilibrium (50% of balance)
                    _items.push({
                        tag:'LineSegments', key:'bc_m_'+bcKey,
                        lines:[{tag:'Line',
                            a:{x:du(bcSx), y:du(bc.mid)},
                            b:{x:du(bcEx), y:du(bc.mid)}}],
                        lineStyle:{lineWidth:1, color:'#d0d0e0', opacity:0.5}
                    });
                    if(Math.abs(c - bc.mid) <= atr*5){
                        _items.push({tag:'Text', key:'bc_lbl_'+bcKey,
                            text:'BAL ('+bc.wickCount+'w) '+bc.bot.toFixed(0)+'-'+bc.top.toFixed(0),
                            point:{x:_px, y:du(bc.top)},
                            style:{fontSize:_fz(9), fontWeight:'bold', fill:bcCol},
                            textAlignment:'leftMiddle', global:true});
                        _items.push({tag:'Text', key:'bc_eq_'+bcKey,
                            text:'EQ '+bc.mid.toFixed(0),
                            point:{x:_px, y:du(bc.mid)},
                            style:{fontSize:_fz(9), fontWeight:'normal', fill:'#d0d0e0'},
                            textAlignment:'leftMiddle', global:true});
                    }
                    bcKey++;
                }

                // ── POSITION LINES — finite segments while in trade ──
                // From entry bar to current bar+small offset.
                if(this.position!==0 && this.entryBar>0){
                    const pos = this.position;
                    const sx = (this.entryChartIdx != null) ? this.entryChartIdx : this.entryBar;
                    const ex = this.lastChartIdx + 5;

                    // Entry line
                    _items.push({
                        tag:'LineSegments', key:'pos_entry_line',
                        lines:[{tag:'Line',
                            a:{x:du(sx), y:du(this.ep)},
                            b:{x:du(ex), y:du(this.ep)}}],
                        lineStyle:{lineWidth:1, color:pos===1?'#00FFCC':'#FF6622', opacity:0.85}
                    });
                    // Stop loss line
                    _items.push({
                        tag:'LineSegments', key:'pos_sl_line',
                        lines:[{tag:'Line',
                            a:{x:du(sx), y:du(this.sl)},
                            b:{x:du(ex), y:du(this.sl)}}],
                        lineStyle:{lineWidth:1, color:'#FF4444', opacity:0.85}
                    });
                    // TP1 / Trail line (whichever is active)
                    const tpLv = this.tp1Hit ? this.trailSL : this.tp1;
                    _items.push({
                        tag:'LineSegments', key:'pos_tp1_line',
                        lines:[{tag:'Line',
                            a:{x:du(sx), y:du(tpLv)},
                            b:{x:du(ex), y:du(tpLv)}}],
                        lineStyle:{lineWidth:1, color:'#00FF66', opacity:0.85}
                    });
                    // TP2 line — only before tp1 hit
                    if(!this.tp1Hit && this.tp2>0){
                        _items.push({
                            tag:'LineSegments', key:'pos_tp2_line',
                            lines:[{tag:'Line',
                                a:{x:du(sx), y:du(this.tp2)},
                                b:{x:du(ex), y:du(this.tp2)}}],
                            lineStyle:{lineWidth:1, color:'#00AA44', opacity:0.6}
                        });
                    }
                }

                // ── COLLISION MERGE — group labels within 5pts ──
                const mergeDist = 5;
                const clusters = [];
                let cur = null;
                for(const lv of inRange){
                    if(cur && lv.p - cur.maxP <= mergeDist){
                        cur.items.push(lv);
                        cur.maxP = lv.p;
                    } else {
                        if(cur) clusters.push(cur);
                        cur = {items:[lv], minP:lv.p, maxP:lv.p};
                    }
                }
                if(cur) clusters.push(cur);

                // Render one label per cluster
                let lvKey = 0;
                for(const cl of clusters){
                    if(cl.items.length===1){
                        const lv = cl.items[0];
                        _items.push({tag:'Text', key:'lv'+lvKey,
                            text: lv.t,
                            point:{x:_px, y:du(lv.p)},
                            style:{fontSize:_fz(lv.s), fontWeight:lv.b?'bold':'normal', fill:lv.f},
                            textAlignment:'leftMiddle', global:true});
                    } else {
                        const names = cl.items.map(lv => {
                            const m = lv.t.match(/^(?:→\s+)?(.*?)\s+\d{4,5}/);
                            return m ? m[1].trim() : lv.t;
                        });
                        const avgP = cl.items.reduce((s,lv)=>s+lv.p,0) / cl.items.length;
                        const boldest = cl.items.find(lv=>lv.b) || cl.items[0];
                        const nearAny = cl.items.some(lv=>Math.abs(c-lv.p)<=proxDist);
                        const prefix = nearAny ? '→ ' : '';
                        const combined = prefix+names.join('/')+' '+avgP.toFixed(0);
                        _items.push({tag:'Text', key:'lv'+lvKey,
                            text: combined,
                            point:{x:_px, y:du(avgP)},
                            style:{fontSize:_fz(11), fontWeight:'bold', fill:boldest.f},
                            textAlignment:'leftMiddle', global:true});
                    }
                    lvKey++;
                }

                // ── ACTIVE POSITION LABELS (numbers at right edge) ──
                if(this.position!==0){
                    const pos=this.position;
                    const pnl=pos===1?c-this.ep:this.ep-c;
                    const pnlD=Math.round(pnl*cv);
                    const ec=pnl>=0?'#00FF88':'#FF4444';
                    const tpLv = this.tp1Hit ? this.trailSL : this.tp1;
                    const rr   = Math.abs(tpLv-this.ep)/Math.max(Math.abs(this.ep-this.sl),0.01);

                    _items.push({tag:'Text',key:'ep_t',
                        text:'ENTRY '+this.ep.toFixed(2),
                        point:{x:_px,y:du(this.ep)},
                        style:{fontSize:_fz(11),fontWeight:'bold',fill:pos===1?_C.bullBright:_C.bearBright},
                        textAlignment:'leftMiddle',global:true});

                    _items.push({tag:'Text',key:'sl_t',
                        text:'SL '+this.sl.toFixed(2)+
                             '  (-'+(Math.abs(this.ep-this.sl)*cv).toFixed(0)+'$)',
                        point:{x:_px,y:du(this.sl)},
                        style:{fontSize:_fz(11),fontWeight:'bold',fill:_C.slLine},
                        textAlignment:'leftMiddle',global:true});

                    _items.push({tag:'Text',key:'tp_t',
                        text:(this.tp1Hit?'TRAIL ':'TP1 ')+tpLv.toFixed(2)+
                             '  ('+rr.toFixed(1)+'R)',
                        point:{x:_px,y:du(tpLv)},
                        style:{fontSize:_fz(11),fontWeight:'bold',fill:_C.tpLine},
                        textAlignment:'leftMiddle',global:true});

                    if(!this.tp1Hit&&this.tp2>0){
                        const rr2=Math.abs(this.tp2-this.ep)/Math.max(Math.abs(this.ep-this.sl),0.01);
                        _items.push({tag:'Text',key:'tp2_t',
                            text:'TP2 '+this.tp2.toFixed(2)+
                                 '  ('+rr2.toFixed(1)+'R)',
                            point:{x:_px,y:du(this.tp2)},
                            style:{fontSize:_fz(11),fill:_C.trailLine},
                            textAlignment:'leftMiddle',global:true});
                    }

                    _items.push({tag:'Text',key:'hud_tr',
                        text:(pos===1?'▲ ':'▼ ')+'['+this.sigBehavior+'] '+
                             rr.toFixed(1)+'R  '+
                             (pnl>=0?'+':'')+pnl.toFixed(0)+'pt  '+
                             (pnlD>=0?'+$':'-$')+Math.abs(pnlD),
                        point:{x:_px,y:du(this.ep)},
                        style:{fontSize:_fz(12),fontWeight:'bold',fill:ec},
                        textAlignment:'leftMiddle',global:true});
                }

                const tot  = this.totalW+this.totalL;
                const wr   = tot>0 ? Math.round(this.totalW/tot*100)+'%' : '--';
                const pnlD = Math.round(this.totalPnl*cv);
                const sessPnlD = Math.round(this.sessPnl*cv);
                const mktCol  = this.mktState==='TRENDING_UP'?'#00FFCC':
                                this.mktState==='TRENDING_DN'?'#FF6622':
                                this.mktState==='TRANSITIONING'?'#FFEE00':'#AAAAAA';
                const mktTag  = this.mktState==='TRENDING_UP'?'📈 TREND UP':
                                this.mktState==='TRENDING_DN'?'📉 TREND DN':
                                this.mktState==='TRANSITIONING'?'⚡ REVERSAL':
                                '↔ RANGE';
                const strTag  = this.trendStrength>=8?'  ███':this.trendStrength>=6?'  ██':this.trendStrength>=4?'  █':'';
                const volTag  = this.volConfirm?' VOL✓':'';
                const blockStr = (this.position===0 && this.blockReason)
                    ? '  ⏱ BLOCKED:'+this.blockReason
                    : '';

                const h1FlipHud = (this.h1FlipBull&&bi-this.h1FlipBar<=8)?' H1↑FLIP':
                                  (this.h1FlipBear&&bi-this.h1FlipBar<=8)?' H1↓FLIP':'';
                const dailyTag = this.dailyBias==='BEAR'?' 📅DN':this.dailyBias==='BULL'?' 📅UP':'';
                // 4H tag — LIVE current building candle (not stale closed-trend).
                // Shows the in-progress 4H bar's direction + points from its open.
                // The previous "h4Trend" version read off the last 2 CLOSED 4H
                // candles, so during a pullback (2 red 4Hs closed, current 4H now
                // making a strong green recovery) it still flashed "4H↓" while
                // your eye saw a clearly bullish current candle. This shows what's
                // happening NOW. The closed-trend still drives signal logic under
                // the hood — only the display changed.
                const h4LiveDir = this.h4O>0 ? (c>=this.h4O?1:-1) : 0;
                const h4LivePts = this.h4O>0 ? Math.round(c-this.h4O) : 0;
                // Flag when current candle is fighting the prior 2-candle trend
                // (real-time pullback / potential reversal cue).
                const h4Diverge = (this.h4Trend==='BEAR' && h4LiveDir===1) ||
                                  (this.h4Trend==='BULL' && h4LiveDir===-1);
                const h4DivTag = h4Diverge ? '⚡' : '';
                const h4Tag = this.h4O>0
                    ? (h4LiveDir===1 ? ' 4H↑+'+h4LivePts+h4DivTag
                                     : ' 4H↓'+h4LivePts+h4DivTag)
                    : '';
                const vsYday   = this.todayVsPrevDay==='ABOVE'?' ▲YDay':this.todayVsPrevDay==='BELOW'?' ▼YDay':'';

                const sessTag = sessSuffix==='_ny'      ? 'MNQ-NY'    :
                                sessSuffix==='_eve'     ? 'MNQ-EVE'   :
                                sessSuffix==='_asia'    ? 'MNQ-ASIA'  :
                                sessSuffix==='_london'  ? 'MNQ-LON'   :
                                                          'MNQ-OFF';
                _items.push({tag:'Text',key:'hud',
                    text:'['+sessTag+'] '+mktTag+strTag+volTag+h1FlipHud+dailyTag+h4Tag+vsYday+
                         '  '+this.dailyTrades+'/'+maxTrades+' trades'+
                         blockStr,
                    point:{x:_px,y:du(c+atr*0.8)},
                    style:{fontSize:_fz(12),fontWeight:'bold',fill:mktCol},
                    textAlignment:'leftMiddle',global:true});

                const minsLeft = 60 - bLtm;
                const lagTag = (isLive && this.barLagMin>=5)
                    ? ' ⚠'+this.barLagMin+'m' : '';
                const h1CurDir = this.h1O>0 ? (c>=this.h1O?1:-1) : 0;
                const h1CurPts = this.h1O>0 ? (c-this.h1O).toFixed(0) : '0';
                const h1CurStr = h1CurDir===1
                    ? '▲'+'+'+h1CurPts
                    : h1CurDir===-1 ? '▼'+h1CurPts : '·';
                const h1CurCol = h1CurDir===1?'#00FFCC':h1CurDir===-1?'#FF6622':'#AAAAAA';

                const h1Hist = this.h1Candles.slice(-4).map(hc=>{
                    const d = hc.dir!==undefined ? hc.dir : (hc.c>=hc.o?1:-1);
                    const pts = (hc.c-hc.o).toFixed(0);
                    return d===1?('↑'+pts):('↓'+pts);
                }).join('  ');
                const h1HistStr = h1Hist.length>0 ? h1Hist+'  ' : '';

                const filledBars = Math.round(minsLeft/60*10);
                const timerBar = '█'.repeat(filledBars)+'░'.repeat(10-filledBars);

                _items.push({tag:'Text',key:'hud_h1timer',
                    text:'H1: '+h1HistStr+'['+h1CurStr+']  '+minsLeft+'m left  '+timerBar+lagTag,
                    point:{x:_px,y:du(c-atr*1.8)},
                    style:{fontSize:_fz(11),fontWeight:'bold',fill:h1CurCol},
                    textAlignment:'leftMiddle',global:true});

                _items.push({tag:'Text',key:'hud_perf',
                    text:this.totalW+'W  '+this.totalL+'L  '+wr+
                         '  Total:'+(pnlD>=0?'+$':'-$')+Math.abs(pnlD)+
                         '  Today:'+(sessPnlD>=0?'+$':'-$')+Math.abs(sessPnlD),
                    point:{x:_px,y:du(c-atr*2.6)},
                    style:{fontSize:_fz(11),fill:pnlD>=0?_C.pnlPos:_C.pnlNeg},
                    textAlignment:'leftMiddle',global:true});

                // ── JOURNAL: full report (works in full diagnostic mode too) ──
                const showRepF = (p.showReport!=null?p.showReport:0) >= 1;
                if(showRepF){
                    this._renderReport(_items, _px, c, atr, _fz);
                }
            }

            return _ret;

        } catch(e){
            // Outer guard — Tradovate's framework calls map() per-bar and
            // an uncaught error stops rendering entirely. We swallow here
            // to keep the indicator alive on edge-case bar data. To debug
            // when running locally, set env.DEBUG_MAP=1 before requiring.
            // N1: ALSO render a visible error badge. A silently-blank chart is
            // the dangerous failure mode — it looks identical to "no setups,"
            // so a crash could go unnoticed while you wait for signals.
            this._mapErrCount = (this._mapErrCount || 0) + 1;
            this._lastMapErr  = (e && e.message) ? e.message : String(e);
            if(typeof process !== 'undefined' && process.env && process.env.DEBUG_MAP){
                console.error('MAP ERROR:', e.message, e.stack);
            }
            const _errItems = [];
            try {
                const _lastC = (this.C && this.C.length) ? this.C[this.C.length-1] : 0;
                const _atrB  = Math.max(this.atr || 1, 1);
                const _ex    = (this.lastChartIdx != null) ? this.lastChartIdx : 0;
                if(_lastC > 0){
                    _errItems.push({tag:'Text', key:'map_error',
                        text:'⚠ INDICATOR ERROR #'+this._mapErrCount+': '+this._lastMapErr,
                        point:{x:du(_ex), y:du(_lastC + _atrB*3)},
                        style:{fontSize:18, fontWeight:'bold', fill:'#FF3333'},
                        textAlignment:'leftMiddle', global:true});
                }
            } catch(_e2){ /* never let the error renderer itself throw */ }
            return {graphics:{items:_errItems}};
        }
    }

    // Sigma-level respect tracker — call once per new bar with bi/h/l/c/atr.
    // Each level (1H/1L/2H/2L/3H/3L/4H/4L) gets touches counted when price
    // first reaches it, then 5 bars later we classify the outcome:
    //   reversal — close still on the original side
    //   break    — close beyond the level (clean breach)
    _trackSigmaRespect(bi, h, l, c, atr){
        const lvls = [
            ['1H', this.exp1H], ['1L', this.exp1L],
            ['2H', this.exp2H], ['2L', this.exp2L],
            ['3H', this.exp3H], ['3L', this.exp3L],
            ['4H', this.exp4H], ['4L', this.exp4L],
        ];
        const tol = Math.max(atr * 0.2, this.tickSize * 2);
        const verifyBars = 5;

        // First, classify any pending touches whose verification window passed
        for (const k in this.pendingSigma) {
            const p = this.pendingSigma[k];
            if (bi - p.hitBar < verifyBars) continue;
            if (!this.sigmaStats[k]) {
                this.sigmaStats[k] = { touches:0, reversals:0, breaks:0 };
            }
            const s = this.sigmaStats[k];
            // For an H-level (resistance) hit from below: reversal = close < level, break = close >= level
            // For an L-level (support) hit from above:    reversal = close > level, break = close <= level
            const isH = k.endsWith('H');
            const broken = isH ? (c >= p.levelPrice) : (c <= p.levelPrice);
            if (broken) s.breaks++; else s.reversals++;
            delete this.pendingSigma[k];
        }

        // Then look for fresh touches this bar
        for (const [k, lvl] of lvls) {
            if (!lvl || lvl <= 0) continue;
            if (this.pendingSigma[k]) continue;     // already pending
            const isH = k.endsWith('H');
            const touched = isH
                ? (h >= lvl - tol && c < lvl)       // reached from below, not yet broken
                : (l <= lvl + tol && c > lvl);      // reached from above, not yet broken
            if (touched) {
                if (!this.sigmaStats[k]) {
                    this.sigmaStats[k] = { touches:0, reversals:0, breaks:0 };
                }
                this.sigmaStats[k].touches++;
                this.pendingSigma[k] = { hitBar: bi, levelPrice: lvl };
            }
        }
    }

    _computeEXP(open){
        const sk = this.sessKey;
        const floor = sk.includes('_ny')     ? 300 :
                      sk.includes('_london') ? 250 :
                      sk.includes('_eve')    ? 200 :
                      sk.includes('_asia')   ? 175 :
                                                150;
        const calRange = this.calDayH>0&&this.calDayL<999999 ? this.calDayH-this.calDayL : 0;
        // Daily expected move: Settings field first, then the EM_DAILY
        // fallback constant. Keeping emDaily>0 forces the input branch
        // (expDailyIsInput=true), which routes the bands through the canvas
        // plotter so the LINES actually draw.
        let emDaily = (this.props && Number(this.props.expMoveDaily)) || 0;
        if(!(emDaily > 0)) emDaily = EM_DAILY;
        // Anchor the daily bands at the 9:30 RTH open. Settings rthOpen first,
        // then the RTH_OPEN constant, then the auto-detected open, then this
        // bar's open.
        const _rthIn = (this.props && Number(this.props.rthOpen)) || 0;
        const anchor = (_rthIn > 0)       ? _rthIn
                     : (RTH_OPEN > 0)     ? RTH_OPEN
                     : (this.rthOpen > 0) ? this.rthOpen
                     : open;
        this.expMid = anchor;
        if(emDaily > 0){
            this.expDailyIsInput = true;
            // TRUE options expected-move levels: 0.5σ/1σ/1.5σ/2σ of the implied
            // daily move (the ATM straddle). No historical-range floor.
            this.exp1H=anchor+emDaily*0.5; this.exp1L=anchor-emDaily*0.5;
            this.exp2H=anchor+emDaily;     this.exp2L=anchor-emDaily;
            this.exp3H=anchor+emDaily*1.5; this.exp3L=anchor-emDaily*1.5;
            this.exp4H=anchor+emDaily*2.0; this.exp4L=anchor-emDaily*2.0;
        } else {
            this.expDailyIsInput = false;
            let base = this.avgSessRange>0 ? this.avgSessRange
                     : calRange>150        ? calRange
                     : floor;
            base = Math.max(base, floor);
            this.exp1H=open+base*0.618; this.exp1L=open-base*0.618;
            this.exp2H=open+base;       this.exp2L=open-base;
            this.exp3H=open+base*1.382; this.exp3L=open-base*1.382;
            this.exp4H=open+base*1.618; this.exp4L=open-base*1.618;
        }
    }

    _update1hr(){
        const cn = this.h1Candles;
        const n  = cn.length;
        if(n<1) return;

        if(n>=2){
            const last = cn[n-1];
            const prev = cn[n-2];
            const lastDir = last.c >= last.o ? 1 : -1;
            const prevDir = prev.c >= prev.o ? 1 : -1;
            if(lastDir===1 && prevDir===1)       this.h1Trend='BULL';
            else if(lastDir===-1 && prevDir===-1) this.h1Trend='BEAR';
            else                                  this.h1Trend='FLAT';
        } else if(n===1){
            const last = cn[0];
            const lastDir = last.c >= last.o ? 1 : -1;
            this.h1Trend = lastDir===1 ? 'BULL' : 'BEAR';
        }

        if(n>=3){
            const l1=cn[n-1].l, l2=cn[n-2].l, l3=cn[n-3].l;
            const h1=cn[n-1].h, h2=cn[n-2].h, h3=cn[n-3].h;
            this.h1HigherLow = l1>l2 && l2>l3;
            this.h1LowerHigh = h1<h2 && h2<h3;
        }
    }

    _getLevels(){
        const lv=[];
        if(this.exp1H>0){
            lv.push({price:this.exp1H,type:'1σH'},{price:this.exp1L,type:'1σL'});
            lv.push({price:this.exp2H,type:'2σH'},{price:this.exp2L,type:'2σL'});
            lv.push({price:this.exp3H,type:'3σH'},{price:this.exp3L,type:'3σL'});
            lv.push({price:this.exp4H,type:'4σH'},{price:this.exp4L,type:'4σL'});
        }
        if(this.prevSessHigh>0){
            lv.push({price:this.prevSessHigh,type:'PSH'});
            lv.push({price:this.prevSessLow, type:'PSL'});
        }
        if(this.prevWeekHigh>0){
            lv.push({price:this.prevWeekHigh,type:'PWH'});
            lv.push({price:this.prevWeekLow, type:'PWL'});
        }
        if(this.asiaHigh>0&&this.asiaLow<999999){
            lv.push({price:this.asiaHigh,type:'AH'});
            lv.push({price:this.asiaLow, type:'AL'});
        }
        if(this.prevDailyHigh>0){
            lv.push({price:this.prevDailyHigh,type:'PDH'});
            lv.push({price:this.prevDailyLow, type:'PDL'});
        }
        if(this.vwap>0) lv.push({price:this.vwap,type:'VWAP'});
        for(const v of this.voids){
            if(!v.filled) lv.push({price:(v.top+v.bot)/2, type:'VOID'});
        }
        for(const w of this.deltaWalls){
            lv.push({price:w.price, type:w.dir===1?'BWALL':'SWALL'});
        }
        for(const f of this.footprintTops){
            lv.push({price:f.price, type:f.dir===1?'BFOOT':'SFOOT'});
        }
        // ── WICK ZONES (Wick Sauce method) ──
        // The 50% mid of each unmitigated wick = the entry trigger.
        // BWICK = bullish wick zone (lower wick rejection = buy zone)
        // SWICK = bearish wick zone (upper wick rejection = sell zone)
        // Inverted variants (counter-trend rejection) tagged for strength.
        for(const wz of this.wickZones){
            if(wz.mitigated) continue;
            const baseType = wz.bull ? 'BWICK' : 'SWICK';
            const type = wz.inverted ? baseType+'_INV' : baseType;
            lv.push({price:wz.mid, type});
        }
        // Balance clusters — wick density zones (multiple wicks at same area)
        // BAL_H = top of balance, BAL_L = bottom, BAL_M = 50% equilibrium
        if(this.balanceClusters.length > 0){
            // Use the most recent cluster nearest current price
            const lastBC = this.balanceClusters[this.balanceClusters.length-1];
            lv.push({price:lastBC.top, type:'BAL_H'});
            lv.push({price:lastBC.bot, type:'BAL_L'});
            lv.push({price:lastBC.mid, type:'BAL_M'});
        }
        // ── MULTI-TOUCH ZONES (double tops/bottoms, triple tops/bottoms) ──
        // The user asked: why did the indicator miss obvious triple-top
        // shorts? Because individual swing highs aren't a "level type" until
        // they cluster. Cluster 2+ swings within ~0.5 ATR of each other and
        // the level becomes meaningful — that's a real supply/demand zone.
        //
        // MTT_H = multi-touch top (resistance, sell zone)
        // MTT_L = multi-touch bottom (support, buy zone)
        const _atrFloor = Math.max(this.atr || 4, 1);
        const _cluster = (arr, type, isHigh) => {
            // Group similar-priced swings within 0.5 ATR
            if(!arr || arr.length < 2) return;
            const used = new Array(arr.length).fill(false);
            for(let i = 0; i < arr.length; i++){
                if(used[i]) continue;
                const cluster = [arr[i]];
                used[i] = true;
                for(let j = i+1; j < arr.length; j++){
                    if(used[j]) continue;
                    if(Math.abs(arr[j].price - arr[i].price) <= _atrFloor * 0.5){
                        cluster.push(arr[j]);
                        used[j] = true;
                    }
                }
                if(cluster.length >= 2){
                    // Average the cluster prices for the level
                    const avg = cluster.reduce((s,p)=>s+p.price, 0) / cluster.length;
                    // Tag with touch count so the auction reader can score it
                    lv.push({
                        price: avg,
                        type: type,
                        touches: cluster.length
                    });
                }
            }
        };
        _cluster(this.swingHighs, 'MTT_H', true);
        _cluster(this.swingLows,  'MTT_L', false);

        // ── CONFIRMED BASES (J-hook source levels) ──
        // Each confirmed base/ceiling that hasn't been broken is a real
        // structural level. Add them so the auction reader can score
        // proximity to them.
        if(this.confirmedBases && this.confirmedBases.length > 0){
            for(const base of this.confirmedBases){
                lv.push({
                    price: base.level,
                    type: base.dir === 1 ? 'JHOOK_L' : 'JHOOK_H',
                    bars: base.bars,
                    formedAt: base.formedAt
                });
            }
        }

        // ── ANTICIPATORY MTT DETECTION ──
        // The cluster logic above requires 2 CONFIRMED swing highs/lows.
        // But swings are confirmed 2 bars after they happen. By the time
        // price has formed a confirmed double top, you've missed the entry.
        //
        // Anticipatory: if the CURRENT bar is at the same level as the most
        // recent confirmed swing high/low (within 0.5 ATR) AND the current
        // bar shows rejection (upper wick for highs, lower wick for lows),
        // register as anticipated MTT zone immediately.
        //
        // This catches the THIRD touch of a triple top in real time, even
        // if the third swing high hasn't been confirmed yet.
        const _atrFloor2 = Math.max(this.atr || 4, 1);
        const _curN = this.H.length;
        if(_curN > 0 && this.swingHighs.length > 0){
            const lastSH = this.swingHighs[this.swingHighs.length-1];
            const curH = this.H[_curN-1];
            const curC = this.C[_curN-1];
            const curO = this.O[_curN-1];
            const curL = this.L[_curN-1];
            const upWick = curH - Math.max(curO, curC);
            const body = Math.abs(curC - curO);
            // Within 0.5 ATR of the last confirmed swing high?
            // AND showing a meaningful upper wick? (rejection at the level)
            if(Math.abs(curH - lastSH.price) <= _atrFloor2 * 0.5 &&
               upWick >= _atrFloor2 * 0.4 && upWick > body * 0.5){
                // Don't double-add if cluster logic already produced an MTT_H
                const alreadyHas = lv.some(v =>
                    v.type === 'MTT_H' &&
                    Math.abs(v.price - ((curH + lastSH.price) / 2)) < _atrFloor2 * 0.5);
                if(!alreadyHas){
                    lv.push({
                        price: (curH + lastSH.price) / 2,
                        type: 'MTT_H',
                        touches: 2,  // current bar + last swing = 2 touches
                        anticipatory: true
                    });
                }
            }
        }
        if(_curN > 0 && this.swingLows.length > 0){
            const lastSL = this.swingLows[this.swingLows.length-1];
            const curL = this.L[_curN-1];
            const curC = this.C[_curN-1];
            const curO = this.O[_curN-1];
            const dnWick = Math.min(curO, curC) - curL;
            const body = Math.abs(curC - curO);
            if(Math.abs(curL - lastSL.price) <= _atrFloor2 * 0.5 &&
               dnWick >= _atrFloor2 * 0.4 && dnWick > body * 0.5){
                const alreadyHas = lv.some(v =>
                    v.type === 'MTT_L' &&
                    Math.abs(v.price - ((curL + lastSL.price) / 2)) < _atrFloor2 * 0.5);
                if(!alreadyHas){
                    lv.push({
                        price: (curL + lastSL.price) / 2,
                        type: 'MTT_L',
                        touches: 2,
                        anticipatory: true
                    });
                }
            }
        }
        // ── RECENT SWINGS AS LEVELS ─────────────────────────────
        // Even before a swing has been re-tested or clustered, the most
        // recent confirmed swing high/low IS a real structural level.
        // After a pullback in a markup, the pullback low is the entry
        // reference for continuation longs even if price hasn't returned
        // to it. This adds the LAST swing high/low as SH/SL levels with
        // moderate strength.
        //
        // Limited to swings within the last 30 bars to avoid stale levels
        // polluting the list.
        const _atrFloor3 = Math.max(this.atr || 4, 1);
        if(this.swingHighs.length > 0){
            const lastSH = this.swingHighs[this.swingHighs.length-1];
            // Only include if recent (within 30 bars) and not already
            // included via MTT cluster.
            if(this.barIdx - lastSH.bar <= 30){
                const dupMTT = lv.some(v =>
                    (v.type === 'MTT_H') &&
                    Math.abs(v.price - lastSH.price) < _atrFloor3 * 0.5);
                if(!dupMTT){
                    lv.push({ price: lastSH.price, type: 'SH', barAge: this.barIdx - lastSH.bar });
                }
            }
        }
        if(this.swingLows.length > 0){
            const lastSL = this.swingLows[this.swingLows.length-1];
            if(this.barIdx - lastSL.bar <= 30){
                const dupMTT = lv.some(v =>
                    (v.type === 'MTT_L') &&
                    Math.abs(v.price - lastSL.price) < _atrFloor3 * 0.5);
                if(!dupMTT){
                    lv.push({ price: lastSL.price, type: 'SL', barAge: this.barIdx - lastSL.bar });
                }
            }
        }

        return lv;
    }
    // ════════════════════════════════════════════════════════════════
    // The market does only three things at any moment:
    //   1. AUCTION — balancing or imbalancing (seeking value or discovery)
    //   2. STRUCTURE — making higher highs/lows or breaking that pattern
    //   3. ORDERFLOW — buyers or sellers winning the aggression battle
    //
    // Every bar, we read all three. Each reader returns:
    //   { dir: -1 | 0 | 1, score: 0-10, reason: string }
    //
    // Then we combine: 2-of-3 alignment at strong level (sigma/wick zone)
    // OR 3-of-3 alignment at any level → fire.
    //
    // No hardcoded patterns. The patterns the user described (J-reversal,
    // V-rejection, momentum, dip-after-exhaustion, structure-break) all
    // emerge naturally when 2 or 3 readers align in the same direction
    // at a tradeable level.
    // ════════════════════════════════════════════════════════════════

    // ── AUCTION READER ──────────────────────────────────────────────
    // Reads where price is in the auction cycle:
    //   • In balance (mktState=RANGING) → fade extremes toward POC
    //   • In imbalance/discovery → continuation in trend direction
    //   • At sigma extreme → strong fade signal
    //   • At balance edge with rejection → strong reversal signal
    // ════════════════════════════════════════════════════════════
    // AUCTION STATE CLASSIFIER
    // ════════════════════════════════════════════════════════════
    // Classifies the market into one of three auction-theory states
    // and returns a directional bias for that state.
    //
    // Returns: { state, bias (-1/0/1), score (0-10), reason }
    //
    // BALANCE — two-sided market, price oscillating in a defined range.
    //   Bias: at lower edge → bull, at upper edge → bear, at mid → 0.
    //   Detection: range over last 12 bars < 1.5 ATR + balanceCluster present
    //
    // ROTATION — price returning to a previous balance area or J-hook
    //   level after extension.
    //   Bias: in direction OF the rotation continuation if held.
    //   Detection: jhookActive (already tracks this) OR price returning
    //   to a balanceCluster after recent extension.
    //
    // DISCOVERY — price moving away from balance with conviction.
    //   Bias: in direction of movement (continuation).
    //   Detection: range expansion + close beyond recent balance bounds
    //   + sustained movement (3+ bars same direction).
    _classifyAuctionState(c, h, l, atr, n){
        const out = { state: 'NEUTRAL', bias: 0, score: 0, reason: '' };
        if(n < 8 || atr <= 0) return out;

        // Compute recent range (last 12 bars)
        const lookback = Math.min(12, n);
        let rngHi = -1e9, rngLo = 1e9;
        for(let i = n - lookback; i < n; i++){
            if(this.H[i] > rngHi) rngHi = this.H[i];
            if(this.L[i] < rngLo) rngLo = this.L[i];
        }
        const recentRange = rngHi - rngLo;
        const rangeATRs = recentRange / atr;

        // Find most recent balance cluster (if any)
        const lastBC = this.balanceClusters && this.balanceClusters.length > 0
            ? this.balanceClusters[this.balanceClusters.length - 1] : null;

        // ── ROTATION CHECK FIRST (highest priority) ──
        // J-hook active = price retesting confirmed base/ceiling. This IS
        // rotation — price left value, now returning to test acceptance.
        if(this.jhookActive){
            out.state = 'ROTATION';
            out.bias = this.jhookDir;
            out.score = 8;
            out.reason = 'rotation: '+(this.jhookDir===1?'bull':'bear')+' base retest';
            return out;
        }

        // Liquidity sweep = a special rotation: price punched OUTSIDE
        // value/structure briefly, got rejected back in. The reversal
        // direction is the auction state's bias.
        if(this.sweepDir !== 0 && this.sweepBar > 0 &&
           this.barIdx - this.sweepBar <= 4){
            out.state = 'ROTATION';
            out.bias = this.sweepDir;
            out.score = 8;
            out.reason = 'rotation: sweep '+(this.sweepDir===1?'low → long':'high → short');
            return out;
        }

        // Rotation back into a balance cluster from outside
        if(lastBC){
            const bcMid = lastBC.mid;
            const bcTop = lastBC.top;
            const bcBot = lastBC.bot;
            // Were we OUTSIDE the cluster recently and are now testing back?
            if(n >= 5){
                const recentMaxC = Math.max(this.C[n-2], this.C[n-3], this.C[n-4]);
                const recentMinC = Math.min(this.C[n-2], this.C[n-3], this.C[n-4]);
                const wasAbove = recentMaxC > bcTop + atr * 0.5;
                const wasBelow = recentMinC < bcBot - atr * 0.5;
                const nowInCluster = c >= bcBot && c <= bcTop;
                if(wasAbove && nowInCluster){
                    // Came down from above — testing top of cluster as support
                    out.state = 'ROTATION';
                    out.bias = 1;
                    out.score = 7;
                    out.reason = 'rotation: testing balance from above';
                    return out;
                }
                if(wasBelow && nowInCluster){
                    out.state = 'ROTATION';
                    out.bias = -1;
                    out.score = 7;
                    out.reason = 'rotation: testing balance from below';
                    return out;
                }
            }
        }

        // ── DISCOVERY CHECK ──
        // Strong directional movement OUT of recent value.
        // Last 3 bars range vs prior 3 bars range (expansion)
        const last3R = ((this.H[n-1]-this.L[n-1]) +
                       (this.H[n-2]-this.L[n-2]) +
                       (this.H[n-3]-this.L[n-3])) / 3;
        const prior3R = n >= 6 ? (((this.H[n-4]-this.L[n-4]) +
                                   (this.H[n-5]-this.L[n-5]) +
                                   (this.H[n-6]-this.L[n-6])) / 3) : last3R;
        const expanding = last3R > prior3R * 1.25;
        // Direction of last 3 bars
        const move3 = c - this.C[n-4 >= 0 ? n-4 : 0];
        const moveDir = Math.abs(move3) > atr * 1.0
            ? (move3 > 0 ? 1 : -1) : 0;
        // Beyond balance cluster?
        let beyondBalance = false;
        let beyondDir = 0;
        if(lastBC){
            if(c > lastBC.top + atr * 0.3){ beyondBalance = true; beyondDir = 1; }
            else if(c < lastBC.bot - atr * 0.3){ beyondBalance = true; beyondDir = -1; }
        } else if(rangeATRs > 2.5){
            // No cluster yet but range is wide — use raw move direction
            beyondBalance = true;
            beyondDir = moveDir;
        }
        if(beyondBalance && beyondDir !== 0 && expanding && moveDir === beyondDir){
            out.state = 'DISCOVERY';
            out.bias = beyondDir;
            out.score = 7;
            out.reason = 'discovery: '+(beyondDir===1?'up':'down')+
                         ' from balance, range expanding';
            return out;
        }

        // ── BALANCE CHECK ──
        // Tight range + balance cluster present = clearly balanced market
        if(rangeATRs < 1.8 && lastBC){
            out.state = 'BALANCE';
            // Bias from position within balance
            const bcMid = lastBC.mid;
            const bcTop = lastBC.top;
            const bcBot = lastBC.bot;
            const bcRange = bcTop - bcBot;
            if(bcRange > 0){
                const posInBalance = (c - bcBot) / bcRange;  // 0 = bottom, 1 = top
                if(posInBalance < 0.25){
                    out.bias = 1;
                    out.score = 6;
                    out.reason = 'balance: at lower edge, fade upward';
                } else if(posInBalance > 0.75){
                    out.bias = -1;
                    out.score = 6;
                    out.reason = 'balance: at upper edge, fade downward';
                } else {
                    out.bias = 0;
                    out.score = 3;
                    out.reason = 'balance: in middle, no edge';
                }
                return out;
            }
        }

        // ── ABSORPTION SEQUENCE ACTIVE = forming balance ──
        // 3+ bars of absorption at same level = base building
        if(this.absSeqDir !== 0 && this.absSeqBars >= 3){
            out.state = 'BALANCE';  // forming balance
            out.bias = this.absSeqDir;
            out.score = 6 + Math.min(2, this.absSeqBars - 3);
            out.reason = 'balance forming: '+this.absSeqBars+
                         '-bar '+(this.absSeqDir===1?'base':'ceiling');
            return out;
        }

        // No clear state
        return out;
    }

    // ════════════════════════════════════════════════════════════════
    // LEVEL VOTE SYSTEM — helpers contribute, readers consume
    // ════════════════════════════════════════════════════════════════
    // Helpers detect specific footprints (absorption, FVG, OB, climax,
    // engulfing, etc.) and vote on a level rather than emitting their
    // own named signal. When multiple helpers vote on the same level,
    // strength stacks — that's the Wyckoff "composite operator" footprint
    // becoming visible through multiple signatures of the same activity.
    //
    // _voteLevel(price, dir, strength, evidence, behavior)
    //   price:    the price level the vote is about
    //   dir:      1 = buyers defend (bullish at low / bearish at high broken)
    //             -1 = sellers defend
    //   strength: 1-10, how strong this evidence is by itself
    //   evidence: tag describing source ('absSeq', 'spring', 'OB', etc.)
    //   behavior: 'HOLDING' | 'FAILING' | 'DISCOVERED'
    //
    // Levels within 0.3 ATR cluster together. The vote map is reset per
    // bar (cleared before per-bar helpers run).

    _voteLevel(price, dir, strength, evidence, behavior, atr) {
        if(!atr || atr <= 0) return;
        if(price == null || !isFinite(price)) return;
        const tol = atr * 0.3;
        // Find existing level within tolerance
        let foundKey = null;
        for(const [k, v] of this.levelVotes){
            if(Math.abs(v.price - price) <= tol && v.dir === dir){
                foundKey = k;
                break;
            }
        }
        if(foundKey != null){
            const v = this.levelVotes.get(foundKey);
            // Stack: take the higher strength but add a small bonus per
            // additional confirming helper. 2 helpers = +1, 3+ = +2.
            const newCount = v.evidence.length + 1;
            // N7: base = strongest single piece of evidence; +1 at the 2nd
            // confirmation, +2 at the 3rd+ (capped). Replaces a convoluted
            // incremental formula that was hard to reason about.
            const stackBonus = Math.min(2, newCount - 1);
            v.strength = Math.min(10, Math.max(v.strength, strength) + stackBonus);
            v.evidence.push(evidence);
            // Refine price toward weighted center
            v.price = (v.price * v.evidence.length + price) / (v.evidence.length + 1);
            // Behavior precedence: HOLDING > DISCOVERED > FAILING
            if(behavior === 'HOLDING') v.behavior = 'HOLDING';
            else if(behavior === 'DISCOVERED' && v.behavior !== 'HOLDING') v.behavior = 'DISCOVERED';
        } else {
            // Use rounded price as key (snap to 0.5-ATR grid)
            const key = Math.round(price / Math.max(0.5, tol)) + ':' + dir;
            this.levelVotes.set(key, {
                price: price,
                dir: dir,
                strength: strength,
                behavior: behavior,
                evidence: [evidence]
            });
        }
    }

    // Get the strongest vote within a price window
    _getStrongestVote(centerPrice, windowAtr, atr) {
        if(!atr) return null;
        const window = atr * (windowAtr || 1.5);
        let best = null;
        for(const [k, v] of this.levelVotes){
            if(Math.abs(v.price - centerPrice) <= window){
                if(!best || v.strength > best.strength) best = v;
            }
        }
        return best;
    }

    // ════════════════════════════════════════════════════════════════
    // PATTERN HELPER DETECTORS
    // ════════════════════════════════════════════════════════════════
    // Each helper looks at the current bar (and recent bars) for a
    // specific footprint and votes on the relevant level. Helpers do
    // NOT emit named signals. They only update levelVotes.
    //
    // All take the standard bar context: c,h,l,o, atr, n=this.C.length
    // and the bar index (this.barIdx).

    // ── HELPER: Engulfing bar ─────────────────────────────────────
    // Current bar's body fully engulfs prior bar's body in opposite
    // direction. Strong intent change at the level of the engulf.
    _helperEngulfing(c, h, l, o, atr) {
        const n = this.C.length;
        if(n < 2 || atr <= 0) return;
        const pO = this.O[n-2], pC = this.C[n-2];
        const pBodyTop = Math.max(pO, pC);
        const pBodyBot = Math.min(pO, pC);
        const cBodyTop = Math.max(o, c);
        const cBodyBot = Math.min(o, c);
        // Bullish engulfing: prior bar bearish (pC<pO), current bar bullish (c>o), body engulfs
        if(pC < pO && c > o && cBodyTop >= pBodyTop && cBodyBot <= pBodyBot){
            const bodySize = c - o;
            if(bodySize > atr * 0.5){
                this._voteLevel(l, 1, 6, 'engulfBull', 'HOLDING', atr);
            }
        }
        // Bearish engulfing: prior bar bullish, current bar bearish, body engulfs
        if(pC > pO && c < o && cBodyTop >= pBodyTop && cBodyBot <= pBodyBot){
            const bodySize = o - c;
            if(bodySize > atr * 0.5){
                this._voteLevel(h, -1, 6, 'engulfBear', 'HOLDING', atr);
            }
        }
    }

    // ── HELPER: Pin bar / hammer / shooting star ──────────────────
    // Long wick on one side, small body on other. Rejection of an
    // attempted move beyond a level.
    _helperPinBar(c, h, l, o, atr) {
        if(atr <= 0) return;
        const range = h - l;
        if(range < atr * 0.6) return;
        const body = Math.abs(c - o);
        const upWick = h - Math.max(o, c);
        const dnWick = Math.min(o, c) - l;
        // Bullish pin (hammer): long lower wick, small body up top
        if(dnWick >= range * 0.6 && body <= range * 0.3 && upWick <= range * 0.2){
            this._voteLevel(l, 1, 5, 'pinBull', 'HOLDING', atr);
        }
        // Bearish pin (shooting star): long upper wick, small body at bottom
        if(upWick >= range * 0.6 && body <= range * 0.3 && dnWick <= range * 0.2){
            this._voteLevel(h, -1, 5, 'pinBear', 'HOLDING', atr);
        }
    }

    // ── HELPER: Inside bar ─────────────────────────────────────────
    // Current bar entirely inside prior bar's range. Coiling, often
    // precedes expansion. Doesn't vote a strong direction; it tags the
    // prior bar's range as a coil zone (handled by other helpers when
    // breakout occurs).
    _helperInsideBar(c, h, l, o, atr) {
        const n = this.C.length;
        if(n < 2) return;
        const pH = this.H[n-2], pL = this.L[n-2];
        if(h <= pH && l >= pL){
            // Inside bar — store flag. Other helpers will see this and
            // weight breakouts of the coil. Not a level vote by itself.
            this._lastInsideBar = this.barIdx;
        }
    }

    // ── HELPER: Climactic reversal ────────────────────────────────
    // Wide-range bar with high volume at trend extreme. Detects
    // rejection by WICK + LOCATION, not just close-vs-open direction.
    // A bar can have c==o or even c>o slightly and still be a textbook
    // climactic top if it wicks hard to a new high then settles in
    // the lower portion of the bar.
    //
    // Selling climax (SC, Wyckoff Phase A bottom): bar made recent low,
    //   then strong recovery wick (close in upper portion of bar).
    // Buying climax (BC, Wyckoff Phase A top): bar made recent high,
    //   then strong rejection wick (close in lower portion of bar).
    _helperClimax(c, h, l, o, atr, vol, avgVol) {
        const n = this.C.length;
        if(n < 6 || atr <= 0 || avgVol <= 0) return;
        const range = h - l;
        if(range <= 0) return;
        const wideBar = range > atr * 1.3;
        const highVol = vol > avgVol * 1.3;
        if(!wideBar || !highVol) return;
        const closePosition = (c - l) / range;
        // Check if this bar made an extreme of recent action
        const lookback = Math.min(20, n-1);
        const recentLow = Math.min.apply(null, this.L.slice(n-lookback, n));
        const recentHigh = Math.max.apply(null, this.H.slice(n-lookback, n));
        // ── PRECEDING-MOVE FILTER ──
        // A real Wyckoff selling climax requires a meaningful prior
        // DECLINE — climaxes mark the end of a move, so there must be
        // a move to end. Without this filter, any wide-range high-vol
        // bar that closes strong becomes a "climax," producing false
        // reversal signals on minor pullbacks within an uptrend.
        // Threshold: preceding 10-bar net move must be ≥ 3 ATR in the
        // opposite direction of the climax. (Selling climax needs a
        // prior decline ≥ 3 ATR; buying climax needs prior advance.)
        const precLook = Math.min(10, n-1);
        const precStartC = this.C[n-precLook-1] != null ? this.C[n-precLook-1] : this.C[0];
        const precMove = c - precStartC;  // negative = decline
        // Selling climax: bar made/equaled recent low, closed in upper half
        // (a long lower wick = sellers exhausted, buyers stepped in).
        // Requires preceding decline of at least 3 ATR.
        if(l <= recentLow + atr * 0.2 && closePosition >= 0.55 &&
           precMove <= -atr * 3){
            this._voteLevel(l, 1, 8, 'SC', 'HOLDING', atr);
            this.lastSC = { bar: this.barIdx, price: l };
            this.lastClimaxBar = this.barIdx;
        }
        // Buying climax: bar made/equaled recent high, closed in lower half.
        // Requires preceding advance of at least 3 ATR.
        if(h >= recentHigh - atr * 0.2 && closePosition <= 0.45 &&
           precMove >= atr * 3){
            this._voteLevel(h, -1, 8, 'BC', 'HOLDING', atr);
            this.lastBC = { bar: this.barIdx, price: h };
            this.lastClimaxBar = this.barIdx;
        }
    }

    // ── HELPER: Fair Value Gap (FVG) ──────────────────────────────
    // 3-bar imbalance: bar 1's high < bar 3's low (bullish gap) or
    // bar 1's low > bar 3's high (bearish gap). Price tends to revisit.
    _helperFVG(atr) {
        const n = this.C.length;
        if(n < 3 || atr <= 0) return;
        const h1 = this.H[n-3], l1 = this.L[n-3];
        const h3 = this.H[n-1], l3 = this.L[n-1];
        // Bullish FVG: gap UP between bar 1 and bar 3
        if(h1 < l3 && (l3 - h1) >= atr * 0.25){
            const top = l3, bot = h1;
            // Vote at the bottom (price will return to fill, support)
            this._voteLevel(bot, 1, 5, 'FVG_bull', 'HOLDING', atr);
            // Track for mitigation detection
            this.fvgZones.push({type:'BULL', top, bot, bar: this.barIdx, mitigated: false});
            if(this.fvgZones.length > 20) this.fvgZones.shift();
        }
        // Bearish FVG: gap DOWN between bar 1 and bar 3
        if(l1 > h3 && (l1 - h3) >= atr * 0.25){
            const top = l1, bot = h3;
            this._voteLevel(top, -1, 5, 'FVG_bear', 'HOLDING', atr);
            this.fvgZones.push({type:'BEAR', top, bot, bar: this.barIdx, mitigated: false});
            if(this.fvgZones.length > 20) this.fvgZones.shift();
        }
        // Vote on existing FVG zones the current bar is interacting with
        for(const fvg of this.fvgZones){
            if(fvg.mitigated) continue;
            const c = this.C[n-1];
            // Bullish FVG being tested as support: price drops into it, holds
            if(fvg.type === 'BULL' && this.L[n-1] <= fvg.top && c >= fvg.bot){
                this._voteLevel(fvg.bot, 1, 4, 'FVG_test_bull', 'HOLDING', atr);
            }
            if(fvg.type === 'BEAR' && this.H[n-1] >= fvg.bot && c <= fvg.top){
                this._voteLevel(fvg.top, -1, 4, 'FVG_test_bear', 'HOLDING', atr);
            }
            // Mitigated when price closes through the gap
            if(fvg.type === 'BULL' && c < fvg.bot) fvg.mitigated = true;
            if(fvg.type === 'BEAR' && c > fvg.top) fvg.mitigated = true;
        }
    }

    // ── HELPER: Order Block (OB) ──────────────────────────────────
    // The last opposing candle before a strong displacement move.
    // Bullish OB = last DOWN candle before a strong UP move.
    _helperOrderBlock(c, h, l, o, atr) {
        const n = this.C.length;
        if(n < 4 || atr <= 0) return;
        // Look for displacement on the current bar
        const range = h - l;
        const body = Math.abs(c - o);
        const wideBar = range > atr * 1.2;
        const strongBody = body > range * 0.6;
        if(!wideBar || !strongBody) return;
        const isBullDisplace = c > o;
        const isBearDisplace = c < o;
        // Find last opposing candle in last 3 bars
        for(let i = n-2; i >= Math.max(0, n-4); i--){
            const piO = this.O[i], piC = this.C[i];
            const piH = this.H[i], piL = this.L[i];
            if(isBullDisplace && piC < piO){
                // Last bearish candle before bull displacement → bullish OB
                this.orderBlocks.push({dir: 1, top: piH, bot: piL, bar: i, mitigated: false});
                this._voteLevel(piL, 1, 6, 'OB_bull', 'HOLDING', atr);
                break;
            }
            if(isBearDisplace && piC > piO){
                this.orderBlocks.push({dir: -1, top: piH, bot: piL, bar: i, mitigated: false});
                this._voteLevel(piH, -1, 6, 'OB_bear', 'HOLDING', atr);
                break;
            }
        }
        if(this.orderBlocks.length > 15) this.orderBlocks.shift();
        // Vote on existing OBs being retested
        for(const ob of this.orderBlocks){
            if(ob.mitigated) continue;
            if(ob.dir === 1 && l <= ob.top && c >= ob.bot){
                this._voteLevel((ob.top+ob.bot)/2, 1, 5, 'OB_retest_bull', 'HOLDING', atr);
            }
            if(ob.dir === -1 && h >= ob.bot && c <= ob.top){
                this._voteLevel((ob.top+ob.bot)/2, -1, 5, 'OB_retest_bear', 'HOLDING', atr);
            }
            // Mitigated when price closes decisively past it
            if(ob.dir === 1 && c < ob.bot - atr*0.3) ob.mitigated = true;
            if(ob.dir === -1 && c > ob.top + atr*0.3) ob.mitigated = true;
        }
    }

    // ── HELPER: Swing Failure Pattern (SFP) ───────────────────────
    // Two flavors of failure:
    //
    // CLASSIC SFP (against a tracked swing): wick breaks recent swing
    //   high/low, bar closes back inside. Wyckoff Spring (low) or
    //   Upthrust (high).
    //
    // FRESH REJECTION (no specific swing needed): bar made the recent
    //   extreme high or low and rejected hard with strong wick. Even
    //   if the close is still beyond the prior swing, the wick + close
    //   position tells the story. This catches the V-top / V-bottom
    //   case where price goes well past the prior swing then reverses.
    _helperSFP(c, h, l, atr) {
        const n = this.C.length;
        if(n < 5 || atr <= 0) return;
        const range = h - l;
        if(range <= 0) return;
        const closePosition = (c - l) / range;

        // Look at recent extremes (last 15 bars exc. current)
        const lookback = Math.min(15, n-1);
        let recentHigh = -Infinity, recentLow = Infinity;
        for(let i = n-lookback-1; i < n-1; i++){
            if(i < 0) continue;
            if(this.H[i] > recentHigh) recentHigh = this.H[i];
            if(this.L[i] < recentLow) recentLow = this.L[i];
        }

        // CLASSIC SFP at swing high (Upthrust)
        if(this.swingHighs.length > 0){
            const lastSH = this.swingHighs[this.swingHighs.length-1];
            if(h > lastSH.price + atr * 0.2 && c < lastSH.price - atr * 0.1){
                this._voteLevel(lastSH.price, -1, 9, 'SFP_high', 'HOLDING', atr);
                this.lastUTADBar = this.barIdx;
            }
        }
        // CLASSIC SFP at swing low (Spring)
        if(this.swingLows.length > 0){
            const lastSL = this.swingLows[this.swingLows.length-1];
            if(l < lastSL.price - atr * 0.2 && c > lastSL.price + atr * 0.1){
                this._voteLevel(lastSL.price, 1, 9, 'SFP_low', 'HOLDING', atr);
                this.lastSpringBar = this.barIdx;
            }
        }

        // FRESH REJECTION at extreme — bar made (or matched) recent
        // extreme high/low and closed in far half of bar away from
        // extreme. Tight margin (0.2 ATR) — must be a clear rejection
        // at the extreme, not just a bar in the area. Looser margins
        // produce false Spring/UTAD detections during normal swings.
        // Also requires a meaningful preceding move in the OPPOSITE
        // direction — a Spring needs a prior decline being absorbed,
        // a UTAD needs a prior advance being capped. Without this,
        // any wide-range strong-close bar in chop becomes a "Wyckoff
        // event" and supports false reversal trades.
        const _sfpPrecLook = Math.min(8, n-1);
        const _sfpPrecStart = this.C[n-_sfpPrecLook-1] != null ? this.C[n-_sfpPrecLook-1] : this.C[0];
        const _sfpPrecMove = c - _sfpPrecStart;
        // Bar made highest high (or matched it) and rejected — UTAD memory.
        // Requires preceding 8-bar net advance ≥ 4 ATR. Real UTADs cap a
        // sustained advance, not minor uptrends ending in 1-bar pullbacks.
        if(h >= recentHigh - atr * 0.2 && closePosition <= 0.4 && range > atr * 0.8 &&
           _sfpPrecMove >= atr * 4){
            this._voteLevel(h, -1, 8, 'rejectHi', 'HOLDING', atr);
            this.lastUTADBar = this.barIdx;
        }
        // Bar made lowest low (or matched it) and rejected — Spring memory.
        // Requires preceding 8-bar net decline ≥ 4 ATR.
        if(l <= recentLow + atr * 0.2 && closePosition >= 0.6 && range > atr * 0.8 &&
           _sfpPrecMove <= -atr * 4){
            this._voteLevel(l, 1, 8, 'rejectLo', 'HOLDING', atr);
            this.lastSpringBar = this.barIdx;
        }
    }

    // ── HELPER: Three-bar reversal ────────────────────────────────
    // Three consecutive bars where bar 2 makes the extreme and bars 1
    // and 3 are on opposite sides of it. Rejection at the apex.
    _helperThreeBar(atr) {
        const n = this.C.length;
        if(n < 3 || atr <= 0) return;
        const c1 = this.C[n-3], c2 = this.C[n-2], c3 = this.C[n-1];
        const h1 = this.H[n-3], h2 = this.H[n-2], h3 = this.H[n-1];
        const l1 = this.L[n-3], l2 = this.L[n-2], l3 = this.L[n-1];
        // Bullish three-bar reversal: bar 2 makes new low, bar 3 closes above bar 1's high
        if(l2 < l1 - atr*0.1 && l2 < l3 - atr*0.1 && c3 > h1){
            this._voteLevel(l2, 1, 6, '3bar_bull', 'HOLDING', atr);
        }
        // Bearish three-bar reversal: bar 2 makes new high, bar 3 closes below bar 1's low
        if(h2 > h1 + atr*0.1 && h2 > h3 + atr*0.1 && c3 < l1){
            this._voteLevel(h2, -1, 6, '3bar_bear', 'HOLDING', atr);
        }
    }

    // ── HELPER: Run all helpers (called per bar) ──────────────────
    // Resets levelVotes, then runs each detector. Must be called BEFORE
    // the framework readers consume votes.
    _runHelpers(c, h, l, o, vol, atr, avgVol) {
        // Don't reset — votes from confirmed bases / sweep / absorption
        // (existing detectors) should also feed in. We add new helpers
        // ON TOP. Reset is per-bar at start of map().
        this._helperEngulfing(c, h, l, o, atr);
        this._helperPinBar(c, h, l, o, atr);
        this._helperInsideBar(c, h, l, o, atr);
        this._helperClimax(c, h, l, o, atr, vol, avgVol);
        this._helperFVG(atr);
        this._helperOrderBlock(c, h, l, o, atr);
        this._helperSFP(c, h, l, atr);
        this._helperThreeBar(atr);

        // Also: relay existing legacy-detector state into the vote map
        // so the unified read sees ALL evidence. This is the bridge from
        // the old system (named signals) to the new one (level votes).
        if(this.absSeqDir !== 0 && this.absSeqBars >= 3 && this.absSeqLevel > 0){
            const score = Math.min(8, 4 + this.absSeqBars);
            this._voteLevel(this.absSeqLevel, this.absSeqDir, score,
                'absSeq×'+this.absSeqBars, 'HOLDING', atr);
        }
        if(this.jhookActive && this.jhookDir !== 0 && this.jhookLevel > 0){
            this._voteLevel(this.jhookLevel, this.jhookDir, 8,
                'jhook', 'HOLDING', atr);
        }
        if(this.sweepDir !== 0 && this.sweepBar > 0 &&
           this.barIdx - this.sweepBar <= 4 && this.sweepLevel > 0){
            const fresh = this.barIdx - this.sweepBar;
            const score = fresh === 0 ? 9 : fresh <= 2 ? 8 : 7;
            const tag = this.sweepDir === 1 ? 'spring' : 'upthrust';
            this._voteLevel(this.sweepLevel, this.sweepDir, score,
                tag, 'HOLDING', atr);
        }
        if(this.steppingIn && this.steppingInDir !== 0){
            const stepLevel = this.steppingInDir === 1 ? l : h;
            this._voteLevel(stepLevel, this.steppingInDir, 5,
                'steppingIn', 'HOLDING', atr);
        }
    }

    _readAuction(c, h, l, atr, levels, nearLevel, nearDist){
        const result = { dir: 0, score: 0, reason: '' };
        if(this.exp1H <= 0) return result;

        // ════════════════════════════════════════════════════════════
        // PROPER AUCTION THEORY STATE DETECTION
        // ════════════════════════════════════════════════════════════
        // Three auction states:
        //   BALANCE   — two-sided market, value being built (range-bound)
        //   ROTATION  — price returning to recent value after extension
        //   DISCOVERY — price extending away from value, seeking new value
        //
        // Each state has its own directional bias logic. Computed from
        // existing data: wickZones, balanceClusters, confirmedBases (J-hooks),
        // sigma bands, and recent range/expansion.
        const n = this.C.length;
        const state = this._classifyAuctionState(c, h, l, atr, n);
        // store for diagnostics + thesis check etc.
        this.auctionState = state.state;
        this.auctionStateBias = state.bias;
        this.auctionStateReason = state.reason;

        // High-confidence reads from auction state (override level-based logic)
        if(state.bias !== 0 && state.score >= 7){
            result.dir = state.bias;
            result.score = state.score;
            result.reason = state.reason;
            return result;
        }

        // ════════════════════════════════════════════════════════════
        // FALLBACK: LEVEL-BASED CLASSIFICATION
        // ════════════════════════════════════════════════════════════
        // If state-based read was weak, fall through to the original
        // level-based logic. This preserves the level reads (sigma fades,
        // wick zone signals, JHOOK retests, MTT zones) that already work.
        const lt = nearLevel ? nearLevel.type : '';
        const atLvl = nearLevel && nearDist <= atr*1.5;
        // If state had a moderate read and we're at a level, blend them:
        // use level for direction but bump score based on state agreement
        const stateBoost = (level_dir) => {
            if(state.bias === level_dir && state.score >= 4) return Math.min(2, state.score - 3);
            if(state.bias === -level_dir && state.score >= 4) return -Math.min(2, state.score - 3);
            return 0;
        };
        // Sigma extremes — auction theory says price doesn't stay at sigmas
        if(atLvl){
            // 2-3 sigma extremes are strongest fade signals
            if(lt==='3σH' || lt==='4σH'){ result.dir=-1; result.score=9; result.reason='extreme σ high'; return result; }
            if(lt==='3σL' || lt==='4σL'){ result.dir=1; result.score=9; result.reason='extreme σ low'; return result; }
            if(lt==='2σH'){ result.dir=-1; result.score=7; result.reason='2σH'; return result; }
            if(lt==='2σL'){ result.dir=1; result.score=7; result.reason='2σL'; return result; }
            if(lt==='1σH'){
                // 1σH is a fade in balance, but a continuation entry from above
                if(c >= this.exp1H && this.mktState==='TRENDING_UP'){
                    result.dir=1; result.score=6; result.reason='above 1σH continuation'; return result;
                }
                result.dir=-1; result.score=5; result.reason='1σH fade';
                return result;
            }
            if(lt==='1σL'){
                if(c <= this.exp1L && this.mktState==='TRENDING_DN'){
                    result.dir=-1; result.score=6; result.reason='below 1σL continuation'; return result;
                }
                result.dir=1; result.score=5; result.reason='1σL fade';
                return result;
            }
            // Wick zones — Wick Sauce method. Bullish zones = buy, bearish = sell
            if(lt==='BWICK' || lt==='BWICK_INV' || lt==='BAL_L'){
                result.dir=1;
                result.score = (lt==='BWICK_INV') ? 8 : 6;
                result.reason = lt;
                return result;
            }
            if(lt==='SWICK' || lt==='SWICK_INV' || lt==='BAL_H'){
                result.dir=-1;
                result.score = (lt==='SWICK_INV') ? 8 : 6;
                result.reason = lt;
                return result;
            }
            // Balance midpoint — neutral
            if(lt==='BAL_M'){ result.dir=0; result.score=2; result.reason='balance EQ'; return result; }
            // Prior session/day/week levels — moderate signal
            if(lt==='PSH' || lt==='PWH' || lt==='PDH'){ result.dir=-1; result.score=5; result.reason=lt+' resistance'; return result; }
            if(lt==='PSL' || lt==='PWL' || lt==='PDL'){ result.dir=1; result.score=5; result.reason=lt+' support'; return result; }
            if(lt==='AH'){ result.dir=-1; result.score=4; result.reason='Asia high'; return result; }
            if(lt==='AL'){ result.dir=1; result.score=4; result.reason='Asia low'; return result; }
            // ── MULTI-TOUCH ZONES ──
            // The more touches at the same level, the more trapped traders
            // are at it. 2 touches = double top/bottom (s7). 3 = triple (s8).
            // 4+ = strongly defended (s9). These are the user's "supply
            // can't push higher" / "demand can't push lower" patterns.
            if(lt==='MTT_H'){
                const touches = nearLevel.touches || 2;
                const score = Math.min(9, 5 + touches);
                result.dir = -1;
                result.score = score;
                result.reason = touches+'-touch top';
                return result;
            }
            if(lt==='MTT_L'){
                const touches = nearLevel.touches || 2;
                const score = Math.min(9, 5 + touches);
                result.dir = 1;
                result.score = score;
                result.reason = touches+'-touch bottom';
                return result;
            }
            // ── JHOOK LEVELS (confirmed base/ceiling from absorption) ──
            // Score based on how strong the original base was (more bars = stronger).
            // Base score 7 (already proven once), +1 per extra bar over 3.
            if(lt==='JHOOK_L'){
                const bars = nearLevel.bars || 3;
                const score = Math.min(9, 6 + Math.min(3, bars-2));
                result.dir = 1;
                result.score = score;
                result.reason = bars+'b base retest';
                return result;
            }
            if(lt==='JHOOK_H'){
                const bars = nearLevel.bars || 3;
                const score = Math.min(9, 6 + Math.min(3, bars-2));
                result.dir = -1;
                result.score = score;
                result.reason = bars+'b ceiling retest';
                return result;
            }
            // ── RECENT SWING HIGH/LOW ──
            // A single recent swing isn't as reliable as MTT (cluster of 2+)
            // but it's still a real structural reference. In an aligned
            // trend, the most recent swing high/low after a pullback is
            // where continuation entries trigger.
            if(lt==='SH'){
                // Swing high = potential resistance/short
                // BUT in markup trend, breaking above SH = continuation long
                if(c > nearLevel.price && this.mktState==='TRENDING_UP'){
                    result.dir = 1; result.score = 6;
                    result.reason = 'SH break (continuation)';
                    return result;
                }
                result.dir = -1; result.score = 4;
                result.reason = 'SH resistance';
                return result;
            }
            if(lt==='SL'){
                // Swing low = potential support/long
                // In markdown trend, breaking below SL = continuation short
                if(c < nearLevel.price && this.mktState==='TRENDING_DN'){
                    result.dir = -1; result.score = 6;
                    result.reason = 'SL break (continuation)';
                    return result;
                }
                result.dir = 1; result.score = 4;
                result.reason = 'SL support';
                return result;
            }
            if(lt==='VWAP'){
                // VWAP — direction depends on if we're trending up or down vs it
                if(this.mktState==='TRENDING_UP'){ result.dir=1; result.score=4; result.reason='VWAP support'; return result; }
                if(this.mktState==='TRENDING_DN'){ result.dir=-1; result.score=4; result.reason='VWAP resistance'; return result; }
                result.dir=0; result.score=3; result.reason='VWAP neutral'; return result;
            }
        }
        // Not at level — auction has nothing to say
        return result;
    }

    // ── STRUCTURE READER ────────────────────────────────────────────
    // Reads market structure: higher highs/lows = bull intact;
    // lower highs/lows = bear intact; broken structure = transition.
    // h1 trend gives macro context, swing levels give micro structure.
    _readStructure(c, h, l, atr){
        const result = { dir: 0, score: 0, reason: '' };

        // ── BREAK-OF-STRUCTURE OVERRIDE ─────────────────────────────
        // If price recently broke a swing high or low decisively, that
        // signals a structural shift NOW — h1/h4 candles are slow to
        // reflect this. When BOS is active (within last ~20 bars), it
        // takes precedence over lagging higher-timeframe trend reads.
        //
        // Strength of BOS reading depends on freshness:
        //   • 0-5 bars after break: very fresh, score 8-9
        //   • 5-12 bars after break: confirmed, score 7
        //   • 12-20 bars after break: aging, score 5-6
        //   • >20 bars: BOS expires, normal logic resumes
        if(this.bosDir !== 0 && this.bosTriggerBar > 0){
            const barsSinceBOS = this.barIdx - this.bosTriggerBar;
            if(barsSinceBOS <= 20){
                let bosScore;
                let freshness;
                if(barsSinceBOS <= 5){
                    bosScore = 9; freshness = 'fresh';
                } else if(barsSinceBOS <= 12){
                    bosScore = 7; freshness = 'confirmed';
                } else {
                    bosScore = 5; freshness = 'aging';
                }
                result.dir = this.bosDir;
                result.score = bosScore;
                result.reason = 'BOS '+(this.bosDir===1?'up':'down')+
                                ' '+freshness+'@'+this.bosBrokeLevel.toFixed(2);
                return result;
            }
        }

        // h1 candles trend (medium-term)
        const h1Bull = this.h1Trend==='BULL' || this.h1HigherLow;
        const h1Bear = this.h1Trend==='BEAR' || this.h1LowerHigh;
        // h4 broader trend
        const h4Bull = this.h4Trend==='BULL' || this.h4Dir===1;
        const h4Bear = this.h4Trend==='BEAR' || this.h4Dir===-1;
        // Swing structure (intraday)
        const sH = this.swingHighs;
        const sL = this.swingLows;
        let swingTrend = 0;
        if(sH.length>=2 && sL.length>=2){
            const lastSH = sH[sH.length-1].price;
            const prevSH = sH[sH.length-2].price;
            const lastSL = sL[sL.length-1].price;
            const prevSL = sL[sL.length-2].price;
            if(lastSH > prevSH && lastSL > prevSL) swingTrend = 1;     // HH+HL = bull
            else if(lastSH < prevSH && lastSL < prevSL) swingTrend = -1; // LH+LL = bear
        }
        // Combine: h1 + h4 + swing all aligned = strongest
        let dir = 0, score = 0, reasons = [];
        if(h1Bull && h4Bull && swingTrend===1){ dir=1; score=9; reasons.push('full bull alignment'); }
        else if(h1Bear && h4Bear && swingTrend===-1){ dir=-1; score=9; reasons.push('full bear alignment'); }
        else if(h1Bull && swingTrend===1){ dir=1; score=7; reasons.push('h1+swing bull'); }
        else if(h1Bear && swingTrend===-1){ dir=-1; score=7; reasons.push('h1+swing bear'); }
        else if(h1Bull && h4Bull){ dir=1; score=6; reasons.push('h1+h4 bull'); }
        else if(h1Bear && h4Bear){ dir=-1; score=6; reasons.push('h1+h4 bear'); }
        else if(h1Bull){ dir=1; score=4; reasons.push('h1 bull'); }
        else if(h1Bear){ dir=-1; score=4; reasons.push('h1 bear'); }
        else if(swingTrend!==0){ dir=swingTrend; score=3; reasons.push('swing only'); }
        // Bonus: live h1 candle direction agrees with macro
        if(this.h1O>0){
            const h1LiveDir = c >= this.h1O ? 1 : -1;
            if(dir!==0 && h1LiveDir === dir){
                score = Math.min(10, score+1);
                reasons.push('h1 live confirms');
            }
        }
        // Penalty: at a structural pivot (mktState=TRANSITIONING) = lower confidence
        if(this.mktState==='TRANSITIONING'){
            score = Math.max(0, score-3);
            reasons.push('TRANSITIONING penalty');
        }
        result.dir = dir;
        result.score = score;
        result.reason = reasons.join('+');
        return result;
    }

    // ── ORDERFLOW READER ────────────────────────────────────────────
    // Reads who's winning the aggression: delta direction, volume profile,
    // exhaustion patterns, absorption, wick rejections on current bar.
    _readOrderflow(c, h, l, o, vol, delta, atr, avgVol, n){
        const result = { dir: 0, score: 0, reason: '' };
        let dir = 0, score = 0, reasons = [];
        // 1. Current bar wick — strongest direct read
        const body = Math.abs(c-o);
        const upWick = h - Math.max(o,c);
        const dnWick = Math.min(o,c) - l;
        const wickMin = atr * 0.6;
        if(dnWick >= wickMin && dnWick > body*0.5){
            dir = 1; score += 4; reasons.push('lower wick rejection');
        }
        if(upWick >= wickMin && upWick > body*0.5){
            // If both wicks present, take the bigger one
            if(score === 0 || upWick > dnWick){
                dir = -1; score = 4; reasons.length = 0; reasons.push('upper wick rejection');
            }
        }
        // 2. Delta direction confirms or fights
        const minFlip = avgVol * 0.08;
        if(dir === 1){
            if(delta > minFlip){ score += 2; reasons.push('delta up'); }
            else if(delta < -minFlip*2){ score = Math.max(0, score-2); reasons.push('delta fights'); }
        } else if(dir === -1){
            if(delta < -minFlip){ score += 2; reasons.push('delta down'); }
            else if(delta > minFlip*2){ score = Math.max(0, score-2); reasons.push('delta fights'); }
        } else {
            // No wick yet — delta alone gives weak signal
            if(n>=2){
                const prevD = this.D[n-2];
                const dfBull = prevD < -minFlip && delta > minFlip;
                const dfBear = prevD > minFlip && delta < -minFlip;
                if(dfBull){ dir=1; score=5; reasons.push('delta flip bull'); }
                else if(dfBear){ dir=-1; score=5; reasons.push('delta flip bear'); }
            }
        }
        // 3. Absorption — small range + high volume + delta fighting price
        const range = h - l;
        if(range < atr*0.65 && vol > avgVol*1.3){
            if(delta < 0 && c >= o){ // selling absorbed by buyers
                if(dir===0 || dir===1){ dir = 1; score += 2; reasons.push('absorption bull'); }
            } else if(delta > 0 && c <= o){ // buying absorbed by sellers
                if(dir===0 || dir===-1){ dir = -1; score += 2; reasons.push('absorption bear'); }
            }
        }
        // 3b. Multi-bar absorption sequence (the U-shape pattern)
        // 3+ consecutive bars rejecting the same level = strong signal
        // even without single-bar absorption qualifying.
        if(this.absSeqBars >= 3 && this.absSeqDir !== 0){
            const seqScore = Math.min(8, 4 + this.absSeqBars);  // 3bars=7, 4bars=8, 5+=8
            if(this.absSeqDir === 1 && (dir === 0 || dir === 1)){
                dir = 1;
                score = Math.max(score, seqScore);
                reasons.push(this.absSeqBars+'bar abs base');
            } else if(this.absSeqDir === -1 && (dir === 0 || dir === -1)){
                dir = -1;
                score = Math.max(score, seqScore);
                reasons.push(this.absSeqBars+'bar abs top');
            }
        }
        // 3c. Demand/supply stepping in — the J-hook recovery trigger.
        // After absorption forms a base/ceiling, this fires when continuation
        // bars start: bigger bodies, vol pickup, delta turning. Highest-edge
        // entry because we have BOTH base confirmation AND directional push.
        if(this.steppingIn && this.steppingInDir !== 0){
            if(this.steppingInDir === 1 && (dir === 0 || dir === 1)){
                dir = 1;
                score = Math.max(score, 7);  // strong because base + push
                reasons.push('demand stepping in');
            } else if(this.steppingInDir === -1 && (dir === 0 || dir === -1)){
                dir = -1;
                score = Math.max(score, 7);
                reasons.push('supply stepping in');
            }
        }
        // 3d. J-HOOK RETEST — current bar at confirmed prior base, holding.
        // This is the textbook J-hook trade: base formed, price ran up,
        // came back to retest the base, and is holding above the floor.
        // Highest-edge entry because the prior base is PROVEN — sellers
        // already failed to break it once. Score 8 to easily clear threshold.
        if(this.jhookActive && this.jhookDir !== 0){
            if(this.jhookDir === 1 && (dir === 0 || dir === 1)){
                dir = 1;
                score = Math.max(score, 8);
                reasons.push('jhook retest base');
            } else if(this.jhookDir === -1 && (dir === 0 || dir === -1)){
                dir = -1;
                score = Math.max(score, 8);
                reasons.push('jhook retest ceiling');
            }
        }
        // 3e. LIQUIDITY SWEEP — fresh sweep + reversal signal.
        // When the recent bar wicked through a swing level and closed
        // back, the reversal direction is the high-edge trade. Trapped
        // breakout traders are now on the wrong side — that's fuel for
        // the reversal. Score 9 because sweeps are among the highest-edge
        // setups in the playbook (compared to clean rejections).
        if(this.sweepDir !== 0 && this.sweepBar > 0 &&
           this.barIdx - this.sweepBar <= 4){
            const sweepFresh = this.barIdx - this.sweepBar;
            // Score decays slightly with age: bar 0=9, bar 1=8, bar 2-3=7, bar 4=6
            const sweepScore = sweepFresh === 0 ? 9 : sweepFresh === 1 ? 8 :
                               sweepFresh <= 3 ? 7 : 6;
            if(this.sweepDir === 1 && (dir === 0 || dir === 1)){
                dir = 1;
                score = Math.max(score, sweepScore);
                reasons.push('liq sweep low → long');
            } else if(this.sweepDir === -1 && (dir === 0 || dir === -1)){
                dir = -1;
                score = Math.max(score, sweepScore);
                reasons.push('liq sweep high → short');
            }
        }
        // 4. Volume confirmation on direction
        if(this.volConfirm && dir!==0){
            score += 1; reasons.push('vol confirms');
        }
        // 5. Exhaustion — if exhBars sequence shows fade, reverse signal
        if(this.exhBars.length >= 5){
            const eb = this.exhBars;
            const first = eb[0], last = eb[eb.length-1];
            const fading = first.range > last.range*1.25 &&
                          (first.vol > last.vol*1.2 || Math.abs(first.delta) > Math.abs(last.delta)*1.2);
            if(fading){
                // Reverse the exhausted direction
                if(this.exhDir===1 && dir!==1){ dir=-1; score = Math.max(score, 5); reasons.push('exhausted bull → short'); }
                else if(this.exhDir===-1 && dir!==-1){ dir=1; score = Math.max(score, 5); reasons.push('exhausted bear → long'); }
            }
        }
        // Cap and return
        score = Math.min(10, score);
        result.dir = dir;
        result.score = score;
        result.reason = reasons.join('+');
        return result;
    }

    // ── COMBINE READINGS ────────────────────────────────────────────
    // Decision rules (per user spec):
    //   • 3-of-3 agree on direction at any level → fire (high conviction)
    //   • 2-of-3 agree at strong level (sigma σH/σL or wick zone) → fire
    //   • Otherwise → no fire
    //
    // Returns {fire:bool, dir, totalScore, setupTag, reason}
    _combineReadings(auction, structure, orderflow, nearLevel, atLvl){
        const result = { fire: false, dir: 0, totalScore: 0, setupTag: '', reason: '' };
        if(!atLvl || !nearLevel) return result;
        const lt = nearLevel.type;

        const auctionDir = auction.dir;
        const structDir = structure.dir;
        const flowDir = orderflow.dir;

        // Tally votes per direction
        let bullVotes = 0, bearVotes = 0;
        const bullScores = [];
        const bearScores = [];
        const reasons = [];
        if(auctionDir === 1){ bullVotes++; bullScores.push(auction.score); reasons.push('A:'+auction.reason); }
        else if(auctionDir === -1){ bearVotes++; bearScores.push(auction.score); reasons.push('A:'+auction.reason); }
        if(structDir === 1){ bullVotes++; bullScores.push(structure.score); reasons.push('S:'+structure.reason); }
        else if(structDir === -1){ bearVotes++; bearScores.push(structure.score); reasons.push('S:'+structure.reason); }
        if(flowDir === 1){ bullVotes++; bullScores.push(orderflow.score); reasons.push('F:'+orderflow.reason); }
        else if(flowDir === -1){ bearVotes++; bearScores.push(orderflow.score); reasons.push('F:'+orderflow.reason); }

        // Determine winning side
        let dir = 0, votes = 0, scores = [];
        if(bullVotes > bearVotes){ dir = 1; votes = bullVotes; scores = bullScores; }
        else if(bearVotes > bullVotes){ dir = -1; votes = bearVotes; scores = bearScores; }
        // Don't early-return on tie — fall through, the Wyckoff override
        // logic below may still set a direction based on a recent
        // structural event (BC, UTAD, SC, Spring) that the framework
        // readers haven't yet caught up to.

        // Average score for the winning side (initial, before override)
        let avgScore = scores.length > 0 ? scores.reduce((a,b)=>a+b,0) / scores.length : 0;

        // ── WYCKOFF EVENT OVERRIDE ──────────────────────────────────
        // Before the routine level-vote consultation, check for a STRONG
        // opposite-direction Wyckoff signature: a stacked level vote with
        // ≥9 strength against the framework consensus. That's a Spring,
        // UTAD, climax, or stacked SFP — explicit reversal evidence so
        // strong it can override the still-trending readers.
        //
        // Without this, the indicator stays long all the way through a
        // V-top because the framework readers lag. The Wyckoff event IS
        // the moment of reversal — by definition the readers haven't
        // updated yet.
        let wyckoffOverride = null;
        if(this.levelVotes && this.levelVotes.size > 0){
            const cur = this.C[this.C.length-1] || nearLevel.price;
            const atrLocal = this.atr || 1;
            for(const [k, v] of this.levelVotes){
                if(v.dir === dir) continue;  // only opposite-direction
                if(Math.abs(v.price - cur) > atrLocal * 2) continue;
                if(v.strength < 9) continue;
                // Must have at least 2 stacked pieces of evidence
                if(v.evidence.length < 2) continue;
                if(!wyckoffOverride || v.strength > wyckoffOverride.strength){
                    wyckoffOverride = v;
                }
            }
        }
        // ALSO check recent (last 15 bars) Wyckoff events. A buying climax
        // at bar 45 should still bias away from longs at bar 60. The
        // event itself doesn't decay quickly — it marked a structural top.
        // 15-bar window matches the "structural topping" timeframe — even
        // if price retraces and approaches the level again days/hours later
        // on a tick chart, the original rejection is still meaningful.
        const recentWyckoffWindow = 15;
        let recentEventDir = 0;
        let recentEventBar = -1;
        let recentEventTag = '';
        if(this.lastBC && this.barIdx - this.lastBC.bar <= recentWyckoffWindow){
            recentEventDir = -1;  // BC = bearish bias
            recentEventBar = this.lastBC.bar;
            recentEventTag = 'BC';
        }
        if(this.lastSC && this.barIdx - this.lastSC.bar <= recentWyckoffWindow){
            // Only override if this is more recent than BC
            if(recentEventBar < 0 || this.lastSC.bar > recentEventBar){
                recentEventDir = 1;  // SC = bullish bias
                recentEventBar = this.lastSC.bar;
                recentEventTag = 'SC';
            }
        }
        if(this.lastUTADBar > 0 && this.barIdx - this.lastUTADBar <= recentWyckoffWindow){
            if(recentEventBar < 0 || this.lastUTADBar > recentEventBar){
                recentEventDir = -1;
                recentEventBar = this.lastUTADBar;
                recentEventTag = 'UTAD';
            }
        }
        if(this.lastSpringBar > 0 && this.barIdx - this.lastSpringBar <= recentWyckoffWindow){
            if(recentEventBar < 0 || this.lastSpringBar > recentEventBar){
                recentEventDir = 1;
                recentEventBar = this.lastSpringBar;
                recentEventTag = 'Spring';
            }
        }
        if(wyckoffOverride){
            // Flip the trade direction. Reset votes/scores to be just
            // the level vote (the readers got it wrong, so we don't
            // want to average their wrong scores in).
            dir = wyckoffOverride.dir;
            votes = 1;
            scores = [wyckoffOverride.strength];
            reasons.push('W_OVERRIDE:'+(dir===1?'spring/SC':'UTAD/BC')+
                         '@'+wyckoffOverride.strength+
                         '['+wyckoffOverride.evidence.slice(0,4).join(',')+']');
            // Recompute avgScore after override
            avgScore = wyckoffOverride.strength;
        } else if(recentEventDir !== 0 && recentEventDir !== dir){
            // Recent Wyckoff event opposes the trade direction.
            // If FRESH (within 5 bars), flip the trade — the structural
            // reversal just happened and we want to take the new direction.
            // If older (5-12 bars), just block — the move may already be
            // far along and we don't want to chase.
            const eventAge = this.barIdx - recentEventBar;
            if(eventAge <= 5){
                // Fresh event — flip direction
                dir = recentEventDir;
                votes = 1;
                scores = [7];
                avgScore = 7;
                reasons.push('FLIP_FROM_RECENT_'+recentEventTag+
                             '@age='+eventAge);
                this._recentWyckoffBlocks = false;
            } else {
                // Older event — block opposing trade
                reasons.push('RECENT_'+recentEventTag+'_BLOCKS_'+
                             (dir===1?'long':'short')+'@age='+eventAge);
                this._recentWyckoffBlocks = true;
            }
        } else if(recentEventDir !== 0 && recentEventDir === dir){
            // Recent Wyckoff event AGREES with the direction. Boost.
            reasons.push('RECENT_'+recentEventTag+'_SUPPORTS_'+(dir===1?'long':'short'));
            scores.push(8);
            votes++;
            avgScore = scores.reduce((a,b)=>a+b,0) / scores.length;
            this._recentWyckoffBlocks = false;
        } else {
            this._recentWyckoffBlocks = false;
        }
        // ── ENTRY IN DIRECTION OF RECENT WYCKOFF EVENT ─────────────
        // A recent BC/UTAD/SC/Spring is a structural reversal signal.
        // After the event, we WANT to fire trades in the event's
        // direction even if the framework readers haven't fully caught
        // up yet. If the readers are tied (votes=0) but a recent event
        // supports a direction, fire in that direction at strong levels.
        if(votes === 0 && recentEventDir !== 0 &&
           atLvl && nearLevel){
            const lt2 = nearLevel.type;
            const isStrong2 = lt2.includes('σ') || lt2==='BWICK' || lt2==='SWICK' ||
                              lt2==='BWICK_INV' || lt2==='SWICK_INV' ||
                              lt2==='BAL_H' || lt2==='BAL_L' ||
                              lt2==='MTT_H' || lt2==='MTT_L' ||
                              lt2==='JHOOK_L' || lt2==='JHOOK_H';
            if(isStrong2){
                dir = recentEventDir;
                votes = 1;
                scores = [7];
                avgScore = 7;
                reasons.push('FIRE_FROM_RECENT_'+recentEventTag);
            }
        }

        // ── LEVEL VOTE CONSULTATION (4th vote source) ──────────────
        // The level vote map aggregates evidence from helper detectors
        // (engulfing, pin bar, climax, FVG, OB, SFP, etc., plus relays
        // from absSeq/jhook/sweep/steppingIn). When a strongly-stacked
        // vote aligns with the trade direction at a nearby level, that's
        // independent confirmation worth a vote of its own.
        const votesBeforeLevel = votes;   // N3: framework/Wyckoff breadth BEFORE the helper vote
        let levelVoteAdded = false;
        let levelVoteStrength = 0;
        let levelVoteEvidence = [];
        if(this.levelVotes && this.levelVotes.size > 0){
            const cur = this.C[this.C.length-1] || nearLevel.price;
            const atrLocal = this.atr || 1;
            // Find strongest vote in same direction within 1.5 ATR
            let bestVote = null;
            for(const [k, v] of this.levelVotes){
                if(v.dir !== dir) continue;
                if(Math.abs(v.price - cur) > atrLocal * 1.5) continue;
                if(!bestVote || v.strength > bestVote.strength) bestVote = v;
            }
            if(bestVote && bestVote.strength >= 6){
                // Stacked level vote acts as a 4th vote
                votes++;
                scores.push(bestVote.strength);
                reasons.push('L:'+bestVote.behavior+'@'+bestVote.strength+
                             '['+bestVote.evidence.slice(0,4).join(',')+']');
                levelVoteAdded = true;
                levelVoteStrength = bestVote.strength;
                levelVoteEvidence = bestVote.evidence;
            }
        }
        // Recompute avg if level vote was added
        const finalAvgScore = scores.length > 0
            ? scores.reduce((a,b)=>a+b,0) / scores.length
            : avgScore;

        // ═══════════════════════════════════════════════════════════
        // WYCKOFF PHASE CONTEXT (the master filter)
        // ═══════════════════════════════════════════════════════════
        // The market is always in one of three phases:
        //   MARKUP    — trending up (TRENDING_UP), making HH/HL
        //   MARKDOWN  — trending down (TRENDING_DN), making LH/LL
        //   RANGE     — RANGING, oscillating between defined boundaries
        //
        // The same setup means different things in different phases:
        //   • J-hook bottom in MARKUP     = strong long (continuation)
        //   • J-hook bottom in MARKDOWN   = weak long (counter-trend bounce)
        //   • J-hook bottom in RANGE      = moderate long (range bottom)
        //   • Triple top in MARKUP        = skip (trend will overpower it)
        //   • Triple top in MARKDOWN      = strong short (continuation)
        //   • Sweep below support in MARKUP = strong long (stop hunt before continuation)
        //   • Sweep above resist in MARKDOWN = strong short (same idea reversed)
        //
        // We classify the trade as ALIGNED, COUNTER, or NEUTRAL relative
        // to the higher-timeframe phase, then adjust score and firing
        // criteria accordingly.
        let phase = 'NEUTRAL';
        if(this.mktState === 'TRENDING_UP') phase = 'MARKUP';
        else if(this.mktState === 'TRENDING_DN') phase = 'MARKDOWN';
        else if(this.mktState === 'RANGING') phase = 'RANGE';

        let phaseAlignment = 'NEUTRAL';  // ALIGNED | COUNTER | NEUTRAL
        if(phase === 'MARKUP'){
            phaseAlignment = dir === 1 ? 'ALIGNED' : 'COUNTER';
        } else if(phase === 'MARKDOWN'){
            phaseAlignment = dir === -1 ? 'ALIGNED' : 'COUNTER';
        } else if(phase === 'RANGE'){
            // In a range, both directions are valid but only at the EDGES.
            // Range middle = NEUTRAL. We approximate "edge" by checking
            // if we're nearer the rangeHigh or rangeLow.
            if(this.rangeHigh > 0 && this.rangeLow > 0){
                const c0 = this.C[this.C.length-1] || 0;
                const rangeWidth = this.rangeHigh - this.rangeLow;
                const distFromHigh = this.rangeHigh - c0;
                const distFromLow = c0 - this.rangeLow;
                const edgeTolerance = rangeWidth * 0.3;  // top/bottom 30%
                if(dir === -1 && distFromHigh <= edgeTolerance){
                    phaseAlignment = 'ALIGNED';  // shorting at range top
                } else if(dir === 1 && distFromLow <= edgeTolerance){
                    phaseAlignment = 'ALIGNED';  // longing at range bottom
                } else {
                    phaseAlignment = 'NEUTRAL';
                }
            }
        }

        // High-conviction REVERSAL setups can override phase counter-bias.
        // These are the Wyckoff "spring" / "upthrust" patterns:
        //   • Sweep + reverse (false breakout) — explicit Wyckoff signal
        //   • J-hook retest at extreme (proven base/ceiling)
        //   • MTT zone (multiple rejection touches)
        // When any of these are involved AND the score is high (≥8),
        // counter-trend is permitted with reduced size penalty.
        const isReversalSetup =
            (this.sweepDir === dir && this.barIdx - this.sweepBar <= 4) ||
            (this.jhookActive && this.jhookDir === dir) ||
            (lt === 'MTT_H' && dir === -1) ||
            (lt === 'MTT_L' && dir === 1);

        if(phaseAlignment === 'COUNTER' && !isReversalSetup){
            // Trying to fade a clear trend without a Wyckoff reversal
            // signal. Penalize heavily — usually the wrong trade.
            reasons.push('PHASE_COUNTER_'+phase);
        }
        if(phaseAlignment === 'ALIGNED'){
            reasons.push('PHASE_ALIGNED_'+phase);
        }
        if(phaseAlignment === 'COUNTER' && isReversalSetup){
            reasons.push('REVERSAL_SETUP_AGAINST_'+phase);
        }

        // Save for diagnostics
        result.phase = phase;
        result.phaseAlignment = phaseAlignment;
        result.isReversalSetup = isReversalSetup;

        // ── DISAGREEMENT PENALTY ────────────────────────────────────
        // If any single framework strongly opposes the trade direction
        // (score >= 6 in the OTHER direction), that's a strong "don't"
        // — block the trade even if other frameworks agree.
        // Rationale: avoids the "shorts on a bull-trend day" problem we
        // saw — auction+flow vote short at PDH while structure clearly
        // says bull. Was firing 2-of-3. Now: structure with score 6+
        // bull blocks it.
        // strongOpposition: framework strongly opposing the trade.
        // EXCEPTION: when we have a clean reversal setup (MTT_H short,
        // MTT_L long, sweep, J-hook), structure's macro-trend bias is
        // EXPECTED to oppose — that's the whole point of a reversal
        // trade. The reversal level IS the structural reference. Skip
        // the structure veto in that case (auction and orderflow vetoes
        // still apply — those read CURRENT bar action).
        let strongOpposition = false;
        const oppositeDir = -dir;
        if(auction.dir === oppositeDir && auction.score >= 6){
            strongOpposition = true;
            reasons.push('A_BLOCKS@'+auction.score);
        }
        if(structure.dir === oppositeDir && structure.score >= 6 && !isReversalSetup){
            strongOpposition = true;
            reasons.push('S_BLOCKS@'+structure.score);
        }
        if(orderflow.dir === oppositeDir && orderflow.score >= 6){
            strongOpposition = true;
            reasons.push('F_BLOCKS@'+orderflow.score);
        }

        // ── IMPLICIT TREND BLOCK ────────────────────────────────────
        // Even when structure didn't vote (dir=0), if h1+h4 are both
        // strongly aligned in opposite direction, block. This catches
        // the case where structure was "neutral" on a pullback within
        // a clear higher-timeframe trend.
        const h1Bull = this.h1Trend==='BULL' || this.h1HigherLow;
        const h1Bear = this.h1Trend==='BEAR' || this.h1LowerHigh;
        const h4Bull = this.h4Trend==='BULL' || this.h4Dir===1;
        const h4Bear = this.h4Trend==='BEAR' || this.h4Dir===-1;
        if(structure.dir === 0){
            if(dir === -1 && h1Bull && h4Bull){
                strongOpposition = true;
                reasons.push('h1+h4_bull_blocks_short');
            }
            if(dir === 1 && h1Bear && h4Bear){
                strongOpposition = true;
                reasons.push('h1+h4_bear_blocks_long');
            }
        }

        // ── BOS COUNTER-TRADE BLOCK ─────────────────────────────────
        // Recent break of structure overrides everything else. If price
        // just broke down through a swing low and we're trying to LONG,
        // that's catching a falling knife — block it. Same in reverse.
        // This is what would have blocked today's mid-drop long after
        // the triple top broke down.
        if(this.bosDir !== 0 && this.bosTriggerBar > 0){
            const barsSinceBOS = this.barIdx - this.bosTriggerBar;
            if(barsSinceBOS <= 15 && dir === -this.bosDir){
                strongOpposition = true;
                reasons.push('BOS_'+(this.bosDir===1?'up':'down')+'_blocks_counter');
            }
        }

        // ── LEVEL CLASSIFICATION (DEMOTED list) ─────────────────────
        // STRONG levels (qualify for 2-of-3 firing): sigma bands and
        // confirmed wick zones. These are the structurally-meaningful
        // levels that produce real edge.
        // CONTEXT levels (require 3-of-3 like any other): PDH/PSH/PWH
        // and prior-day levels. They were being treated as "strong"
        // and qualifying weak 2-of-3 trades — that was the bug.
        const isStrongLevel = lt.includes('σ') ||
                              lt==='BWICK' || lt==='SWICK' ||
                              lt==='BWICK_INV' || lt==='SWICK_INV' ||
                              lt==='BAL_H' || lt==='BAL_L' ||
                              lt==='MTT_H' || lt==='MTT_L' ||
                              lt==='JHOOK_L' || lt==='JHOOK_H';
        // PDH/PSH/PWH/PDL/PSL/PWL/AH/AL/VWAP/BAL_M = context only,
        // NOT strong-level qualifying. They still appear in level list
        // (price needs to be near SOMETHING to consider trading), but
        // a 2-of-3 alignment at one of these is not enough alone.
        // MTT_H/MTT_L (multi-touch zones) ARE strong levels — they
        // represent confirmed supply/demand zones traders are watching.

        // ── DECISION ────────────────────────────────────────────────
        // votes can be 0-4 now (3 framework readers + level vote source).
        // Firing thresholds:
        //   4 votes (full alignment): fire anywhere
        //   3 votes: fire anywhere
        //   2 votes: fire only at strong level
        //   <2: don't fire
        // N3: the helper level-vote may CONFIRM (it adds score) and can help meet
        // the 2-of-3-at-strong-level rule, but it must NOT by itself promote a
        // weak-level 2-framework setup into the "fire anywhere" tier. The
        // "fire anywhere" branch uses the PRE-helper breadth.
        const frameworkBreadth = levelVoteAdded ? votesBeforeLevel : votes;
        if(strongOpposition || this._recentWyckoffBlocks){
            result.fire = false;
        } else if(frameworkBreadth >= 3){
            result.fire = true;                       // genuine 3-vote breadth → fire anywhere
        } else if(votes >= 2 && isStrongLevel){
            result.fire = true;                       // 2+ (helper may count) only at a strong level
        }
        // Minimum average quality
        if(result.fire && finalAvgScore < 5){
            result.fire = false;
            reasons.push('avg_score_too_low');
        }
        // ── WYCKOFF PHASE FILTER ────────────────────────────────────
        // Counter-phase trades require BOTH a reversal setup AND a
        // higher average score (≥7). This blocks "shorting in markup"
        // and "longing in markdown" unless we have explicit reversal
        // signal (sweep, J-hook, MTT, multi-helper stacked behavior).
        // Note: levelVoteAdded with single helper isn't enough for counter-
        // phase — must have ≥2 stacked helpers at strength ≥8 (genuine
        // reversal signature, not just one detection).
        const hasStackedReversal = levelVoteAdded && levelVoteStrength >= 8 &&
            levelVoteEvidence && levelVoteEvidence.length >= 2;
        if(result.fire && phaseAlignment === 'COUNTER'){
            if(!isReversalSetup && !hasStackedReversal){
                result.fire = false;
                reasons.push('counter_phase_without_reversal');
            } else if(finalAvgScore < 6){
                // Counter-phase with a reversal setup — these include MTT
                // touch (multi-tested level), fresh sweep, J-hook retest,
                // or stacked Wyckoff helpers. These ARE the moments to
                // trade against the macro phase. Threshold of 6 (was 7)
                // — a clean reversal at a multi-touch level shouldn't
                // require near-perfect framework alignment.
                result.fire = false;
                reasons.push('counter_phase_score_too_low');
            }
        }
        // Aligned-phase trades get a small effective bonus
        if(!result.fire && phaseAlignment === 'ALIGNED' && votes >= 2 &&
           isStrongLevel && finalAvgScore >= 5 && !strongOpposition &&
           !this._recentWyckoffBlocks){
            result.fire = true;
            reasons.push('aligned_phase_2of3');
        }
        // ── ZONE-FLIP REQUIREMENT (Ro's rule) ────────────────────────
        // "Don't trade the swing high/low — trade the zone that CREATED
        // it, and only AFTER the zone gets flipped." Apply this rule:
        // at a wick zone (BWICK/SWICK) or MTT level, with only moderate
        // conviction (score 5-6.5) and no recent BOS or sweep through
        // that zone, the trade is just a touch — not a flip. Hold off.
        //
        // A trade qualifies as having a "confirmed flip" if:
        //  - bosDir matches trade direction AND bos within last 8 bars, OR
        //  - sweepDir matches trade direction AND sweep within last 5 bars, OR
        //  - high conviction (avg score ≥ 6.5) — already cross-validated
        //    by multiple frameworks, treat as confirmed
        //
        // This stops trades that fire on a single-touch interaction with
        // a wick/MTT zone before price has actually proven that the
        // zone is breaking. Ro's loss-cutting absorption-pattern false
        // long is the canonical example.
        if(result.fire && nearLevel && finalAvgScore < 6.5){
            const lvType = nearLevel.type;
            const isWickOrMTT = lvType === 'BWICK' || lvType === 'SWICK' ||
                                 lvType === 'BWICK_INV' || lvType === 'SWICK_INV' ||
                                 lvType === 'MTT_H' || lvType === 'MTT_L';
            if(isWickOrMTT){
                const recentBOS = this.bosDir === dir &&
                                   this.bosTriggerBar > 0 &&
                                   (this.barIdx - this.bosTriggerBar) <= 8;
                const recentSweep = this.sweepDir === dir &&
                                     this.sweepBar > 0 &&
                                     (this.barIdx - this.sweepBar) <= 5;
                // Ro's flip rule: a wick zone closed-through in trade
                // direction = sentiment shifted, fire is licensed.
                const recentZoneFlip = this.lastZoneFlipDir === dir &&
                                        this.lastZoneFlipBar > 0 &&
                                        (this.barIdx - this.lastZoneFlipBar) <= 6;
                if(!recentBOS && !recentSweep && !recentZoneFlip){
                    result.fire = false;
                    reasons.push('zone_not_yet_flipped@'+lvType);
                }
            }
        }
        // ── APPROACHING-RESISTANCE/SUPPORT BLOCK ────────────────────
        // Prevent longing into known resistance (MTT_H/JHOOK_H) or
        // shorting into known support (MTT_L/JHOOK_L) even when frameworks
        // align. The level being CLOSE means the move has limited room
        // before hitting structural rejection — don't pile in.
        if(result.fire && dir === 1 && this._approachingResistance){
            const lv = this._approachingResistance;
            const strongTopLvl = (lv.type === 'MTT_H' && (lv.touches || 0) >= 2) ||
                                  lv.type === 'JHOOK_H';
            if(strongTopLvl){
                result.fire = false;
                reasons.push('approaching_'+lv.type+'@'+lv.price.toFixed(0));
            }
        }
        if(result.fire && dir === -1 && this._approachingSupport){
            const lv = this._approachingSupport;
            const strongBotLvl = (lv.type === 'MTT_L' && (lv.touches || 0) >= 2) ||
                                  lv.type === 'JHOOK_L';
            if(strongBotLvl){
                result.fire = false;
                reasons.push('approaching_'+lv.type+'@'+lv.price.toFixed(0));
            }
        }

        result.dir = dir;
        result.totalScore = Math.round(finalAvgScore * 10) / 10;
        result.setupTag = votes+'@'+lt;
        if(levelVoteAdded){
            result.setupTag += '+L'+levelVoteStrength;
        }
        result.reason = reasons.join(' | ');
        return result;
    }

    // ════════════════════════════════════════════════════════════════
    // RUNTIME EXIT INTELLIGENCE
    // ════════════════════════════════════════════════════════════════
    // While in a trade, these methods continuously read the market and
    // return signals that modify exit behavior. Two complementary checks:
    //
    //   _assessTrendStrength → 0-10 score of how well the trend is doing
    //     IN YOUR TRADE DIRECTION. Higher = let it run, looser trail.
    //     Lower = trend fading, tighten everything.
    //
    //   _assessThesisIntact → boolean. True if framework readers (auction,
    //     structure, orderflow) still support your trade direction.
    //     False = thesis broken, exit immediately.
    //
    // Together: strength tunes the magnitude of risk management, thesis
    // tells you when to abandon the trade entirely.

    _assessTrendStrength(c, h, l, atr, n, dir){
        // Returns { score: 0-10, reasons: [...] } where score is trend
        // strength in the dir direction. Higher = stronger continuation.
        if(n < 6 || dir === 0 || atr <= 0){
            return { score: 5, reasons: ['warmup'] };
        }
        let score = 5;  // neutral baseline
        const reasons = [];

        // 1. Range expansion (last 3 bars vs prior 3 bars in trade direction)
        const last3Range = ((this.H[n-1]-this.L[n-1]) +
                           (this.H[n-2]-this.L[n-2]) +
                           (this.H[n-3]-this.L[n-3])) / 3;
        const prior3Range = ((this.H[n-4]-this.L[n-4]) +
                            (this.H[n-5]-this.L[n-5]) +
                            (this.H[n-6]-this.L[n-6])) / 3;
        if(last3Range > prior3Range * 1.2){
            score += 1; reasons.push('range expanding');
        } else if(last3Range < prior3Range * 0.7){
            score -= 1; reasons.push('range compressing');
        }

        // 2. Volume on continuation vs pullback bars
        // Bars in trade direction are "continuation" — should have decent vol
        let contVolSum = 0, contCount = 0;
        let pbVolSum = 0, pbCount = 0;
        for(let i=Math.max(0,n-5); i<n; i++){
            const isCont = dir===1 ? this.C[i] >= (this.O[i]||this.C[i])
                                   : this.C[i] <= (this.O[i]||this.C[i]);
            if(isCont){ contVolSum += this.V[i]; contCount++; }
            else      { pbVolSum  += this.V[i]; pbCount++; }
        }
        if(contCount > 0 && pbCount > 0){
            const contAvg = contVolSum/contCount;
            const pbAvg   = pbVolSum/pbCount;
            if(contAvg > pbAvg * 1.3){
                score += 1; reasons.push('vol on continuation');
            } else if(pbAvg > contAvg * 1.3){
                score -= 1; reasons.push('vol on pullbacks');
            }
        }

        // 3. Delta agreement with trade direction (last 3 bars cumulative)
        let deltaSum = 0;
        for(let i=Math.max(0,n-3); i<n; i++) deltaSum += (this.D[i]||0);
        const deltaThresh = (this.avgVol || 1) * 0.15;
        if((dir===1 && deltaSum > deltaThresh) ||
           (dir===-1 && deltaSum < -deltaThresh)){
            score += 1; reasons.push('delta confirms');
        } else if((dir===1 && deltaSum < -deltaThresh*1.5) ||
                  (dir===-1 && deltaSum > deltaThresh*1.5)){
            score -= 2; reasons.push('delta diverging');
        }

        // 4. Pullback depth (am I retracing from an unrealized peak?)
        if(this.peakUnrealizedPnl > atr * 0.5 && this.position !== 0){
            const _unrl = dir===1 ? c - this.ep : this.ep - c;
            const retracePct = this.peakUnrealizedPnl > 0
                ? (this.peakUnrealizedPnl - _unrl) / this.peakUnrealizedPnl * 100
                : 0;
            if(retracePct > 60){
                score -= 2; reasons.push('deep pullback from peak');
            } else if(retracePct > 35){
                score -= 1; reasons.push('moderate pullback');
            } else if(retracePct < 15 && _unrl > atr*0.5){
                score += 1; reasons.push('holding peak');
            }
        }

        // 5. Higher-high / lower-low continuation
        if(n >= 4){
            const recentExtreme = dir===1
                ? Math.max(this.H[n-1], this.H[n-2], this.H[n-3])
                : Math.min(this.L[n-1], this.L[n-2], this.L[n-3]);
            const priorExtreme = dir===1
                ? Math.max(this.H[n-4]||0, this.H[n-5]||0, this.H[n-6]||0)
                : Math.min(this.L[n-4]||999999, this.L[n-5]||999999, this.L[n-6]||999999);
            if(dir===1 && recentExtreme > priorExtreme + atr*0.3){
                score += 1; reasons.push('new HH');
            } else if(dir===-1 && recentExtreme < priorExtreme - atr*0.3){
                score += 1; reasons.push('new LL');
            } else if((dir===1 && recentExtreme < priorExtreme) ||
                     (dir===-1 && recentExtreme > priorExtreme)){
                score -= 1; reasons.push('structure breaking');
            }
        }

        // 6. Last-bar candle health — small body / large opposite wick = doji-like indecision
        const lastBody = Math.abs(this.C[n-1] - this.O[n-1]);
        const lastRange = this.H[n-1] - this.L[n-1];
        if(lastRange > 0 && lastBody / lastRange < 0.25){
            score -= 1; reasons.push('indecision bar');
        }

        // Clamp to 0-10
        score = Math.max(0, Math.min(10, score));
        return { score, reasons };
    }

    _assessThesisIntact(c, h, l, o, vol, delta, atr, avgVol, n, dir, levels, nearLevel, nearDist){
        // Re-run the three framework readers. If 2+ now point AGAINST our
        // trade direction with score >= 5, thesis is broken — exit.
        // Returns { intact: bool, votesAgainst: int, reasons: [...] }
        if(dir === 0 || n < 5){
            return { intact: true, votesAgainst: 0, reasons: ['warmup'] };
        }

        // ── BOS REVERSAL FAST-EXIT ──
        // If price just broke structure in the OPPOSITE direction of our
        // trade, that's an instant exit signal — don't wait for 2-of-3
        // framework agreement. A long with BOS down means the move that
        // started our trade has structurally reversed.
        if(this.bosDir !== 0 && this.bosDir === -dir &&
           this.bosTriggerBar > 0 &&
           this.barIdx - this.bosTriggerBar <= 8){
            return {
                intact: false,
                votesAgainst: 99,  // marker for BOS-driven exit
                reasons: ['BOS_REVERSAL@'+this.bosBrokeLevel.toFixed(2)]
            };
        }

        const auctionR = this._readAuction(c, h, l, atr, levels, nearLevel, nearDist);
        const structR  = this._readStructure(c, h, l, atr);
        const flowR    = this._readOrderflow(c, h, l, o, vol, delta, atr, avgVol, n);
        const reasons = [];
        let votesAgainst = 0;
        const oppDir = -dir;
        if(auctionR.dir === oppDir && auctionR.score >= 5){
            votesAgainst++;
            reasons.push('A:'+auctionR.reason+'(s'+auctionR.score+')');
        }
        if(structR.dir === oppDir && structR.score >= 5){
            votesAgainst++;
            reasons.push('S:'+structR.reason+'(s'+structR.score+')');
        }
        if(flowR.dir === oppDir && flowR.score >= 5){
            votesAgainst++;
            reasons.push('F:'+flowR.reason+'(s'+flowR.score+')');
        }
        // Thesis broken when 2+ frameworks oppose with meaningful score
        return {
            intact: votesAgainst < 2,
            votesAgainst: votesAgainst,
            reasons: reasons
        };
    }

    // ─────────────────────────────────────────────────────────
    // MARKET-STATE CLASSIFIER
    // ─────────────────────────────────────────────────────────
    // Classify the current market into one of 6 regimes. Used by the
    // dynamic gate (refuse setups with poor historical WR in this
    // state) and surfaced in the HUD so the user can see the regime
    // the indicator is reading.
    //
    // States:
    //   TREND_UP    — slope strongly positive, HH made
    //   TREND_DOWN  — slope strongly negative, LL made
    //   ACCUMULATION— slope flat, range tight, CD positive
    //   DISTRIBUTION— slope flat, range tight, CD negative
    //   RANGE       — clear bounds, no directional bias
    //   CHOP        — high-frequency oscillation, no structure
    //   NEUTRAL     — not enough data yet
    _classifyMarketState(c, atr) {
        const N = 20;
        if (this.C.length < N + 1 || atr <= 0) return 'NEUTRAL';
        const start = this.C.length - N;
        // Linear regression slope
        let sumX=0, sumY=0, sumXY=0, sumX2=0;
        for (let i = 0; i < N; i++) {
            const x = i, y = this.C[start + i];
            sumX += x; sumY += y; sumXY += x*y; sumX2 += x*x;
        }
        const denom = (N * sumX2 - sumX * sumX);
        const slope = denom !== 0 ? (N * sumXY - sumX * sumY) / denom : 0;
        // Slope projected over the window, normalised to ATR
        const slopePerATR = (slope * N) / atr;

        // Recent range
        let hi = -Infinity, lo = Infinity;
        for (let i = 0; i < N; i++) {
            if (this.H[start + i] > hi) hi = this.H[start + i];
            if (this.L[start + i] < lo) lo = this.L[start + i];
        }
        const rangePerATR = (hi - lo) / atr;

        // CD direction (sign of cumDelta)
        const cdDir = this.cumDelta > 50 ? 1 : this.cumDelta < -50 ? -1 : 0;

        // Bar-color skew
        let upBars = 0, downBars = 0;
        for (let i = 0; i < N; i++) {
            const o = this.O[start + i], cc = this.C[start + i];
            if (cc > o) upBars++; else if (cc < o) downBars++;
        }

        // Decision tree
        if (slopePerATR > 1.8 && upBars >= 12) return 'TREND_UP';
        if (slopePerATR < -1.8 && downBars >= 12) return 'TREND_DOWN';
        if (Math.abs(slopePerATR) > 0.6) {
            // Weak trend — call it RANGE if range is tight, TREND if wide
            return rangePerATR > 4 ? (slopePerATR > 0 ? 'TREND_UP' : 'TREND_DOWN')
                                    : 'RANGE';
        }
        // Flat-ish slope
        if (rangePerATR < 2.5) {
            // Tight range — accumulation/distribution by CD direction
            if (cdDir === 1)  return 'ACCUMULATION';
            if (cdDir === -1) return 'DISTRIBUTION';
            return 'RANGE';
        }
        if (rangePerATR > 5 && Math.abs(upBars - downBars) < 4) return 'CHOP';
        return 'RANGE';
    }

    // Return historical (state, setupTag) stats: win-rate, sample size, and
    // total P&L. Null if fewer than 5 samples.
    _stateSetupWR(state, setupTag) {
        if (!this.stateStats[state]) return null;
        const s = this.stateStats[state][setupTag];
        if (!s) return null;
        const n = s.w + s.l;
        // N2: require a meaningful sample (was 5) before a per-(state,setup)
        // record is allowed to gate trading — 5 trades is noise, not evidence.
        if (n < 20) return null;
        return { wr: s.w / n, n, pnl: s.pnl };
    }

    // COIL detector — checks if the last N bars form a compression cluster.
    // Returns true if:
    //   - avg range of last N bars < 60% of ATR
    //   - max-min closes within 1.5 ATR (tight cluster)
    // Caller then watches the CURRENT bar for a strong-bodied breakout.
    _detectCoil(bi, atr, lookback) {
        const N = lookback || 6;
        const n = this.H.length;
        if (n < N + 2 || atr <= 0) return null;
        let sumRng = 0, hi = -Infinity, lo = Infinity;
        for (let i = n - 1 - N; i < n - 1; i++) {     // exclude current bar
            const rng = this.H[i] - this.L[i];
            sumRng += rng;
            if (this.C[i] > hi) hi = this.C[i];
            if (this.C[i] < lo) lo = this.C[i];
        }
        const avgRng = sumRng / N;
        if (avgRng > atr * 0.60) return null;         // not tight enough
        if ((hi - lo) > atr * 1.5) return null;       // closes too spread
        return { hi, lo, avgRng };
    }

    // Check the CURRENT bar for a strong-bodied breakout of the coil range.
    // Returns +1 (bull break), -1 (bear break), or 0.
    _coilBreakDir(coil, c, o, h, l, atr) {
        if (!coil || atr <= 0) return 0;
        const body = Math.abs(c - o);
        if (body < atr * 1.5) return 0;               // not a decisive bar
        if (c > coil.hi + atr * 0.1 && c > o) return 1;
        if (c < coil.lo - atr * 0.1 && c < o) return -1;
        return 0;
    }

    // Look for a recent bubble within `lookback` bars near `price` (within
    // `priceTol` ATR). Returns the strongest match keyed by direction (positive
    // delta = ask aggression = bullish; negative = bearish). null if none.
    _recentBubbleAtZone(price, atr, lookback, priceTol, bi) {
        if (!this.bubbles || this.bubbles.length === 0) return null;
        const tol = atr * priceTol;
        let best = null, bestAbs = 0;
        for (let i = this.bubbles.length - 1; i >= 0; i--) {
            const b = this.bubbles[i];
            if ((bi - b.bar) > lookback) break;
            if (Math.abs(b.price - price) <= tol) {
                if (Math.abs(b.delta) > bestAbs) {
                    bestAbs = Math.abs(b.delta);
                    best = b;
                }
            }
        }
        return best;
    }

    _findTPs(dir, price, levels, atr){
        const cands = levels
            .map(lv=>lv.price)
            .filter(p => dir===1 ? p>price+atr : p<price-atr)
            .sort((a,b) => dir===1 ? a-b : b-a);
        return [cands[0]||0, cands[1]||0];
    }

    // Helper — format wall-clock time as HH:MM string (24h) from a Date
    _fmtTime(date){
        if(!date) return '';
        try {
            const h = date.getUTCHours();
            const m = date.getUTCMinutes();
            return (h<10?'0':'')+h+':'+(m<10?'0':'')+m;
        } catch(e){ return ''; }
    }

    // Helper — append a journal event with current bar/time/session
    _logJournal(bi, sessKey, time, type, details){
        const entry = Object.assign({bar:bi, time:time, session:sessKey, type:type}, details||{});
        this.journal.push(entry);
        while(this.journal.length > 500) this.journal.shift();
        this.lastEventTime = time;
    }

    // Render the session report as text lines on the chart.
    // Called only when showReport=1. Prints:
    //   • Session header (current session key + counts + W/L + pnl)
    //   • Chronological event list (last ~30 entries)
    //   • Brief stats footer (calibration ratio, health summary)
    _renderReport(items, xToken, c, atr, _fz){
        if(!_fz) _fz = (n) => n;
        const lines = [];
        // Find which session(s) to show. If current session has events,
        // show those. Otherwise (e.g., we're now in '_overnight' after NY
        // closed at 4pm), find the most recent session that DID have
        // activity and show that report instead. This way the report
        // remains useful after session close.
        let showSession = this.sessKey;
        let curSessEvts = this.journal
            .filter(e => e.session === this.sessKey);
        let isCurrent = true;
        if(curSessEvts.length === 0 || (curSessEvts.length === 1 && curSessEvts[0].type === 'SESSION_START')){
            // Find the most recent OTHER session in the journal with real activity
            const sessions = {};
            for(const e of this.journal){
                if(!sessions[e.session]) sessions[e.session] = [];
                sessions[e.session].push(e);
            }
            // Pick the session with the highest bar number that has FIRED/BLOCKED/MISSED
            let bestSess = null, bestBar = -1;
            for(const sk in sessions){
                if(sk === this.sessKey) continue;
                for(const e of sessions[sk]){
                    if((e.type==='FIRED' || e.type==='BLOCKED' || e.type==='MISSED' || e.type==='EXIT')
                       && e.bar > bestBar){
                        bestBar = e.bar;
                        bestSess = sk;
                    }
                }
            }
            if(bestSess){
                showSession = bestSess;
                curSessEvts = sessions[bestSess];
                isCurrent = false;
            }
        }
        // Compute summary from the events being shown (not just live counters,
        // which only reflect the *current* session)
        let firedC = 0, blockedC = 0, missedC = 0, winsC = 0, lossesC = 0;
        let sessionPnlPts = 0;
        for(const e of curSessEvts){
            if(e.type === 'FIRED') firedC++;
            else if(e.type === 'BLOCKED') blockedC++;
            else if(e.type === 'MISSED') missedC++;
            else if(e.type === 'EXIT'){
                if(e.win) winsC++; else lossesC++;
                if(typeof e.pnl === 'number') sessionPnlPts += e.pnl;
            } else if(e.type === 'SESSION_END'){
                // Session_end has summary fields if available
                if(typeof e.fired === 'number') firedC = Math.max(firedC, e.fired);
                if(typeof e.wins === 'number')  winsC  = Math.max(winsC,  e.wins);
                if(typeof e.losses === 'number')lossesC= Math.max(lossesC,e.losses);
                if(typeof e.blocked === 'number')blockedC=Math.max(blockedC,e.blocked);
                if(typeof e.missed === 'number') missedC =Math.max(missedC, e.missed);
            }
        }

        lines.push('═══ SESSION REPORT ═══');
        // ── WEEKLY / ALL-TIME PROFITABILITY (across the full journal) ──
        // Aggregates EVERY recorded EXIT in memory, not just the active
        // session. Gives the numbers needed to evaluate the indicator's
        // expectancy + profit factor.
        const _allExits = this.journal.filter(e => e.type === 'EXIT');
        if(_allExits.length > 0){
            let _wPnl = 0, _lPnl = 0, _w = 0, _l = 0, _maxL = 0, _maxW = 0;
            const _bySess = {};
            const _bySetup = {};
            for(const e of _allExits){
                const _pnl = typeof e.pnl === 'number' ? e.pnl : 0;
                if(e.win){ _w++; _wPnl += _pnl; if(_pnl > _maxW) _maxW = _pnl; }
                else      { _l++; _lPnl += _pnl; if(_pnl < _maxL) _maxL = _pnl; }
                const _ses = e.session || 'UNKNOWN';
                if(!_bySess[_ses]) _bySess[_ses] = {w:0,l:0,pnl:0};
                _bySess[_ses][e.win?'w':'l']++;
                _bySess[_ses].pnl += _pnl;
            }
            const _tot = _w + _l;
            const _wr  = _tot>0 ? Math.round(_w/_tot*100) : 0;
            const _avgW = _w>0 ? (_wPnl/_w) : 0;
            const _avgL = _l>0 ? (_lPnl/_l) : 0;
            const _grossW = _wPnl;
            const _grossL = Math.abs(_lPnl);
            const _pf = _grossL>0 ? (_grossW/_grossL).toFixed(2) : '∞';
            const _expPt = _tot>0 ? ((_wPnl + _lPnl) / _tot) : 0;
            const _net$ = Math.round((_wPnl + _lPnl) * (this.autoContractValue || 2));
            lines.push('━━━ WEEKLY / ALL-TIME ━━━');
            lines.push('Trades '+_tot+'  W '+_w+'/L '+_l+'  WR '+_wr+'%');
            lines.push('Net '+(_net$>=0?'+$':'-$')+Math.abs(_net$)+
                       '  ('+(_wPnl+_lPnl>=0?'+':'')+(_wPnl+_lPnl).toFixed(1)+'pt)');
            lines.push('AvgW '+(_avgW>=0?'+':'')+_avgW.toFixed(1)+'pt'+
                       '  AvgL '+_avgL.toFixed(1)+'pt'+
                       '  Exp '+(_expPt>=0?'+':'')+_expPt.toFixed(2)+'pt/trade');
            lines.push('PF '+_pf+
                       '  MaxW '+_maxW.toFixed(1)+'pt'+
                       '  MaxL '+_maxL.toFixed(1)+'pt');
            // Sigma respect — how often each level holds vs breaks.
            const _sigKeys = Object.keys(this.sigmaStats || {});
            if(_sigKeys.length > 0){
                lines.push('Sigma respect:');
                const _order = ['1H','1L','2H','2L','3H','3L','4H','4L'];
                for(const _sk of _order){
                    const _ss = this.sigmaStats[_sk];
                    if(!_ss || _ss.touches < 1) continue;
                    const _resolved = _ss.reversals + _ss.breaks;
                    const _pct = _resolved>0 ? Math.round(_ss.reversals/_resolved*100) : 0;
                    lines.push('  '+_sk+': '+_ss.touches+' touches, '+
                               _ss.reversals+' reversals ('+_pct+'%)');
                }
            }
            // Bubble baseline for this chart — useful for tuning the
            // contra/hold floor params per chart (NY 4096t vs EVE 3072t).
            if(this.bubbleAvgAbs > 0){
                lines.push('Bubble avg|Δ|: '+this.bubbleAvgAbs.toFixed(0)+
                           '  contra≥'+Math.max(
                               (this.props && this.props.bubbleContraFloor!=null?this.props.bubbleContraFloor:200),
                               this.bubbleAvgAbs * 1.5).toFixed(0));
            }
            // Per-day rollup
            const _dayKeys = Object.keys(_bySess).sort();
            if(_dayKeys.length > 0){
                lines.push('Per session:');
                for(const _sk of _dayKeys.slice(-7)){
                    const _s = _bySess[_sk];
                    const _spt = (_s.pnl).toFixed(1);
                    lines.push('  '+_sk+'  '+_s.w+'W/'+_s.l+'L  '+
                               (_s.pnl>=0?'+':'')+_spt+'pt');
                }
            }
            // Per-state-per-setup table (online learning summary)
            const _stKeys = Object.keys(this.stateStats || {});
            if(_stKeys.length > 0){
                lines.push('Per state × level type:');
                for(const _st of _stKeys){
                    const _setups = this.stateStats[_st];
                    for(const _lt in _setups){
                        const _ss = _setups[_lt];
                        const _stTot = _ss.w + _ss.l;
                        if(_stTot < 1) continue;
                        const _stwr = Math.round(_ss.w/_stTot*100);
                        lines.push('  '+_st+' × '+_lt+': '+
                                   _ss.w+'W/'+_ss.l+'L ('+_stwr+'%)  '+
                                   (_ss.pnl>=0?'+':'')+_ss.pnl.toFixed(1)+'pt');
                    }
                }
            }
            lines.push('───────────────────────');
        }
        lines.push('Session: '+showSession+(isCurrent?' (live)':' (closed)'));
        lines.push('Fired: '+firedC+
                   '  Wins: '+winsC+
                   '  Losses: '+lossesC+
                   '  PnL: '+(sessionPnlPts>=0?'+':'')+sessionPnlPts.toFixed(0)+'pt');
        lines.push('Blocked: '+blockedC+'  Missed: '+missedC);
        lines.push('Health: '+this.healthVerdict+
                   (this.healthVerdict!=='OK'?' ('+this.healthMsg+')':''));
        lines.push('Wick params: min='+(this.liveWickMinAtr||0).toFixed(2)+
                   '  body='+(this.liveWickBodyRatio||0).toFixed(2)+
                   '  cluster='+(this.liveClusterMinWicks||3));
        lines.push('───────────────────────');
        lines.push('EVENTS (most recent last)');
        lines.push('───────────────────────');
        // ── EVENT PRIORITIZATION ──
        // The journal accumulates 500 events but the chart can only
        // display ~30 readable lines. Prioritize FIRED, EXIT, MISSED,
        // TUNE, HEALTH, SESSION events first (these are the most
        // informative) — fill remaining slots with most recent BLOCKED
        // entries. This ensures the user always sees their trades and
        // the misses, not just a wall of BLOCKED entries.
        const importantEvts = curSessEvts.filter(e =>
            e.type === 'FIRED' || e.type === 'EXIT' ||
            e.type === 'MISSED' || e.type === 'TUNE' ||
            e.type === 'HEALTH' || e.type === 'SESSION_START' ||
            e.type === 'SESSION_END');
        const blockedEvts = curSessEvts.filter(e => e.type === 'BLOCKED');
        // Show all important events + most recent N blocked to fill space
        const importantCount = importantEvts.length;
        const blockedSlots = Math.max(0, 30 - importantCount);
        const recentBlocked = blockedEvts.slice(-blockedSlots);
        // Re-merge in chronological order
        const sessEvts = [...importantEvts, ...recentBlocked]
            .sort((a, b) => a.bar - b.bar)
            .slice(-30);
        if(sessEvts.length===0){
            lines.push('(no events yet in this session)');
        } else {
            for(const e of sessEvts){
                lines.push(this._formatEvent(e));
            }
        }
        // Render lines top-to-bottom on chart
        // Start from upper area (price + atr*4) and move down
        const lineH = atr*0.65;  // line height in price units
        let yPos = c + atr*5;
        for(let i=0; i<lines.length; i++){
            const ln = lines[i];
            // Highlight headers and key lines with bold
            const isHeader = ln.startsWith('═') || ln.startsWith('─');
            const isStat = ln.startsWith('Session') || ln.startsWith('Fired') ||
                            ln.startsWith('Blocked') || ln.startsWith('Health') ||
                            ln.startsWith('Wick');
            const col = isHeader ? '#88AACC' :
                        isStat   ? '#DDDDFF' :
                        ln.startsWith('  FIRED') ? '#00FFCC' :
                        ln.startsWith('  EXIT')  ? (ln.indexOf('WIN')>=0?'#00DC78':'#E24B4A') :
                        ln.startsWith('  BLOCKED')? '#888888' :
                        ln.startsWith('  MISSED') ? '#FFAA66' :
                        ln.startsWith('  TUNE')   ? '#FFCC44' :
                        ln.startsWith('  HEALTH') ? '#FFAA22' :
                        ln.startsWith('  SESSION')? '#88AACC' :
                                                    '#CCCCCC';
            items.push({tag:'Text', key:'rep_'+i,
                text: ln,
                point:{x:xToken, y:du(yPos - i*lineH)},
                style:{fontSize:_fz(10), fontWeight:isHeader||isStat?'bold':'normal', fill:col},
                textAlignment:'leftMiddle', global:true});
        }
    }

    // Format a single journal entry as a readable line.
    _formatEvent(e){
        const t = e.time || '?';
        switch(e.type){
            case 'FIRED': {
                const dirStr = e.dir===1?'LONG':'SHORT';
                const out = e.exitReason
                    ? '  → '+e.exitReason+(e.exitWin?' WIN ':' LOSS ')+
                      (e.exitPnl>=0?'+':'')+(e.exitPnl||0).toFixed(0)+'pt'
                    : ' (open)';
                return '  FIRED '+t+' '+dirStr+' '+e.behavior+' @'+e.ep+out;
            }
            case 'EXIT':
                return '  EXIT  '+t+' '+(e.win?'WIN ':'LOSS ')+
                       (e.pnl>=0?'+':'')+(e.pnl||0).toFixed(0)+'pt ('+e.reason+')';
            case 'BLOCKED':
                return '  BLOCKED '+t+' '+e.reason+' @'+e.level+
                       ' (mkt='+e.mktState+', pb='+e.pbClass+')';
            case 'MISSED': {
                // Show why we missed plus what each reader saw at the bar.
                // Format: A:dir/score S:dir/score F:dir/score abs:N step:Y
                const dirSym = (d) => d===1?'+':d===-1?'-':'·';
                const readerSummary =
                    'A'+dirSym(e.aDir)+(e.aScore||0)+
                    ' S'+dirSym(e.sDir)+(e.sScore||0)+
                    ' F'+dirSym(e.fDir)+(e.fScore||0);
                const patternSummary = (e.absSeqBars>0 ? ' abs'+e.absSeqBars : '') +
                                       (e.steppingIn ? ' step' : '');
                const lvSummary = e.nearLv && e.nearLv !== 'none'
                    ? ' @'+e.nearLv+'('+e.nearDistATR+'σ)'
                    : '';
                return '  MISSED  '+t+' '+(e.dir===1?'LONG':'SHORT')+
                       ' @'+e.price+lvSummary+' '+readerSummary+patternSummary+
                       ' why:'+e.why;
            }
            case 'TUNE':
                return '  TUNE  '+t+' '+e.param+' '+e.oldVal+'→'+e.newVal+
                       ' ('+e.reason+')';
            case 'HEALTH':
                return '  HEALTH '+t+' → '+e.verdict+': '+e.msg;
            case 'SESSION_START':
                return '  SESSION '+t+' START open='+(e.open||0).toFixed(0);
            case 'SESSION_END':
                return '  SESSION '+t+' END  '+e.fired+'F '+e.wins+'W/'+
                       e.losses+'L  pnl='+(e.pnl>=0?'+$':'-$')+Math.abs(e.pnl||0);
            default:
                return '  '+e.type+' '+t;
        }
    }

    // ── DIAGNOSTICS ENGINE ──────────────────────────────────────────
    // Runs every 20 bars from map(). Computes a health verdict and
    // (if verdict allows) decides whether to auto-tune.
    //
    // Verdicts: OK | WARN | ERROR
    //   OK    = all subsystems nominal, auto-tune allowed if calibration off
    //   WARN  = something looks unusual but not broken (e.g., 1 behavior disabled)
    //   ERROR = something is broken (no levels, ATR=0, state stuck) — alert user
    _runHealthCheck(bi, atr, avgVol){
        const issues = [];
        let verdict = 'OK';
        // Check 1: pipeline integrity
        if(atr <= 0)            { issues.push('ATR=0'); verdict='ERROR'; }
        if(!isFinite(avgVol) || avgVol <= 0) { issues.push('avgVol invalid'); verdict='ERROR'; }
        if(this.exp1H <= 0)     { issues.push('sigmas not computed'); verdict='ERROR'; }
        const lvls = this._getLevels();
        if(lvls.length < 2)     { issues.push('no levels available'); verdict='ERROR'; }
        // Check 2: state freshness
        if(bi - this.mktStateBar > 200){
            issues.push('mktState frozen '+(bi-this.mktStateBar)+'b');
            if(verdict==='OK') verdict='WARN';
        }
        // Check 3: behavior bucket health (any behaviors auto-disabled?)
        let disabledCount = 0;
        const disabledList = [];
        for(const k in this.behaviorStats){
            const s = this.behaviorStats[k];
            if(s.l - s.w >= 5 && s.pnl < -200){
                disabledCount++;
                disabledList.push(k);
            }
        }
        if(disabledCount >= 3){
            issues.push(disabledCount+' bhv disabled: '+disabledList.join(','));
            if(verdict==='OK') verdict='WARN';
        } else if(disabledCount >= 1){
            issues.push(disabledCount+' bhv disabled');
        }
        // Check 4: signal pipeline — anything firing?
        const recentAttempts = this.signalAttempts.filter(a => bi - a.bar < 200);
        const recentFires = recentAttempts.filter(a => a.blockReason === 'OK').length;
        const recentSetups = this.postHocSetups.filter(p => bi - p.bar < 200);
        // Only flag silence if there were actual setups available
        if(recentFires === 0 && recentSetups.length >= 3 && bi > 100){
            issues.push('0 fires vs '+recentSetups.length+' setups');
            if(verdict==='OK') verdict='WARN';
        }
        // Check 5: filter calibration ratio (basis for auto-tune)
        const setupCount = recentSetups.length;
        const fireCount = recentFires;
        let calibrationOff = false;
        let calibReason = '';
        if(setupCount >= 5 && fireCount === 0){
            calibrationOff = true;
            calibReason = 'too tight ('+fireCount+'/'+setupCount+')';
        } else if(setupCount >= 8 && fireCount/setupCount < 0.25){
            calibrationOff = true;
            calibReason = 'low capture ('+fireCount+'/'+setupCount+')';
        }
        // Build human-readable message
        if(issues.length === 0){
            this.healthMsg = 'OK';
        } else {
            this.healthMsg = issues.join('; ');
        }
        this.healthVerdict = verdict;
        this.lastHealthCheckBar = bi;
        if(this.healthLog.length === 0 ||
           this.healthLog[this.healthLog.length-1].verdict !== verdict){
            this.healthLog.push({bar:bi, verdict, reason:this.healthMsg});
            if(this.healthLog.length > 50) this.healthLog.shift();
            // Journal: only log non-OK transitions (OK→OK is silence)
            if(verdict !== 'OK'){
                this._logJournal(bi, this.sessKey, this.lastEventTime, 'HEALTH', {
                    verdict: verdict,
                    msg: this.healthMsg
                });
            }
        }
        // Return calibration info for auto-tuner
        return { verdict, calibrationOff, calibReason, fireCount, setupCount };
    }

    // ── AUTO-TUNER ──────────────────────────────────────────────────
    // Conservative parameter adjustment, gated by diagnostics.
    // Rules:
    //   • Only acts when health verdict = OK
    //   • Only after 200 bars cooldown since last tune
    //   • Adjusts ONE param at a time, by 5% of current value
    //   • Stays within hard bounds
    //   • Logs every action with reason and bar number
    //   • Probation tracking: monitors if change improved capture rate;
    //     reverts if next 100 bars show worse output
    _autoTune(bi, calib){
        // Forward-test / honesty guard: when params are frozen the strategy is
        // a STABLE target you can measure. Auto-tuning mid-test makes every
        // trade a different system → expectancy becomes meaningless.
        if((this.props||{}).freezeTuning) return null;
        // Don't tune if not OK
        if(this.healthVerdict !== 'OK') return null;
        if(!calib.calibrationOff) return null;
        // Cooldown — 150 bars between adjustments (balanced setting:
        // not so eager it bounces values around mid-session, not so
        // slow it never adapts within a session).
        if(bi - this.lastAutoTuneBar < 150) return null;
        // Pick the most impactful param to adjust based on the symptom
        // "Too tight" / "low capture" → loosen wick detection
        // We adjust wickMinAtr first (biggest impact), then wickBodyRatio
        let target = null;
        if(this.liveWickMinAtr > 0.35){
            target = 'wickMinAtr';
        } else if(this.liveWickBodyRatio > 0.25){
            target = 'wickBodyRatio';
        } else if(this.liveClusterMinWicks > 2){
            target = 'clusterMinWicks';
        }
        if(!target) return null;  // already at bounds
        // Compute new value (7% step — balanced between conservative 5%
        // and moderate 10%)
        let oldVal, newVal;
        if(target === 'wickMinAtr'){
            oldVal = this.liveWickMinAtr;
            newVal = Math.max(0.35, oldVal * 0.93);
            this.liveWickMinAtr = newVal;
        } else if(target === 'wickBodyRatio'){
            oldVal = this.liveWickBodyRatio;
            newVal = Math.max(0.25, oldVal * 0.93);
            this.liveWickBodyRatio = newVal;
        } else {
            oldVal = this.liveClusterMinWicks;
            newVal = Math.max(2, oldVal - 1);
            this.liveClusterMinWicks = newVal;
        }
        // Log + start probation tracking
        const rec = {
            bar:bi, param:target,
            oldVal:Math.round(oldVal*1000)/1000,
            newVal:Math.round(newVal*1000)/1000,
            reason:calib.calibReason
        };
        this.autoTuneLog.push(rec);
        if(this.autoTuneLog.length > 20) this.autoTuneLog.shift();
        this.lastAutoTuneBar = bi;
        this.tuneProbation[target] = {
            sinceBar: bi,
            baselineFires: calib.fireCount,
            baselineSetups: calib.setupCount,
            oldVal
        };
        // Also append to the structured journal for the report
        this._logJournal(bi, this.sessKey, this.lastEventTime, 'TUNE', {
            param: target,
            oldVal: rec.oldVal,
            newVal: rec.newVal,
            reason: rec.reason
        });
        return rec;
    }

    // Probation revert check — call separately, looks at probation
    // window (100 bars after a tune) and reverts if capture got worse.
    _checkRevert(bi){
        for(const k in this.tuneProbation){
            const pr = this.tuneProbation[k];
            if(bi - pr.sinceBar < 100) continue;  // probation window not done
            // Compute new fire/setup ratio in this window
            const newFires = this.signalAttempts
                .filter(a => a.bar > pr.sinceBar && a.blockReason==='OK').length;
            const newSetups = this.postHocSetups
                .filter(p => p.bar > pr.sinceBar).length;
            // If we've gone backwards (less captures), revert
            const oldRatio = pr.baselineSetups>0 ? pr.baselineFires/pr.baselineSetups : 0;
            const newRatio = newSetups>0 ? newFires/newSetups : 0;
            const worse = newSetups > 0 && newRatio < oldRatio - 0.1;
            if(worse){
                // Revert
                if(k === 'wickMinAtr')        this.liveWickMinAtr = pr.oldVal;
                else if(k === 'wickBodyRatio') this.liveWickBodyRatio = pr.oldVal;
                else if(k === 'clusterMinWicks') this.liveClusterMinWicks = pr.oldVal;
                this.autoTuneLog.push({
                    bar:bi, param:k+' (REVERT)',
                    oldVal: 0, newVal: pr.oldVal,
                    reason:'capture worsened'
                });
                if(this.autoTuneLog.length > 20) this.autoTuneLog.shift();
            }
            // End probation either way
            delete this.tuneProbation[k];
        }
    }
}

function expPlotter(canvas, indicator, history){
    // Draw the expected-move bands as full-width horizontal levels straight
    // from the live anchor + EM value. This deliberately does NOT reconstruct
    // levels by matching per-bar history fields (session id / stored exp
    // value) — that matching broke whenever the chart was rebuilt (tick-count
    // change, tick<->time switch), which is why the lines vanished or jumped.
    // Anchoring off indicator state makes it chart-type-independent.
    try{
        if(!history || !history.data || history.data.length===0) return;
        const pt = plottingTools;
        const first = history.get(0);
        const last  = history.get(history.data.length-1);
        if(!first || !last) return;
        const lx = pt.x.get(first);
        const rx = pt.x.get(last);
        if(lx===null || rx===null) return;
        const ex = pt.x.relative(rx, 3000);
        const span = (y,color,width,opacity)=>{
            if(!(y>0)) return;
            canvas.drawLine(pt.offset(lx,y), pt.offset(ex,y), {color:color,lineWidth:width,opacity:opacity});
        };

        // ── Daily expected-move bands ──────────────────────────────────────
        // EM value: the setting if Tradovate passes it, else the EM_DAILY
        // constant. Anchor: pasted RTH_OPEN, else auto-detected 9:30 open,
        // else the current session open.
        let em = (indicator.props && Number(indicator.props.expMoveDaily)) || 0;
        if(!(em > 0)) em = EM_DAILY;
        const _rthIn = (indicator.props && Number(indicator.props.rthOpen)) || 0;
        let anchor = _rthIn > 0              ? _rthIn
                   : RTH_OPEN > 0            ? RTH_OPEN
                   : indicator.rthOpen > 0   ? indicator.rthOpen
                   : indicator.sessOpen > 0  ? indicator.sessOpen : 0;
        if(anchor > 0 && em > 0){
            span(anchor,         '#00FF88', 1, 0.35);  // 9:30 open
            span(anchor+em*0.5,  '#00CCFF', 2, 1.0);   // ±0.5σ
            span(anchor-em*0.5,  '#00CCFF', 2, 1.0);
            span(anchor+em,      '#FF8C00', 1, 0.85);   // ±1σ
            span(anchor-em,      '#FF8C00', 1, 0.85);
            span(anchor+em*1.5,  '#FFEE00', 1, 0.75);   // ±1.5σ
            span(anchor-em*1.5,  '#FFEE00', 1, 0.75);
            span(anchor+em*2.0,  '#FF2244', 2, 0.9);    // ±2σ
            span(anchor-em*2.0,  '#FF2244', 2, 0.9);
        }

        // ── Weekly (purple) / monthly (pink) bands ─────────────────────────
        // Own fixed numbers, anchored at the week open / month open. They
        // stay put for the whole week/month and don't move with the daily.
        let emW = (indicator.props && Number(indicator.props.expMoveWeekly)) || 0;
        if(!(emW > 0)) emW = EM_WEEKLY;
        let emM = (indicator.props && Number(indicator.props.expMoveMonthly)) || 0;
        if(!(emM > 0)) emM = EM_MONTHLY;
        const wkA = indicator.weekOpen || 0;
        const moA = indicator.monthOpen || 0;
        if(wkA > 0 && emW > 0){ span(wkA+emW, '#B388FF', 2, 0.8); span(wkA-emW, '#B388FF', 2, 0.8); }
        if(moA > 0 && emM > 0){ span(moA+emM, '#FF88DD', 2, 0.7); span(moA-emM, '#FF88DD', 2, 0.7); }
    } catch(e){}
}

module.exports = {
    name:       'SD_MarketReader',
    calculator: MarketReader,
    inputType:  'bars',
    // Enable per-bar volume-profile data (d.profile()) so the bubble
    // detector can read price-level bid/ask volume.
    requirements: {
        volumeProfiles: true,
    },
    plotter: [
        predef.plotters.custom(expPlotter)
    ],
    params: {
        tzOffsetHours: predef.paramSpecs.number(-4,1,-12),
        // Expected-move levels (options-implied). Step is 1 so any value
        // (e.g. 455) is accepted, not just multiples of 25. Default 0: when
        // left at 0 the bands use the EM_DAILY / EM_WEEKLY / EM_MONTHLY code
        // constants at the top of the file. NOTE: Tradovate does not reliably
        // pass these Settings to the indicator, so the code constants are the
        // guaranteed control — set them there if a Settings change has no effect.
        expMoveDaily:   predef.paramSpecs.number(0, 1, 0),
        expMoveWeekly:  predef.paramSpecs.number(0, 1, 0),
        expMoveMonthly: predef.paramSpecs.number(0, 1, 0),
        // rthOpen: today's exact 9:30 RTH open price; the daily bands anchor
        // here. 0 = auto-detect (only approximate on tick charts, so paste
        // the real open). Step 0.25 = NQ tick, so prices like 29902.25 work.
        rthOpen:        predef.paramSpecs.number(0, 0.25, 0),
        // 0 = hide historical fallback sigmas from the chart. They remain
        // available internally, but only true user-entered expected moves
        // draw by default.
        showFallbackSigmas: predef.paramSpecs.number(0, 1, 0),
        // contractValuePt: $/point per contract. Set to 0 (default) to
        // let the indicator auto-detect from the instrument profile —
        // MNQ=$2, MGC=$10. Override only if you trade full contracts
        // (NQ=$20, GC=$100) or another instrument.
        contractValuePt: predef.paramSpecs.number(0,1,0),
        maxDailyLoss:    predef.paramSpecs.number(400,50,0),
        maxDailyTrades:  predef.paramSpecs.number(8,1,1),
        riskPerTrade:    predef.paramSpecs.number(100,25,0),
        // maxContracts: hard cap on risk-based size (H4). qty = floor(
        //   riskPerTrade / per-contract$ risk), clamped to [1, this].
        maxContracts:    predef.paramSpecs.number(10,1,1),
        // maxStopAtr: hard cap on stop distance in ATRs (N4). Bounds per-trade
        //   risk when a level-anchored stop would otherwise be very wide.
        maxStopAtr:      predef.paramSpecs.number(3.0, 0.5, 1.0),
        // instrument: 0=auto-detect from price, 1=NQ/MNQ, 2=GC/MGC (M2).
        instrument:      predef.paramSpecs.number(0,1,0),
        // ── FORWARD-TEST / HONESTY CONTROLS ──
        // freezeTuning: 1 = lock auto-tuned detection params (REQUIRED for a
        //   valid forward test). Default flipped to 1 — auto-tune is curve-fit
        //   risk; set 0 to restore the old self-adjusting behavior.
        freezeTuning:  predef.paramSpecs.number(1,1,0),
        // forwardLog: 1 = print one 'SDTRADE,' line per closed trade. Defaults ON
        //   (forward-test build) so it's paste-and-go; set 0 to silence the log.
        forwardLog:    predef.paramSpecs.number(1,1,0),
        // Session toggles — 1=on, 0=off. NY+Evening on by default.
        tradeNY:       predef.paramSpecs.number(1,1,0),
        tradeEvening:  predef.paramSpecs.number(1,1,0),
        tradeAsia:     predef.paramSpecs.number(1,1,0),
        tradeLondon:   predef.paramSpecs.number(0,1,0),
        // ── WICK-ZONE TUNING (Wick Sauce framework) ──
        // wickMinAtr: Minimum wick length as ATR multiple. Higher = stricter,
        //   fewer zones marked. Lower = looser, more zones (can clutter).
        //   Default 0.6 works for 4096-tick NQ. Try 0.45-0.5 for smaller
        //   tick sizes, 0.75-0.8 if you want only the biggest rejections.
        wickMinAtr:        predef.paramSpecs.number(0.6, 0.05, 0.1),
        // wickBodyRatio: Wick must be > X * candle body to count. Filters
        //   out big-body candles with token wicks. Higher = stricter.
