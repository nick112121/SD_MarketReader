        diagMode:          predef.paramSpecs.number(1, 1, 0),
        autoTune:          predef.paramSpecs.number(0, 1, 0),
        // showReport: 1 = fill the chart with the structured session report
        //   (events, stats, health, params). 0 = hide. Toggle on demand —
