        //   cluster. 3 is the textbook minimum. 4-5 = stronger zones only.
        clusterMinWicks:   predef.paramSpecs.number(3, 1, 2),
        // wickTrendLookback: Bars used to determine short-term trend for
        //   inverted-wick detection. Smaller = more reactive, picks up
        //   short pullbacks. Larger = only marks inversions vs sustained trend.
        wickTrendLookback: predef.paramSpecs.number(5, 1, 2),
        // ── DISPLAY MODE ──
        // simpleMode: 1 = clean signal-focused chart (recommended for trading)
        //   • Flat: just sigmas + nearest 2 levels + status text
